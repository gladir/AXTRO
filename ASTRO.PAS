Begin
 { --- Valeurs par defaut --- }
 nmobj:='Comete';
 mgr:=0.15; mgt:=10.0; flgt:=True; flgn:=False;
 flfng:=False; fnga1:=0; fnga2:=0; fnga3:=0;
 flobs:=True; fldtl:=False; flprt:=True;
 anorg:=0; tosc:=0; eqr:=2000;
 eps2:=10547681*pi/81000000;
 eps1:=16880971*pi/129600000;
 eps0:=84428261*pi/648000000;

 { Type d'orbite : E (defaut) / P / H, demande par 2 YesNo }
 If YesNo('Comete','Orbite parabolique (q et T seulement) ?') Then typ:='P'
 Else If YesNo('Comete','Orbite hyperbolique (e>1) ?') Then typ:='H'
 Else typ:='E';

 { --- Saisie des elements via dialogues --- }
 If Not InputDateTime('Comete - Instant du passage au perihelie T (TE)',
                      qu,ms,an,hr,mn,sc) Then Exit;
 tpas:=jj(qu,ms,an,hr,mn,sc);
 tpr:='J';  { force la date du perihelie en jour julien (deja calcule) }

 If Not InputReal('Comete','Distance perihelique q (UA) :',dper) Then Exit;
 If dper<=0 Then Begin ShowMessage('Erreur','q doit etre > 0'); Exit; End;

 Case typ Of
  'E' : Begin
         If Not InputReal('Comete','Excentricite e (0<=e<1) :',exc) Then Exit;
         If (exc<0) Or (exc>=1) Then
          Begin ShowMessage('Erreur','Excentricite hors bornes pour ellipse'); Exit; End;
         dga:=dper/(1-exc);
        End;
  'P' : Begin exc:=1.0; dga:=dper; End;
  'H' : Begin
         If Not InputReal('Comete','Excentricite e (>1) :',exc) Then Exit;
         If exc<=1 Then Begin ShowMessage('Erreur','e doit etre > 1 pour hyperbole'); Exit; End;
         dga:=dper/(exc-1);
        End;
 End;

 If Not InputReal('Comete','Argument du perihelie omega (degres) :',prr) Then Exit;
 If Not InputReal('Comete','Longitude du noeud ascendant Omega (degres) :',ndr) Then Exit;
 If Not InputReal('Comete','Inclinaison i (degres) :',inr) Then Exit;

 { Equinoxe des elements : par defaut J2000 ; YesNo pour les anciens }
 If YesNo('Comete','Elements rapportes a B1950 ?') Then eqr:=1950
 Else If YesNo('Comete','Elements rapportes a B1900 ?') Then eqr:=1900
 Else eqr:=2000;

 If YesNo('Comete','Estimation de la magnitude totale ?') Then
  Begin
   flgt:=True;
   If Not InputReal('Comete','Magnitude absolue H :',mgt) Then Exit;
   If Not InputReal('Comete','Parametre de pente G (typiquement 0.15) :',mgr) Then Exit;
   If mgr<0 Then mgr:=0;
  End
 Else flgt:=False;

 AngtoVec;
 tosc:=tpas;
 otd:=tpas;
 ComputeStateAtTosc;

 { --- Saisie de la date d'observation --- }
 If Not InputDateTime('Comete - Date d''observation (TE)',
                      qu,ms,an,hr,mn,sc) Then Exit;

 RClear;
 ResultTitle:='Ephemeride cometaire ('+nmobj+')';
 RWriteLn('Elements osculateurs (equinoxe '+FmtI(eqr,4)+') :');
 RWriteLn('  T perihelie : '+FmtF(tpas,15,6)+' JJ');
 RWriteLn('  q = '+FmtF(dper,10,7)+' UA   e = '+FmtF(exc,10,7));
 If typ<>'P' Then RWriteLn('  a = '+FmtF(dga,10,7)+' UA');
 RWriteLn('  omega = '+FmtF(prr,9,4)+' deg   Omega = '+FmtF(ndr,9,4)+' deg   i = '+FmtF(inr,9,4)+' deg');
 RWriteLn('  Etat initial (UA, km/s) : '+FmtF(xc0/UA,10,6)+' '+FmtF(yc0/UA,10,6)+' '+FmtF(zc0/UA,10,6));
 RWriteLn('                            '+FmtF(vx0,10,6)+' '+FmtF(vy0,10,6)+' '+FmtF(vz0,10,6));

 jd:=jj(qu,ms,an,hr,mn,sc);
 EphCometeAt;
 ResultsShow;
End;

