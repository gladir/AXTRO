Procedure RClear;
Begin
 ResultCount:=0;
 CurLine:='';
End;

Procedure RAppendLine(Const S:TStrLine);
Begin
 If ResultCount<MAX_RESULTS Then Begin
  ResultLines[ResultCount]:=S;
  Inc(ResultCount);
 End;
End;

Procedure RWriteLn(Const S:String);
{ Equivalent de writeln(S) - termine la ligne courante puis ajoute la nouvelle. }
Begin
 If CurLine<>'' Then Begin
  RAppendLine(CurLine);
  CurLine:='';
 End;
 RAppendLine(S);
End;

Procedure RWrite(Const S:String);
{ Equivalent de write(S) - accumule sans terminer. }
Begin
 If Length(CurLine)+Length(S) > RESULT_LINE_LEN Then Begin
  RAppendLine(CurLine);
  CurLine:='';
 End;
 CurLine:=CurLine+S;
End;

Procedure RFlush;
Begin
 If CurLine<>'' Then Begin
  RAppendLine(CurLine);
  CurLine:='';
 End;
End;

{ Helpers de formatage compacts pour les Do* (alternative a writeln(x:n:p)). }

Function FmtI(V:LongInt; W:Integer):String;
Var S:String;
Begin
 Str(V:W,S);
 FmtI:=S;
End;

Function FmtF(V:Extended; W,D:Integer):String;
Var S:String;
Begin
 Str(V:W:D,S);
 FmtF:=S;
End;

Function FmtS(Const S:String; W:Integer):String;
Var R:String;
Begin
 R:=S;
 While Length(R)<W Do R:=' '+R;
 FmtS:=R;
End;

{ Forward pour utilisation depuis ResultsShow (definis plus bas). }
Function  InputString(Const Title,Prompt:String; Var S:String;
                      MaxLen:Integer):Boolean; Forward;
Procedure ShowMessage(Const Title,Msg:String); Forward;

{ Sauvegarde le contenu accumule dans un fichier texte. }
Procedure ResultsSaveToFile;
Var FN:String;
    F:Text;
    I:Integer;
Begin
 FN:='RESULTS.TXT';
 If Not InputString('Sauvegarder les resultats',
                    'Nom du fichier texte :',FN,60) Then Exit;
 If FN='' Then Exit;
 {$I-} Assign(F,FN); Rewrite(F); {$I+}
 If IOResult<>0 Then Begin
  ShowMessage('Erreur','Impossible de creer le fichier "'+FN+'".');
  Exit;
 End;
 Writeln(F,ResultTitle);
 Writeln(F,'');
 For I:=0 To ResultCount-1 Do
  Writeln(F,ResultLines[I]);
 {$I-} Close(F); {$I+}
 If IOResult<>0 Then Begin
  ShowMessage('Erreur','Erreur d''ecriture sur "'+FN+'".');
  Exit;
 End;
 ShowMessage('Sauvegarde',FmtI(ResultCount,1)+
             ' ligne(s) enregistree(s) dans "'+FN+'".');
End;

