Procedure CalcLocal;
Procedure SubCalc;
Var lp:LongInt;
Begin
 h:=0; vcd:=0; vsd:=0; tfe:=0; tfi:=0; ue:=0; ui:=0; gu:=0; gv:=0;
 For lp:=4 DownTo 0 Do
  Begin
   h:=td*h+cfh[lp];
   vcd:=td*vcd+cfcd[lp];
   vsd:=td*vsd+cfsd[lp];
   tfe:=td*tfe+cftfe[lp];
   tfi:=td*tfi*cftfi[lp];           { verbatim BIBLIP : multiplication (preserve) }
   ue:=td*ue+cfue[lp];
   ui:=td*ui+cfui[lp];
   gu:=td*gu+cfx[lp];
   gv:=td*gv+cfy[lp];
  End;
 dh:=0; dcd:=0; dsd:=0; dgu:=0; dgv:=0;
 For lp:=4 DownTo 1 Do
  Begin
   dh:=td*dh+lp*cfh[lp];
   dcd:=td*dcd+lp*cfcd[lp];
   dsd:=td*dsd+lp*cfsd[lp];
   dgu:=td*dgu+lp*cfx[lp];
   dgv:=td*dgv+lp*cfy[lp];
  End;
 h:=((pi*h)/180)-lg;
 ksi:=rcp*sin(h);
 eta:=rsp*vcd-rcp*vsd*cos(h);
 dzeta:=rsp*vsd+rcp*vcd*cos(h);
 dksi:=pi*rcp*dh*cos(h)/180;
 deta:=rsp*dcd-rcp*dsd*cos(h)+pi*rcp*vsd*dh*sin(h)/180;
 le:=REQT*ue-dzeta*tfe;
 li:=REQT*ui-dzeta*tfi;
 gu:=REQT*gu-ksi;
 dgu:=REQT*dgu-dksi;
 gv:=REQT*gv-eta;
