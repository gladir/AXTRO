{ ========================================================================== }
{ ============ EPHEMERIDES PLANETAIRES (verbatim BIBLIE.PAS) =============== }
{ ========================================================================== }
{ Calcul des positions geocentriques apparentes des 8 planetes + Soleil +
  Lune (et optionnellement Pluton) a un instant TE donne, suivi des
  magnitudes, parallaxes, diametres apparents et elongations geocentriques.
  Algorithme integralement repris de BIBLIE.PAS (Bureau des Longitudes). }

Procedure Mercure; Forward;
Procedure Venus;   Forward;
Procedure Mars;    Forward;
Procedure Jupiter; Forward;
Procedure Saturne; Forward;
Procedure Uranus;  Forward;
Procedure Neptune; Forward;
Procedure Pluton;  Forward;

Procedure Ephempl;
Var
 ts,tssc,lgs,bts,ads,dcs:Extended;
 mg0,mg1,mg2,mg3,mg4,mg5,mg6,mg7,mg8,mg9:Extended;
 elg1,elg2,elg3,elg4,elg5,elg6,elg7,elg8,elg9:Extended;
 x,y,z,u,v,wkc,wkd:Extended;
 tshr,tsmn,lgd,lgm,btd,btm,adh,adm,dcd,dcm:LongInt;

 Procedure AffOne(Const Nm:String;
                  Const Distance:String;
                  lg,b,ad,dc:Extended);
 Var sgB,sgD:Char; bAbs,dAbs:Extended;
 Begin
  lgs:=648000*lg/pi;
  lgd:=Trunc(lgs/3600) Mod 360;
  lgm:=Trunc(lgs/60) Mod 60;
  lgs:=lgs-60*Int(lgs/60);
  If b<0 Then sgB:='-' Else sgB:='+';
  bAbs:=Abs(b);
  bts:=648000*bAbs/pi;
  btd:=Trunc(bts/3600) Mod 90;
  btm:=Trunc(bts/60) Mod 60;
  bts:=bts-60*Int(bts/60);
  ads:=3600*ad;
  adh:=Trunc(ads/3600) Mod 24;
  adm:=Trunc(ads/60) Mod 60;
  ads:=ads-60*Int(ads/60);
  If dc<0 Then sgD:='-' Else sgD:='+';
  dAbs:=Abs(3600*dc);
  dcd:=Trunc(dAbs/3600) Mod 90;
  dcm:=Trunc(dAbs/60) Mod 60;
  dcs:=dAbs-60*Int(dAbs/60);
  RWriteLn(Nm+' '+Distance+' L:'+FmtI(lgd,4)+FmtI(lgm,3)+FmtF(lgs,7,2)
           +' B:'+sgB+FmtI(btd,3)+FmtI(btm,3)+FmtF(bts,7,2));
  RWriteLn('             AD:'+FmtI(adh,3)+FmtI(adm,3)+FmtF(ads,8,3)
           +' D:'+sgD+FmtI(dcd,3)+FmtI(dcm,3)+FmtF(dcs,7,2));
 End;

 Function DistTxt(rUA:Extended):String;
 Begin DistTxt:='d='+FmtF(rUA/UA,11,7)+'UA'; End;

 Function ElongVal(adp,dcp:Extended):Extended;
 Var xx,yy,zz,uu,vv,e:Extended;
 Begin
  xx:=adp-ad0;
  While xx<-12 Do xx:=xx+24;
  While xx>12 Do xx:=xx-24;
  xx:=pi*xx/12;
  yy:=pi*dc0/180;
  zz:=pi*dcp/180;
  uu:=cos(xx)*cos(yy)*cos(zz)+sin(yy)*sin(zz);
  vv:=sqrt(1-uu*uu);
  If xx<0 Then vv:=-vv;
  If uu=0 Then e:=90 Else e:=180*arctan(vv/uu)/pi;
  If uu<0 Then e:=e+180;
  If e>180 Then e:=e-360;
  ElongVal:=e;
 End;

Begin
 jd:=jj(qu,ms,an,hr,mn,sc);
 flag:=True;
 t:=(jd-2451545)/365250;
 CalcNut;
 eps:=pi*(deps+84381.448+t*((1.813*t-0.059)*t-468.15))/648000;
 ts:=24110.54841+t*(86401848.12866+t*(9.3104-0.0062*t))+(hr*60+mn)*60+sc;
 ts:=ts+((dpsi*cos(eps))/15);
 ts:=(ts-86400.0*Int(ts/86400.0))/3600;
 If ts<0.0 Then ts:=ts+24.0;
 tshr:=Trunc(ts);
 tsmn:=Trunc(60*ts) Mod 60;
 tssc:=3600*ts-60*Int(60*ts);
 Terre;
 flag:=False;
 Mercure;
 Venus;
 Mars;
 Jupiter;
 Saturne;
 Uranus;
 Neptune;
 If flpl Then Pluton;
 Lune;
 { --- En-tete : date, jour julien, aberration, nutation, obliquite, TSG --- }
 wkc:=abad*6480000000.0/pi;
 wkd:=abdc*6480000000.0/pi;
 wkc:=wkc+(cos(lg2)+cos(lg0)+86*cos(lg4)+19*cos(lg5)+2*(cos(lg6)+cos(lg7)))*cos(eps);
 wkd:=wkd+(sin(lg2)+sin(lg0)+86*sin(lg4)+19*sin(lg5)+2*(sin(lg6)+sin(lg7)));
 wkc:=wkc/10000;
 wkd:=wkd/10000;
 cor:=Trunc(jd+1.5) Mod 7;
 RWriteLn('Date et TE : '+sem[cor]+FmtI(qu,3)+' '+mth[ms]+FmtI(an,6)
          +'  '+FmtI(hr,2)+'h'+FmtI(mn,3)+'m'+FmtF(sc,8,4)+'s');
 RWriteLn('Jour julien : '+FmtF(jd,20,12));
 RWriteLn('C = '+FmtF(wkc,7,3)+'   D = '+FmtF(wkd,7,3)
          +'   c = '+FmtF(dabad*648000/pi,7,3)+'   d = '+FmtF(dabdc*648000/pi,7,3));
 RWriteLn('Dpsi = '+FmtF(dpsi,7,3)+'   Deps = '+FmtF(deps,7,3));
 RWriteLn('Obliquite de l''ecliptique : '+FmtF(eps*180/pi,10,7)
          +'   TSG : '+FmtI(tshr,3)+'h'+FmtI(tsmn,3)+'m'+FmtF(tssc,8,4)+'s');
 RWriteLn('');
 { --- Soleil --- }
 lgs:=648000*(lg0+pi)/pi;
 lgd:=Trunc(lgs/3600) Mod 360;
 lgm:=Trunc(lgs/60) Mod 60;
 lgs:=lgs-60*Int(lgs/60);
 If b0>0 Then hmc:='-' Else hmc:='+';
 bts:=648000*Abs(b0)/pi;
 btd:=Trunc(bts/3600) Mod 90;
 btm:=Trunc(bts/60) Mod 60;
 bts:=bts-60*Int(bts/60);
 ads:=3600*ad0;
 adh:=Trunc(ads/3600) Mod 24;
 adm:=Trunc(ads/60) Mod 60;
 ads:=ads-60*Int(ads/60);
 If dc0<0 Then hmq:='-' Else hmq:='+';
 dcs:=Abs(3600*dc0);
 dcd:=Trunc(dcs/3600) Mod 90;
 dcm:=Trunc(dcs/60) Mod 60;
 dcs:=dcs-60*Int(dcs/60);
 RWriteLn('Soleil   d='+FmtF(r0/UA,11,7)+'UA L:'+FmtI(lgd,4)+FmtI(lgm,3)+FmtF(lgs,7,2)
          +' B:'+hmc+FmtI(btd,3)+FmtI(btm,3)+FmtF(bts,7,2));
 RWriteLn('             AD:'+FmtI(adh,3)+FmtI(adm,3)+FmtF(ads,8,3)
          +' D:'+hmq+FmtI(dcd,3)+FmtI(dcm,3)+FmtF(dcs,7,2));
 { --- Planetes --- }
 AffOne('Mercure ','r='+FmtF(r1/UA,9,7)+' d='+FmtF(d1/UA,9,7),lg1,b1,ad1,dc1);
 AffOne('Venus   ','r='+FmtF(r2/UA,9,7)+' d='+FmtF(d2/UA,9,7),lg2,b2,ad2,dc2);
 AffOne('Mars    ','r='+FmtF(r3/UA,9,7)+' d='+FmtF(d3/UA,9,7),lg3,b3,ad3,dc3);
 AffOne('Jupiter ','r='+FmtF(r4/UA,9,7)+' d='+FmtF(d4/UA,9,7),lg4,b4,ad4,dc4);
 AffOne('Saturne ','r='+FmtF(r5/UA,9,7)+' d='+FmtF(d5/UA,9,7),lg5,b5,ad5,dc5);
 AffOne('Uranus  ','r='+FmtF(r6/UA,9,7)+' d='+FmtF(d6/UA,9,7),lg6,b6,ad6,dc6);
 AffOne('Neptune ','r='+FmtF(r7/UA,9,7)+' d='+FmtF(d7/UA,9,7),lg7,b7,ad7,dc7);
 If flpl Then
  AffOne('Pluton  ','r='+FmtF(r8/UA,9,7)+' d='+FmtF(d8/UA,9,7),lg8,b8,ad8,dc8);
 { --- Lune (distance en km) --- }
 lgs:=648000*lg9/pi;
 lgd:=Trunc(lgs/3600) Mod 360;
 lgm:=Trunc(lgs/60) Mod 60;
 lgs:=lgs-60*Int(lgs/60);
 If b9<0 Then hmc:='-' Else hmc:='+';
 bts:=648000*Abs(b9)/pi;
 btd:=Trunc(bts/3600) Mod 90;
 btm:=Trunc(bts/60) Mod 60;
 bts:=bts-60*Int(bts/60);
 ads:=3600*ad9;
 adh:=Trunc(ads/3600) Mod 24;
 adm:=Trunc(ads/60) Mod 60;
 ads:=ads-60*Int(ads/60);
 If dc9<0 Then hmq:='-' Else hmq:='+';
 dcs:=Abs(3600*dc9);
 dcd:=Trunc(dcs/3600) Mod 90;
 dcm:=Trunc(dcs/60) Mod 60;
 dcs:=dcs-60*Int(dcs/60);
 RWriteLn('Lune     d='+FmtF(r9,12,3)+'km L:'+FmtI(lgd,4)+FmtI(lgm,3)+FmtF(lgs,7,2)
          +' B:'+hmc+FmtI(btd,3)+FmtI(btm,3)+FmtF(bts,7,2));
 RWriteLn('             AD:'+FmtI(adh,3)+FmtI(adm,3)+FmtF(ads,8,3)
          +' D:'+hmq+FmtI(dcd,3)+FmtI(dcm,3)+FmtF(dcs,7,2));
 RWriteLn('');
 { --- Magnitudes, parallaxes, diametres apparents, elongations (verbatim BIBLIE) --- }
 mg0:=-26.86+5*ln(r0/UA)/ln(10);
 phs:=((x1+x0)*x1+(y1+y0)*y1+(z1+z0)*z1);
 wrk:=x1*x1+y1*y1+z1*z1+x0*x0+y0*y0+z0*z0+2*(x0*x1+y0*y1+z0*z1);
 phs:=phs/(sqrt(wrk)*d1);
 If phs=0 Then phs:=0.9 Else phs:=arctan(sqrt(1-phs*phs)/phs)*1.8/pi;
 If phs<0 Then phs:=phs+1.8;
 mg1:=-0.36+5*ln((r1*d1)/(UA*UA))/ln(10)+((2*phs-2.73)*phs+3.8)*phs;
 phs:=((x2+x0)*x2+(y2+y0)*y2+(z2+z0)*z2);
 wrk:=x2*x2+y2*y2+z2*z2+x0*x0+y0*y0+z0*z0+2*(x0*x2+y0*y2+z0*z2);
 phs:=phs/(sqrt(wrk)*d2);
 If phs=0 Then phs:=0.9 Else phs:=arctan(sqrt(1-phs*phs)/phs)*1.8/pi;
 If phs<0 Then phs:=phs+1.8;
 mg2:=-4.29+5*ln((r2*d2)/(UA*UA))/ln(10)+((2.39-0.65*phs)*phs+0.09)*phs;
 phs:=((x3+x0)*x3+(y3+y0)*y3+(z3+z0)*z3);
 wrk:=x3*x3+y3*y3+z3*z3+x0*x0+y0*y0+z0*z0+2*(x0*x3+y0*y3+z0*z3);
 phs:=phs/(sqrt(wrk)*d3);
 If phs=0 Then phs:=0.9 Else phs:=arctan(sqrt(1-phs*phs)/phs)*1.8/pi;
 If phs<0 Then phs:=phs+1.8;
 mg3:=-1.52+5*ln((r3*d3)/(UA*UA))/ln(10)+1.5*phs;
 phs:=((x4+x0)*x4+(y4+y0)*y4+(z4+z0)*z4);
 wrk:=x4*x4+y4*y4+z4*z4+x0*x0+y0*y0+z0*z0+2*(x0*x4+y0*y4+z0*z4);
 phs:=phs/(sqrt(wrk)*d4);
 phs:=arctan(sqrt(1-phs*phs)/phs)*1.8/pi;
 If phs<0 Then phs:=phs+1.8;
 mg4:=-9.25+5*ln((r4*d4)/(UA*UA))/ln(10)+phs/2;
 phs:=((x5+x0)*x5+(y5+y0)*y5+(z5+z0)*z5);
 wrk:=x5*x5+y5*y5+z5*z5+x0*x0+y0*y0+z0*z0+2*(x0*x5+y0*y5+z0*z5);
 phs:=phs/(sqrt(wrk)*d5);
 phs:=arctan(sqrt(1-phs*phs)/phs)*1.8/pi;
 If phs<0 Then phs:=phs+1.8;
 mg5:=-7.19+5*ln((r5*d5)/(UA*UA))/ln(10)+4.4*phs;
 phs:=((x6+x0)*x6+(y6+y0)*y6+(z6+z0)*z6);
 wrk:=x6*x6+y6*y6+z6*z6+x0*x0+y0*y0+z0*z0+2*(x0*x6+y0*y6+z0*z6);
 phs:=phs/(sqrt(wrk)*d6);
 mg6:=-7.19+5*ln((r6*d6)/(UA*UA))/ln(10)+0.28*phs;
 mg7:=-6.87+5*ln((r7*d7)/(UA*UA))/ln(10);
 If flpl Then
  Begin
   phs:=((x8+x0)*x8+(y8+y0)*y8+(z8+z0)*z8);
   wrk:=x8*x8+y8*y8+z8*z8+x0*x0+y0*y0+z0*z0+2*(x0*x8+y0*y8+z0*z8);
   phs:=phs/(sqrt(wrk)*d8);
   mg8:=-1.01+5*ln((r8*d8)/(UA*UA))/ln(10)+0.13*phs;
  End;
 x:=x0+x9;
 y:=y0+y9;
 z:=z0+z9;
 wrk:=sqrt(x*x+y*y+z*z);
 phs:=(x*x9+y*y9+z*z9)/(r9*wrk);
 If phs=0 Then phs:=0.9 Else phs:=arctan(sqrt(1-phs*phs)/phs)*1.8/pi;
 If phs<0 Then phs:=phs+1.8;
 mg9:=0.21+5*ln(r9/384400)/ln(10)+((2.418*phs-4.475)*phs+3.057)*phs;
 { --- Elongations geocentriques (Mercure..Neptune, Pluton, Lune) --- }
 elg1:=ElongVal(ad1,dc1);
 elg2:=ElongVal(ad2,dc2);
 elg3:=ElongVal(ad3,dc3);
 elg4:=ElongVal(ad4,dc4);
 elg5:=ElongVal(ad5,dc5);
 elg6:=ElongVal(ad6,dc6);
 elg7:=ElongVal(ad7,dc7);
 If flpl Then elg8:=ElongVal(ad8,dc8);
 elg9:=ElongVal(ad9,dc9);
 RWriteLn('Attention pour Saturne : la magnitude ne tient pas compte des anneaux !');
 RWriteLn('Soleil    m='+FmtF(mg0,6,2)+'  Paral.='+FmtF(pr0,7,2)+'"  Diam.='+FmtF(dm0,7,2)+'"');
 RWriteLn('Mercure   m='+FmtF(mg1,6,2)+'  Paral.='+FmtF(pr1,7,2)+'"  Diam.='+FmtF(dm1,7,2)+'"  Elong.='+FmtF(elg1,7,2));
 RWriteLn('Venus     m='+FmtF(mg2,6,2)+'  Paral.='+FmtF(pr2,7,2)+'"  Diam.='+FmtF(dm2,7,2)+'"  Elong.='+FmtF(elg2,7,2));
 RWriteLn('Mars      m='+FmtF(mg3,6,2)+'  Paral.='+FmtF(pr3,7,2)+'"  Diam.='+FmtF(dm3,7,2)+'"  Elong.='+FmtF(elg3,7,2));
 RWriteLn('Jupiter   m='+FmtF(mg4,6,2)+'  Paral.='+FmtF(pr4,7,2)+'"  Diam.='+FmtF(dm4,7,2)+'"  Elong.='+FmtF(elg4,7,2));
 RWriteLn('Saturne   m='+FmtF(mg5,6,2)+'  Paral.='+FmtF(pr5,7,2)+'"  Diam.='+FmtF(dm5,7,2)+'"  Elong.='+FmtF(elg5,7,2));
 RWriteLn('Uranus    m='+FmtF(mg6,6,2)+'  Paral.='+FmtF(pr6,7,2)+'"  Diam.='+FmtF(dm6,7,2)+'"  Elong.='+FmtF(elg6,7,2));
 RWriteLn('Neptune   m='+FmtF(mg7,6,2)+'  Paral.='+FmtF(pr7,7,2)+'"  Diam.='+FmtF(dm7,7,2)+'"  Elong.='+FmtF(elg7,7,2));
 If flpl Then
  RWriteLn('Pluton    m='+FmtF(mg8,6,2)+'  Paral.='+FmtF(pr8,7,2)+'"  Diam.='+FmtF(dm8,7,2)+'"  Elong.='+FmtF(elg8,7,2));
 RWriteLn('Lune      m='+FmtF(mg9,6,2)+'  Paral.='+FmtF(pr9,7,2)+'"  Diam.='+FmtF(dm9,7,2)+'"  Elong.='+FmtF(elg9,7,2));
