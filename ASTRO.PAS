Procedure HandleKeyPress(K:Char);
Var
 Idx,I,J,N,FirstMatch:Integer;
 UK:Char;
 Found:Boolean;
Begin
 If K=#0 Then Begin
  K:=ReadKey;
  Case K Of
   #59: Begin DoAbout; NeedRedraw:=True; End;        { F1 - Aide }
   #68: Begin                                         { F10 - ouvrir 1er menu }
    MenuActive:=True; ActiveMenu:=0; ActiveMenuItem:=-1; NeedRedraw:=True;
   End;
   #107,                                               { Alt+F4 - Quitter }
   #45: ProgramRunning:=False;                          { Alt+X - Quitter }
   #75: Begin                                         { Fleche gauche }
    If MenuActive Then Begin
     ActiveMenu:=ActiveMenu-1;
     If ActiveMenu<0 Then ActiveMenu:=NUM_MENUS-1;
     ActiveMenuItem:=-1; NeedRedraw:=True;
    End;
   End;
   #77: Begin                                         { Fleche droite }
    If MenuActive Then Begin
     ActiveMenu:=(ActiveMenu+1) Mod NUM_MENUS;
     ActiveMenuItem:=-1; NeedRedraw:=True;
    End;
   End;
   #72: Begin                                         { Fleche haut }
    If MenuActive Then Begin
     N:=Menus[ActiveMenu].ItemCount;
     If N>0 Then Begin
      I:=ActiveMenuItem;
      Repeat
       I:=I-1; If I<0 Then I:=N-1;
      Until (Not Menus[ActiveMenu].Items[I].Separator) Or (I=ActiveMenuItem);
      ActiveMenuItem:=I; NeedRedraw:=True;
     End;
    End;
   End;
   #80: Begin                                         { Fleche bas }
    If MenuActive Then Begin
     N:=Menus[ActiveMenu].ItemCount;
     If N>0 Then Begin
      I:=ActiveMenuItem;
      Repeat
       I:=(I+1) Mod N;
      Until (Not Menus[ActiveMenu].Items[I].Separator) Or (I=ActiveMenuItem);
      ActiveMenuItem:=I; NeedRedraw:=True;
     End;
    End;
   End;
   #71: Begin                                         { Home - premier item }
    If MenuActive Then Begin
     N:=Menus[ActiveMenu].ItemCount;
     I:=0;
     While (I<N) And Menus[ActiveMenu].Items[I].Separator Do Inc(I);
     If I<N Then Begin ActiveMenuItem:=I; NeedRedraw:=True; End;
    End;
   End;
   #79: Begin                                         { End - dernier item }
    If MenuActive Then Begin
     N:=Menus[ActiveMenu].ItemCount;
     I:=N-1;
     While (I>=0) And Menus[ActiveMenu].Items[I].Separator Do Dec(I);
     If I>=0 Then Begin ActiveMenuItem:=I; NeedRedraw:=True; End;
    End;
   End;
  End;
  Exit;
 End;

 If K=#27 Then Begin                                  { Esc - fermer menu }
  If MenuActive Then Begin
   MenuActive:=False; ActiveMenu:=-1; ActiveMenuItem:=-1; NeedRedraw:=True;
  End;
  Exit;
 End;

 If K=#13 Then Begin                                  { Enter - activer item }
  If MenuActive And (ActiveMenu>=0) And (ActiveMenuItem>=0) Then Begin
   MenuActive:=False;
   Idx:=ActiveMenuItem;
   I:=ActiveMenu;
   ActiveMenu:=-1; ActiveMenuItem:=-1;
   DispatchAction(Menus[I].Items[Idx].Action);
  End;
  Exit;
 End;

 { Touche alphanumerique : hotkey de menu (premiere lettre) }
 UK:=UpCase(K);
 If Not (UK In ['A'..'Z','0'..'9']) Then Exit;

 If Not MenuActive Then Begin
  { Cherche un menu dont la 1ere lettre du Caption = UK }
  For I:=0 To NUM_MENUS-1 Do
   If (Length(Menus[I].Caption)>0) And (UpCase(Menus[I].Caption[1])=UK) Then Begin
    MenuActive:=True; ActiveMenu:=I; ActiveMenuItem:=-1; NeedRedraw:=True;
    Exit;
   End;
 End
 Else Begin
  { Dans un menu ouvert : cycle sur les items dont la 1ere lettre = UK }
  N:=Menus[ActiveMenu].ItemCount;
  FirstMatch:=-1; Found:=False;
  J:=ActiveMenuItem;
  For I:=1 To N Do Begin
   J:=(J+1) Mod N;
   If (Not Menus[ActiveMenu].Items[J].Separator) And
      (Length(Menus[ActiveMenu].Items[J].Caption)>0) And
      (UpCase(Menus[ActiveMenu].Items[J].Caption[1])=UK) Then Begin
    If FirstMatch<0 Then FirstMatch:=J;
    Found:=True;
    Break;
   End;
  End;
  If Found Then Begin
   ActiveMenuItem:=FirstMatch; NeedRedraw:=True;
  End;
 End;
End;

Procedure HandleMouseClick(X,Y:LongInt);
Var Idx:Integer;
Begin
 If MenuActive Then Begin
  Idx:=MenuItemHitTest(ActiveMenu,X,Y);
  If Idx>=0 Then Begin
   MenuActive:=False;
   DispatchAction(Menus[ActiveMenu].Items[Idx].Action);
   ActiveMenu:=-1;
   Exit;
  End;
  Idx:=MenuBarHitTest(X,Y);
  If Idx>=0 Then Begin
   ActiveMenu:=Idx; ActiveMenuItem:=-1; NeedRedraw:=True;
  End
  Else Begin
   MenuActive:=False; ActiveMenu:=-1; NeedRedraw:=True;
  End;
  Exit;
 End;
 Idx:=MenuBarHitTest(X,Y);
 If Idx>=0 Then Begin
  MenuActive:=True; ActiveMenu:=Idx; ActiveMenuItem:=-1; NeedRedraw:=True;
  Exit;
 End;
 Idx:=ToolbarHitTest(X,Y);
 If Idx>=0 Then Begin
  DispatchAction(ToolButtons[Idx].Action);
  NeedRedraw:=True;
 End;
End;

Procedure HandleMouseMove(X,Y:LongInt);
{ Suivi du curseur souris hors clic :
  - menu ouvert + curseur sur un autre menu bar => bascule de menu
  - menu ouvert + curseur sur un item de la popup => highlight item }
Var Idx:Integer;
Begin
 If Not MenuActive Then Exit;
 Idx:=MenuBarHitTest(X,Y);
 If (Idx>=0) And (Idx<>ActiveMenu) Then Begin
  ActiveMenu:=Idx; ActiveMenuItem:=-1; NeedRedraw:=True;
  Exit;
 End;
 Idx:=MenuItemHitTest(ActiveMenu,X,Y);
 If (Idx>=0) And (Idx<>ActiveMenuItem) And
    (Not Menus[ActiveMenu].Items[Idx].Separator) Then Begin
  ActiveMenuItem:=Idx; NeedRedraw:=True;
 End;
End;

Procedure MainLoop;
Var K:Char;
    OldX,OldY:LongInt;
Begin
 ProgramRunning:=True;
 NeedRedraw:=True;
 OldMouseBtn:=0;
 OldX:=-1; OldY:=-1;
 While ProgramRunning Do Begin
  If NeedRedraw Then Begin
   RedrawAll;
   If MenuActive Then Begin
    HideMouse;
    DrawMenuPopup(ActiveMenu);
    ShowMouse;
   End;
   NeedRedraw:=False;
  End;
  If KeyPressed Then Begin
   K:=ReadKey;
   HandleKeyPress(K);
  End;
  If HasMouse Then Begin
   ReadMouse(MouseX,MouseY,MouseBtn);
   If (MouseX<>OldX) Or (MouseY<>OldY) Then Begin
    HandleMouseMove(MouseX,MouseY);
    OldX:=MouseX; OldY:=MouseY;
   End;
   If (MouseBtn=1) And (OldMouseBtn=0) Then
    HandleMouseClick(MouseX,MouseY);
   OldMouseBtn:=MouseBtn;
  End;
  Delay(15);
 End;
End;

{ ========================================================================== }
{ ============================ PROGRAMME PRINCIPAL ========================= }
{ ========================================================================== }

BEGIN
 InitializeGraphics;
 ScreenWidth:=SCREEN_WIDTH;
 ScreenHeight:=SCREEN_HEIGHT;
 HasMouse:=MouseDriverFound;
 If HasMouse Then ShowMouse;
 InitSemMth;
 InitMenus;
 LayoutMenuBar;
 InitToolbar;
 RClear;
 ResultTitle:='Resultats';
 ActiveMenu:=-1;
 ActiveMenuItem:=-1;
 MenuActive:=False;
 fldt:=True;     { mode interactif - fichier desactive par defaut }
 flsv:=False;
 flpr:=False;
 flmn:=False;
 flag:=False;
 flpl:=False;
 fler:=False;
 MainLoop;
 If HasMouse Then HideMouse;
 CloseGraph;
END.
