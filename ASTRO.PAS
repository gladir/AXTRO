End;

Begin {CalcLocal body}
 temut:=gPhTEMUT;
 lg:=gPhLg; lt:=gPhLt; alt:=gPhAlt;
 ier:=False;
 wrk:=REQT/sqrt(cos(lt)*cos(lt)+0.99330562*sin(lt)*sin(lt));
 rcp:=(wrk+(alt/1000))*cos(lt);
 rsp:=(0.99330562*wrk+(alt/1000))*sin(lt);
 td:=-3.1875; dt:=-12;
 While (abs(dt)>LIM) Do
  Begin
   SubCalc;
   b:=(gu*dgu+gv*dgv)/(dgu*dgu+dgv*dgv);
   g:=(gu*gu+gv*gv-le*le)/(dgu*dgu+dgv*dgv);
   th:=b*b-g;
   If (th<0) Then
    Begin
     RWriteLn('Eclipse invisible de ce lieu.');
     ier:=True;
    End;
   If ier Then dt:=0
   Else
    Begin
     th:=sqrt(th);
     If (b<0) Then th:=-th;
     dt:=b-th;
     td:=td-dt;
    End;
  End;
 If Not ier Then
  Begin
   If (gv<>0) Then apl:=arctan(gu/gv)*180/pi Else apl:=90*gu/abs(gu);
   If (gv<0) Then apl:=apl+180;
   If (apl<0) Then apl:=apl+360;
   If (eta<>0) Then apr:=arctan(ksi/eta)*180/pi Else apr:=90*ksi/abs(ksi);
   If (eta<0) Then apr:=apr+180;
   If (apr<0) Then apr:=apr+360;
   azn:=apl-apr;
   If (azn<0) Then azn:=azn+360;
   jd:=jd0+(td/24)-(temut/86400);
   cal(jd,qu,ms,an,hr,mn,sc);
   cor:=Trunc(jd+1.5-7*int((jd+1.5)/7));
   If (cor<0) Then cor:=cor+7;
   WrContUT('Premier contact exterieur : ',apl,azn);
   If (tpe>1) Then
    Begin
     td:=-0.5; dt:=-12;
     While (abs(dt)>LIM) Do
      Begin
       SubCalc;
       b:=(gu*dgu+gv*dgv)/(dgu*dgu+dgv*dgv);
       g:=(gu*gu+gv*gv-li*li)/(dgu*dgu+dgv*dgv);
       th:=b*b-g;
       If (th<0) Then
        Begin
         RWriteLn('Eclipse partielle en ce lieu.');
         ier:=True;
        End;
       If ier Then dt:=0
       Else
        Begin
         th:=sqrt(b*b-g);
         If (b<0) Then th:=-th;
         dt:=b+abs(th);
         td:=td-dt;
        End;
      End;
     If (Not ier) Then
      Begin
       If (gv<>0) Then apl:=arctan(gu/gv)*180/pi Else apl:=90*gu/abs(gu);
       If (gv<0) Then apl:=apl+180;
       If (apl<0) Then apl:=apl+360;
       If (eta<>0) Then apr:=arctan(ksi/eta)*180/pi Else apr:=90*ksi/abs(ksi);
       If (eta<0) Then apr:=apr+180;
       If (apr<0) Then apr:=apr+360;
       azn:=apl-apr;
       If (azn<0) Then azn:=azn+360;
       jd:=jd0+(td/24)-(temut/86400);
       cal(jd,qu,ms,an,hr,mn,sc);
       cor:=Trunc(jd+1.5-7*int((jd+1.5)/7));
       If (cor<0) Then cor:=cor+7;
       WrContUT('Premier contact interieur : ',apl,azn);
      End;
    End;
   td:=0; dt:=12;
   While (abs(dt)>LIM) Do
    Begin
     SubCalc;
     dt:=(gu*dgu+gv*dgv)/(dgu*dgu+dgv*dgv);
     td:=td-dt;
    End;
   lm:=sqrt(gu*gu+gv*gv);
   g:=le-lm;
   If (tpe=1) Then g:=g/(2*le-3485.65351) Else g:=g/(le-li);
   jd:=jd0+(td/24)-(temut/86400);
   cal(jd,qu,ms,an,hr,mn,sc);
   cor:=Trunc(jd+1.5-7*int((jd+1.5)/7));
   If (cor<0) Then cor:=cor+7;
   RWriteLn('Maximum  : '+FmtS(sem[cor],8)+FmtI(qu,3)+FmtS(mth[ms],10)+FmtI(an,6)
    +' a '+FmtI(hr,2)+' h '+FmtI(mn,2)+' mn '+FmtF(sc,4,1)+' s UT.');
   RWriteLn('Grandeur : '+FmtF(g,6,4));
   If (Not ier) Then
    Begin
     td:=0.5; dt:=12;
     While (abs(dt)>LIM) Do
      Begin
       SubCalc;
       b:=(gu*dgu+gv*dgv)/(dgu*dgu+dgv*dgv);
       g:=(gu*gu+gv*gv-li*li)/(dgu*dgu+dgv*dgv);
       th:=sqrt(abs(b*b-g));
       If (b<0) Then th:=-th;
       dt:=b-abs(th);
       td:=td-dt;
      End;
     If (gv<>0) Then apl:=arctan(gu/gv)*180/pi Else apl:=90*gu/abs(gu);
     If (gv<0) Then apl:=apl+180;
     If (apl<0) Then apl:=apl+360;
     If (eta<>0) Then apr:=arctan(ksi/eta)*180/pi Else apr:=90*ksi/abs(ksi);
     If (eta<0) Then apr:=apr+180;
     If (apr<0) Then apr:=apr+360;
     azn:=apl-apr;
     If (azn<0) Then azn:=azn+360;
     jd:=jd0+(td/24)-(temut/86400);
     cal(jd,qu,ms,an,hr,mn,sc);
     cor:=Trunc(jd+1.5-7*int((jd+1.5)/7));
     If (cor<0) Then cor:=cor+7;
     WrContUT('Second contact interieur  : ',apl,azn);
    End;
   td:=3.1875; dt:=12;
   While (abs(dt)>LIM) Do
    Begin
     SubCalc;
     b:=(gu*dgu+gv*dgv)/(dgu*dgu+dgv*dgv);
     g:=(gu*gu+gv*gv-le*le)/(dgu*dgu+dgv*dgv);
     th:=sqrt(b*b-g);
     If (b<0) Then th:=-th;
     dt:=b-th;
     td:=td-dt;
    End;
   If (gv<>0) Then apl:=arctan(gu/gv)*180/pi Else apl:=90*gu/abs(gu);
   If (gv<0) Then apl:=apl+180;
   If (apl<0) Then apl:=apl+360;
   If (eta<>0) Then apr:=arctan(ksi/eta)*180/pi Else apr:=90*ksi/abs(ksi);
   If (eta<0) Then apr:=apr+180;
   If (apr<0) Then apr:=apr+360;
   azn:=apl-apr;
   If (azn<0) Then azn:=azn+360;
   jd:=jd0+(td/24)-(temut/86400);
   cal(jd,qu,ms,an,hr,mn,sc);
   cor:=Trunc(jd+1.5-7*int((jd+1.5)/7));
   If (cor<0) Then cor:=cor+7;
   WrContUT('Second contact exterieur  : ',apl,azn);
  End;
End; {CalcLocal}

Begin {EclipseSoleil body}
 jd0:=jd;
 tfi:=0; tfe:=0;
 For lp:=-17 To 17 Do
  Begin
   jd:=jd0+(lp/128);
   cal(jd,qu,ms,an,hr,mn,sc);
   t:=(jd-2451545)/365250;
   CalcNut;
   eps:=pi*(deps+84381.448+t*((1.813*t-0.059)*t-468.15))/648000;
   ts:=24110.54841+t*(86401848.12866+t*(9.3104-0.0062*t))+(hr*60+mn)*60+sc;
   ts:=(ts/3600)+((dpsi*cos(eps))/54000);
   ts:=ts-24*trunc(ts/24);
   If (ts<0) Then ts:=ts+24;
   Terre;
   x:=x0+x9; y:=y0+y9; z:=z0+z9;
   wrk:=sqrt(x*x+y*y+z*z);
   sd[lp]:=-z/wrk;
   cd[lp]:=sqrt(x*x+y*y)/wrk;
   If (cd[lp]<>0) Then dc[lp]:=180*arctan(sd[lp]/cd[lp])/pi Else dc[lp]:=90*sd[lp]/abs(sd[lp]);
   If (x<>0) Then dlt:=12*arctan(y/x)/pi Else dlt:=6*y/abs(y);
   If (x>0) Then dlt:=dlt+12;
   If (dlt<0) Then dlt:=dlt+24;
   dlt:=15*(ts-dlt);
   dlt:=dlt-360*trunc(dlt/360);
   If (dlt<0) Then dlt:=dlt+360;
   ah[lp]:=dlt;
   If (lp>-17) Then If (ah[lp]<ah[lp-1]) Then ah[lp]:=ah[lp]+360;
   vti[lp]:=-694262.6/sqrt((wrk-694262.6)*(wrk+694262.6));
   vte[lp]:=697737.4/sqrt((wrk-697737.4)*(wrk+697737.4));
   wrk:=REQT*wrk;
   u[lp]:=((x*x+y*y)*z9-z*(x9*x+y9*y))/(wrk*sqrt(x*x+y*y));
   v[lp]:=(x9*y-x*y9)/(REQT*sqrt(x*x+y*y));
   w[lp]:=abs(x*x9+y*y9+z*z9)/wrk;
   dlt:=sqrt(u[lp]*u[lp]+v[lp]*v[lp]);
   dst[lp]:=dlt;
   ro[lp]:=vti[lp]*w[lp]+(1737.4/REQT);
   rp[lp]:=vte[lp]*w[lp]+(1737.4/REQT);
  End;
 CalcCfts(v,cfx);
 CalcCfts(u,cfy);
 CalcCfts(w,cfz);
 CalcCfts(dst,cfdst);
 CalcCfts(sd,cfsd);
 CalcCfts(cd,cfcd);
 CalcCfts(dc,cfdc);
 CalcCfts(ah,cfh);
 If (cfh[0]<0) Then cfh[0]:=cfh[0]+360;
 If (cfh[0]>360) Then cfh[0]:=cfh[0]-360;
 CalcCfts(rp,cfue);
 CalcCfts(ro,cfui);
 CalcCfts(vte,cftfe);
 CalcCfts(vti,cftfi);
 tm:=0; dt:=5;
 While (abs(36000000*dt)>1) Do
  Begin
   x:=0; y:=0;
   For lp:=4 DownTo 1 Do x:=x*tm+lp*cfdst[lp];
   For lp:=4 DownTo 2 Do y:=y*tm+lp*(lp-1)*cfdst[lp];
   dt:=x/y;
   tm:=tm-dt;
  End;
 dt:=0; ue:=0; ui:=0;
 For lp:=4 DownTo 0 Do
  Begin
   dt:=dt*tm+cfdst[lp];
   ue:=ue*tm+cfue[lp];
   ui:=ui*tm+cfui[lp];
  End;
 dt:=dt-1;
 If (dt>ue) Then tpe:=0 Else tpe:=1;
 If (tpe=1) Then
  Begin
   If (ui<0) Then
     Begin
      If (dt<0) Then tpe:=2;
      If (dt<ui) Then tpe:=3;
     End
    Else
     Begin
      If (dt<ui) Then tpe:=4;
      If (dt<0) Then tpe:=5;
     End;
  End;
 Case tpe Of
   1 : RWriteLn('Eclipse partielle de Soleil.');
   2 : RWriteLn('Eclipse annulaire de Soleil, non centrale.');
   3 : RWriteLn('Eclipse annulaire de Soleil, centrale.');
   4 : RWriteLn('Eclipse totale de Soleil, non centrale.');
   5 : RWriteLn('Eclipse totale de Soleil, centrale.');
  End;
 If (tpe>0) Then
  Begin
   RWriteLn('Elements de Bessel pour l''eclipse.');
   RWriteLn('Le meridien origine est celui du TE.');
   RWriteLn('L''origine des temps est l''instant de la Nouvelle Lune.');
   RWriteLn('L''intervalle de validite est de 3 h 11 mn 15 s avant et apres la NL.');
   RWriteLn('L''unite de temps est l''heure.');
   RWriteLn('L''utilisation de ces elements est expliquee dans l''Annuaire du BdL.');
   RWriteLn('x      = '+FmtF(cfx[0],14,9)+FmtF(cfx[1],14,9)+FmtF(cfx[2],14,9)+FmtF(cfx[3],14,9)+FmtF(cfx[4],14,9));
   RWriteLn('y      = '+FmtF(cfy[0],14,9)+FmtF(cfy[1],14,9)+FmtF(cfy[2],14,9)+FmtF(cfy[3],14,9)+FmtF(cfy[4],14,9));
   RWriteLn('z      = '+FmtF(cfz[0],14,9)+FmtF(cfz[1],14,9)+FmtF(cfz[2],14,9)+FmtF(cfz[3],14,9)+FmtF(cfz[4],14,9));
   RWriteLn('Dist.  = '+FmtF(cfdst[0],14,9)+FmtF(cfdst[1],14,9)+FmtF(cfdst[2],14,9)+FmtF(cfdst[3],14,9)+FmtF(cfdst[4],14,9));
   RWriteLn('sin(d) = '+FmtF(cfsd[0],14,9)+FmtF(cfsd[1],14,9)+FmtF(cfsd[2],14,9)+FmtF(cfsd[3],14,9)+FmtF(cfsd[4],14,9));
   RWriteLn('cos(d) = '+FmtF(cfcd[0],14,9)+FmtF(cfcd[1],14,9)+FmtF(cfcd[2],14,9)+FmtF(cfcd[3],14,9)+FmtF(cfcd[4],14,9));
   RWriteLn('d      = '+FmtF(cfdc[0],14,9)+FmtF(cfdc[1],14,9)+FmtF(cfdc[2],14,9)+FmtF(cfdc[3],14,9)+FmtF(cfdc[4],14,9));
   RWriteLn('H      = '+FmtF(cfh[0],14,9)+FmtF(cfh[1],14,9)+FmtF(cfh[2],14,9)+FmtF(cfh[3],14,9)+FmtF(cfh[4],14,9));
   RWriteLn('ue     = '+FmtF(cfue[0],14,9)+FmtF(cfue[1],14,9)+FmtF(cfue[2],14,9)+FmtF(cfue[3],14,9)+FmtF(cfue[4],14,9));
   RWriteLn('ui     = '+FmtF(cfui[0],14,9)+FmtF(cfui[1],14,9)+FmtF(cfui[2],14,9)+FmtF(cfui[3],14,9)+FmtF(cfui[4],14,9));
   RWriteLn('tg(fe) = '+FmtF(cftfe[0],14,9)+FmtF(cftfe[1],14,9)+FmtF(cftfe[2],14,9)+FmtF(cftfe[3],14,9)+FmtF(cftfe[4],14,9));
   RWriteLn('tg(fi) = '+FmtF(cftfi[0],14,9)+FmtF(cftfi[1],14,9)+FmtF(cftfi[2],14,9)+FmtF(cftfi[3],14,9)+FmtF(cftfi[4],14,9));
   If ((tpe=3) Or (tpe=5)) Then
    Begin
     x:=0; y:=0; ts:=0; gu:=0; gv:=0;
     For lp:=4 DownTo 0 Do
      Begin
       x:=x*tm+cfx[lp];
       y:=y*tm+cfy[lp];
       ts:=ts*tm+cfh[lp];
       gu:=gu*tm+cfcd[lp];
       gv:=gv*tm+cfsd[lp];
      End;
     p:=0; b:=0; c:=0;
     For lp:=4 DownTo 1 Do
      Begin
       c:=c*tm+lp*cfx[lp];
       b:=b*tm+lp*cfy[lp];
       p:=p*tm+lp*cfh[lp];
      End;
     omg:=298.257/sqrt(88957.238049-595.514*gu*gu);
     p:=p*pi/180;
     b:=b-p*x*gv;
     c:=c+p*y*gv;
     y1:=omg*y;
     b1:=omg*gv;
     b2:=297.257*omg*gu/298.257;
     gb:=sqrt(1-x*x-y1*y1);
     y:=x;
     x:=gb*b2-y1*b1;
     z:=gb*b1+y1*b2;
     If (x<>0) Then b:=arctan(y/x) Else b:=pi*y/abs(2*y);
     If (x<0) Then b:=b+pi;
     If (b<0) Then b:=b+2*pi;
     b:=ts-180*b/pi;
     While (b>0) Do b:=b-360;
     While (b<0) Do b:=b+360;
     c:=298.257*z/sqrt(x*x+y*y);
     c:=180*arctan(c/297.257)/pi;
     omg:=jd0+(tm/24);
     cal(omg,qu,ms,an,hr,mn,sc);
     WrShortTE('Maximum de l''eclipse le : ');
     RWriteLn('Longitude Ouest : '+FmtF(b,10,6));
     RWriteLn('Latitude Nord   : '+FmtF(c,10,6));
     dt:=5;
     While (abs(36000000*dt)>1) Do
      Begin
       x:=0; y:=0;
       For lp:=4 DownTo 0 Do x:=x*tm+cfx[lp];
       For lp:=4 DownTo 1 Do y:=y*tm+lp*cfx[lp];
       dt:=x/y;
       tm:=tm-dt;
      End;
     x:=0; y:=0; ts:=0; gu:=0; gv:=0;
     For lp:=4 DownTo 0 Do
      Begin
       y:=y*tm+cfy[lp];
       ts:=ts*tm+cfh[lp];
       gu:=gu*tm+cfcd[lp];
       gv:=gv*tm+cfsd[lp];
      End;
     p:=0; b:=0; c:=0;
     For lp:=4 DownTo 1 Do
      Begin
       c:=c*tm+lp*cfx[lp];
       b:=b*tm+lp*cfy[lp];
       p:=p*tm+lp*cfh[lp];
      End;
     omg:=88957.238049-595.514*gu*gu;
     omg:=298.257/sqrt(omg);
     p:=p*pi/180;
     c:=c+p*y*gv;
     y1:=omg*y;
     b1:=omg*gv;
     b2:=297.257*omg*gu/298.257;
     gb:=1-y1*y1;
     If Not (gb<0) Then
      Begin
       gb:=sqrt(gb);
       x:=gb*b2-y1*b1;
       z:=gb*b1+y1*b2;
       If (x<0) Then b:=180 Else b:=0;
       b:=ts-b;
       While (b>0) Do b:=b-360;
       While (b<0) Do b:=b+360;
       c:=298.257*z/x;
       c:=180*arctan(c/297.257)/pi;
       omg:=jd0+(tm/24);
       cal(omg,qu,ms,an,hr,mn,sc);
       WrShortTE('Eclipse a midi local vrai le : ');
       RWriteLn('Longitude Ouest : '+FmtF(b,10,6));
       RWriteLn('Latitude Nord   : '+FmtF(c,10,6));
      End;
    End;
   If gPhWantLocal Then CalcLocal;
  End;
End; {EclipseSoleil}

Procedure EclipseLune;
Var
 jd0,x,y,z,ro,rp,dlt,w:Extended;
 grp,gro:dts;
 cfrp,cfro:cft;
 flg,lp,tp:LongInt;
Begin
 jd0:=jd;
 flg:=0;
 For lp:=-17 To 17 Do
  Begin
   jd:=jd0+(lp/128);
   t:=(jd-2451545)/365250;
   CalcNut;
   eps:=pi*(deps+84381.448+t*((1.813*t-0.059)*t-468.15))/648000;
   Terre;
   x:=x0+x9; y:=y0+y9; z:=z0+z9;
   w:=(x*x0+y*y0+z*z0)/r0;
   dlt:=sqrt(x*x+y*y+z*z-w*w);
   ro:=(696000.0*r0-689621.863*w)/r0;
   rp:=(702378.137*w-696000.0*r0)/r0;
   grp[lp]:=(rp+1737.4-dlt)/3474.8;
   gro[lp]:=(ro+1737.4-dlt)/3474.8;
   If (dlt<rp+1737.4) Then flg:=flg Or 1;
   If (dlt<ro+1737.4) Then flg:=flg Or 2;
   If (dlt<ro-1737.4) Then flg:=flg Or 4;
  End;
 CalcCfts(grp,cfrp);
 CalcCfts(gro,cfro);
 tp:=0;
 If (flg=1) Then tp:=1;
 If ((flg=2) Or (flg=3)) Then tp:=2;
 If (flg>3) Then tp:=3;
 Case tp Of
   1 : RWriteLn('Eclipse de Lune par la penombre.');
   2 : RWriteLn('Eclipse partielle de Lune.');
   3 : RWriteLn('Eclipse totale de Lune.');
  End;
 Case tp Of
  1 : Begin
       x:=-3.1875; dt:=5;
       While (abs(1728000000.0*dt)>1) Do
        Begin
         y:=0; z:=0;
         For lp:=4 DownTo 0 Do y:=y*x+cfrp[lp];
         For lp:=4 DownTo 1 Do z:=z*x+lp*cfrp[lp];
         dt:=y/z;
         x:=x-dt;
        End;
       jd:=jd0+(x/24); cal(jd,qu,ms,an,hr,mn,sc);
       WrShortTE('Entree dans la penombre le : ');
       w:=x; x:=0; dt:=5;
       While (abs(1728000000.0*dt)>1) Do
        Begin
         y:=0; z:=0;
         For lp:=4 DownTo 1 Do y:=y*x+lp*cfrp[lp];
         For lp:=4 DownTo 2 Do z:=z*x+lp*(lp-1)*cfrp[lp];
         dt:=y/z;
         x:=x-dt;
        End;
       jd:=jd0+(x/24); cal(jd,qu,ms,an,hr,mn,sc);
       WrShortTE('Maximum de l''eclipse le    : ');
       x:=2*x-w; dt:=5;
       While (abs(1728000000.0*dt)>1) Do
        Begin
         y:=0; z:=0;
         For lp:=4 DownTo 0 Do y:=y*x+cfrp[lp];
         For lp:=4 DownTo 1 Do z:=z*x+lp*cfrp[lp];
         dt:=y/z;
         x:=x-dt;
        End;
       jd:=jd0+(x/24); cal(jd,qu,ms,an,hr,mn,sc);
       WrShortTE('Sortie de la penombre le   : ');
      End;
  2 : Begin
       x:=-3.1875; dt:=5;
       While (abs(1728000000.0*dt)>1) Do
        Begin
         y:=0; z:=0;
         For lp:=4 DownTo 0 Do y:=y*x+cfrp[lp];
         For lp:=4 DownTo 1 Do z:=z*x+lp*cfrp[lp];
         dt:=y/z;
         x:=x-dt;
        End;
       jd:=jd0+(x/24); cal(jd,qu,ms,an,hr,mn,sc);
       WrShortTE('Entree dans la penombre le : ');
       x:=x/2; dt:=5;
       While (abs(1728000000.0*dt)>1) Do
        Begin
         y:=0; z:=0;
         For lp:=4 DownTo 0 Do y:=y*x+cfro[lp];
         For lp:=4 DownTo 1 Do z:=z*x+lp*cfro[lp];
         dt:=y/z;
         x:=x-dt;
        End;
       jd:=jd0+(x/24); cal(jd,qu,ms,an,hr,mn,sc);
       WrShortTE('Entree dans l''ombre le     : ');
       w:=x; x:=0; dt:=5;
       While (abs(1728000000.0*dt)>1) Do
        Begin
         y:=0; z:=0;
         For lp:=4 DownTo 1 Do y:=y*x+lp*cfro[lp];
         For lp:=4 DownTo 2 Do z:=z*x+lp*(lp-1)*cfro[lp];
         dt:=y/z;
         x:=x-dt;
        End;
       jd:=jd0+(x/24); cal(jd,qu,ms,an,hr,mn,sc);
       WrShortTE('Maximum de l''eclipse le    : ');
       x:=2*x-w; dt:=5;
       While (abs(1728000000.0*dt)>1) Do
        Begin
         y:=0; z:=0;
         For lp:=4 DownTo 0 Do y:=y*x+cfro[lp];
         For lp:=4 DownTo 1 Do z:=z*x+lp*cfro[lp];
         dt:=y/z;
         x:=x-dt;
        End;
       jd:=jd0+(x/24); cal(jd,qu,ms,an,hr,mn,sc);
       WrShortTE('Sortie de l''ombre le       : ');
       x:=3.1875; dt:=5;
       While (abs(1728000000.0*dt)>1) Do
        Begin
         y:=0; z:=0;
         For lp:=4 DownTo 0 Do y:=y*x+cfrp[lp];
         For lp:=4 DownTo 1 Do z:=z*x+lp*cfrp[lp];
         dt:=y/z;
         x:=x-dt;
        End;
       jd:=jd0+(x/24); cal(jd,qu,ms,an,hr,mn,sc);
       WrShortTE('Sortie de la penombre le   : ');
      End;
  3 : Begin
       x:=-3.1875; dt:=5;
       While (abs(1728000000.0*dt)>1) Do
        Begin
         y:=0; z:=0;
         For lp:=4 DownTo 0 Do y:=y*x+cfrp[lp];
         For lp:=4 DownTo 1 Do z:=z*x+lp*cfrp[lp];
         dt:=y/z;
         x:=x-dt;
        End;
       jd:=jd0+(x/24); cal(jd,qu,ms,an,hr,mn,sc);
       WrShortTE('Entree dans la penombre le : ');
       x:=x/1.5; dt:=5;
       While (abs(1728000000.0*dt)>1) Do
        Begin
         y:=0; z:=0;
         For lp:=4 DownTo 0 Do y:=y*x+cfro[lp];
         For lp:=4 DownTo 1 Do z:=z*x+lp*cfro[lp];
         dt:=y/z;
         x:=x-dt;
        End;
       jd:=jd0+(x/24); cal(jd,qu,ms,an,hr,mn,sc);
       WrShortTE('Entree dans l''ombre le     : ');
       x:=x/2; dt:=5;
       While (abs(1728000000.0*dt)>1) Do
        Begin
         y:=0; z:=0;
         For lp:=4 DownTo 0 Do y:=y*x+cfro[lp];
         For lp:=4 DownTo 1 Do z:=z*x+lp*cfro[lp];
         dt:=(y-1)/z;
         x:=x-dt;
        End;
       jd:=jd0+(x/24); cal(jd,qu,ms,an,hr,mn,sc);
       WrShortTE('Debut de la totalite le    : ');
       w:=x; x:=0; dt:=5;
       While (abs(1728000000.0*dt)>1) Do
        Begin
         y:=0; z:=0;
         For lp:=4 DownTo 1 Do y:=y*x+lp*cfro[lp];
         For lp:=4 DownTo 2 Do z:=z*x+lp*(lp-1)*cfro[lp];
         dt:=y/z;
         x:=x-dt;
        End;
       jd:=jd0+(x/24); cal(jd,qu,ms,an,hr,mn,sc);
       WrShortTE('Maximum de l''eclipse le    : ');
       x:=2*x-w; dt:=5;
       While (abs(1728000000.0*dt)>1) Do
        Begin
         y:=0; z:=0;
         For lp:=4 DownTo 0 Do y:=y*x+cfro[lp];
         For lp:=4 DownTo 1 Do z:=z*x+lp*cfro[lp];
         dt:=(y-1)/z;
         x:=x-dt;
        End;
       jd:=jd0+(x/24); cal(jd,qu,ms,an,hr,mn,sc);
       WrShortTE('Fin de la totalite le      : ');
       x:=2*x; dt:=5;
       While (abs(1728000000.0*dt)>1) Do
        Begin
         y:=0; z:=0;
         For lp:=4 DownTo 0 Do y:=y*x+cfro[lp];
         For lp:=4 DownTo 1 Do z:=z*x+lp*cfro[lp];
         dt:=y/z;
         x:=x-dt;
        End;
       jd:=jd0+(x/24); cal(jd,qu,ms,an,hr,mn,sc);
       WrShortTE('Sortie de l''ombre le       : ');
       x:=1.5*x; dt:=5;
       While (abs(1728000000.0*dt)>1) Do
        Begin
         y:=0; z:=0;
         For lp:=4 DownTo 0 Do y:=y*x+cfrp[lp];
         For lp:=4 DownTo 1 Do z:=z*x+lp*cfrp[lp];
         dt:=y/z;
         x:=x-dt;
        End;
       jd:=jd0+(x/24); cal(jd,qu,ms,an,hr,mn,sc);
       WrShortTE('Sortie de la penombre le   : ');
      End;
  End;
End; {EclipseLune}

Begin {Phases body - main}
 jd:=jj(qu,ms,an,hr,mn,sc);
 cor:=Trunc(jd+1.5-7*int((jd+1.5)/7));
 If (cor<0) Then cor:=cor+7;
 RWriteLn('Date et TE : '+FmtS(sem[cor],8)+FmtI(qu,3)+FmtS(mth[ms],10)+FmtI(an,6)
  +FmtI(hr,3)+FmtI(mn,3)+FmtF(sc,8,4));
 flag:=True;
 t:=(jd-2451545)/365250;
 CalcNut;
 eps:=pi*(deps+84381.448+t*((1.813*t-0.059)*t-468.15))/648000;
 Terre;
 wrk:=4.7*sin(lg9-lg0);
 If (wrk>0) Then jd:=jd-28;
 wrk:=10;
 While (abs(wrk)>LIM) Do
  Begin
   t:=(jd-2451545)/365250;
   CalcNut;
   eps:=pi*(deps+84381.448+t*((1.813*t-0.059)*t-468.15))/648000;
   Terre;
   wrk:=4.7*sin(lg9-lg0);
   jd:=jd+wrk;
  End;
 cal(jd,qu,ms,an,hr,mn,sc);
 cor:=Trunc(jd+1.5-7*int((jd+1.5)/7));
 If (cor<0) Then cor:=cor+7;
 WrPhaseTE('NL');
 wrk:=36000*abs(b9-b0)/pi;
 If (wrk<313) Then EclipseSoleil;
 wrk:=10;
 While (abs(wrk)>LIM) Do
  Begin
   t:=(jd-2451545)/365250;
   CalcNut;
   eps:=pi*(deps+84381.448+t*((1.813*t-0.059)*t-468.15))/648000;
   Terre;
   wrk:=-4.7*cos(lg9-lg0);
   jd:=jd+wrk;
  End;
 cal(jd,qu,ms,an,hr,mn,sc);
 cor:=Trunc(jd+1.5-7*int((jd+1.5)/7));
 If (cor<0) Then cor:=cor+7;
 WrPhaseTE('PQ');
 wrk:=10;
 While (abs(wrk)>LIM) Do
  Begin
   t:=(jd-2451545)/365250;
   CalcNut;
   eps:=pi*(deps+84381.448+t*((1.813*t-0.059)*t-468.15))/648000;
   Terre;
   wrk:=-4.7*sin(lg9-lg0);
   jd:=jd+wrk;
  End;
 cal(jd,qu,ms,an,hr,mn,sc);
 cor:=Trunc(jd+1.5-7*int((jd+1.5)/7));
 If (cor<0) Then cor:=cor+7;
 WrPhaseTE('PL');
 wrk:=36000*abs(b9-b0)/pi;
 If (wrk<317) Then EclipseLune;
 wrk:=10;
 While (abs(wrk)>LIM) Do
  Begin
   t:=(jd-2451545)/365250;
   CalcNut;
   eps:=pi*(deps+84381.448+t*((1.813*t-0.059)*t-468.15))/648000;
   Terre;
   wrk:=4.7*cos(lg9-lg0);
   jd:=jd+wrk;
  End;
 cal(jd,qu,ms,an,hr,mn,sc);
 cor:=Trunc(jd+1.5-7*int((jd+1.5)/7));
 If (cor<0) Then cor:=cor+7;
 WrPhaseTE('DQ');
 wrk:=10;
 While (abs(wrk)>LIM) Do
  Begin
   t:=(jd-2451545)/365250;
   CalcNut;
   eps:=pi*(deps+84381.448+t*((1.813*t-0.059)*t-468.15))/648000;
   Terre;
   wrk:=4.7*sin(lg9-lg0);
   jd:=jd+wrk;
  End;
 cal(jd,qu,ms,an,hr,mn,sc);
 cor:=Trunc(jd+1.5-7*int((jd+1.5)/7));
 If (cor<0) Then cor:=cor+7;
 WrPhaseTE('NL');
 wrk:=36000*abs(b9-b0)/pi;
 If (wrk<313) Then EclipseSoleil;
End;


Procedure DoPhases;
{ Phases de la Lune et eclipses pour la lunaison contenant une date donnee.
  Source verbatim : BIBLIP.PAS (Bureau des Longitudes). }
Var
 lgd,lgm,ltd,ltm:LongInt;
 lgs,lts:Extended;
 OK:Boolean;
Begin
 If Not InputDateTime('Phases de la Lune - Date et TE',
                      qu,ms,an,hr,mn,sc) Then Exit;
 gPhWantLocal:=YesNo('Circonstances locales',
   'Calculer les circonstances locales pour une eclipse de Soleil ?');
 If gPhWantLocal Then
  Begin
   OK:=True;
   lgd:=0; lgm:=0; lgs:=0;
   If OK Then If Not InputAngleDMS('Phases - Lieu',
        'Longitude Ouest (deg min sec, Est=negatif)',
        lgd,lgm,lgs,True) Then OK:=False;
   If OK Then gPhLg:=PI_VAL*((lgd*60+lgm)*60+lgs)/648000;
   ltd:=0; ltm:=0; lts:=0;
   If OK Then If Not InputAngleDMS('Phases - Lieu',
        'Latitude Nord (deg min sec, Sud=negatif)',
        ltd,ltm,lts,True) Then OK:=False;
   If OK Then gPhLt:=PI_VAL*((ltd*60+ltm)*60+lts)/648000;
   gPhAlt:=0.0;
   If OK Then If Not InputReal('Phases - Lieu','Altitude (m):',gPhAlt) Then OK:=False;
   gPhTEMUT:=66.0;
   If OK Then If Not InputReal('Phases - Temps',
        'Difference TE-UT estimee (s):',gPhTEMUT) Then OK:=False;
   If Not OK Then gPhWantLocal:=False;
  End;
 RClear;
 ResultTitle:='Phases de la Lune et eclipses';
 Phases;
 ResultsShow;
End;

Procedure DoLeCouMer;
{ Lever, coucher, passage au meridien d'un astre quelconque (AD+Dec).
  Source verbatim : BIBLIL.PAS, procedure LeCouMer, branche "autres astres".
  Les variantes pour le Soleil/Lune/planetes necessitent le portage des
  modules BIBLILA/BIBLILB/BIBLILC (Phase 5+). }
Var
 lg,lt,alt,sref,ts0,ts1,ad,dc,ah,az,u,v,x,y,z:Extended;
 lgdg,lgmn,ltdg,ltmn,adh,adm,dcd,dcm:LongInt;
 lgsc,ltsc,adsv,dcsv:Extended;
 estE,sudS,nordN:Boolean;
 quL,msL,anL:LongInt;
 quS,msS,anS,hrS,mnS:LongInt; scS:Extended;
 jdv,tv:Extended;
 rcp,rsp:Extended;
Begin
 { 1. Position de l'observateur }
 lgdg:=0; lgmn:=0; lgsc:=0.0;
 If Not InputAngleDMS('Lever / Coucher / Meridien',
                      'Longitude (signe : O>0, E<0)',
                      lgdg,lgmn,lgsc,True) Then Exit;
 estE:=(lgdg<0) Or (lgmn<0) Or (lgsc<0);
 lgdg:=Abs(lgdg); lgmn:=Abs(lgmn); lgsc:=Abs(lgsc);
 lg:=PI_VAL*((lgdg*60+lgmn)*60+lgsc)/648000;
 If estE Then lg:=-lg;
 ltdg:=46; ltmn:=0; ltsc:=0.0;
 If Not InputAngleDMS('Lever / Coucher / Meridien',
                      'Latitude (signe : N>0, S<0)',
                      ltdg,ltmn,ltsc,True) Then Exit;
 sudS:=(ltdg<0) Or (ltmn<0) Or (ltsc<0);
 ltdg:=Abs(ltdg); ltmn:=Abs(ltmn); ltsc:=Abs(ltsc);
 lt:=PI_VAL*((ltdg*60+ltmn)*60+ltsc)/648000;
 If sudS Then lt:=-lt;
 alt:=0.0;
 If Not InputReal('Lever / Coucher / Meridien','Altitude (m)',alt) Then Exit;
 { 2. Date }
 quL:=1; msL:=1; anL:=2000;
 If Not InputDate('Lever / Coucher / Meridien - Date civile',quL,msL,anL) Then Exit;
 If Not DateOK(quL,msL,anL) Then Begin ShowMessage('Erreur','Date invalide.'); Exit; End;
 qu:=quL; ms:=msL; an:=anL;
 { 3. Ascension droite, declinaison }
 adh:=0; adm:=0; adsv:=0.0;
 If Not InputAngleDMS('Lever / Coucher / Meridien',
                      'Ascension droite (h m s)',adh,adm,adsv,False) Then Exit;
 If (adh<0) Or (adh>=24) Or (adm<0) Or (adm>=60) Or (adsv<0) Or (adsv>=60) Then Begin
  ShowMessage('Erreur','AD doit etre dans 0..24h.'); Exit;
 End;
 dcd:=0; dcm:=0; dcsv:=0.0;
 If Not InputAngleDMS('Lever / Coucher / Meridien',
                      'Declinaison absolue (d m s)',dcd,dcm,dcsv,False) Then Exit;
 If Not DecliOK(dcd,dcm,dcsv) Then Begin ShowMessage('Erreur','Declinaison invalide.'); Exit; End;
 nordN:=YesNo('Hemisphere','Hemisphere Nord ?');
 ad:=((adh*60+adm)*60+adsv)/3600;
 dc:=PI_VAL*((dcd*60+dcm)*60+dcsv)/648000;
 If Not nordN Then dc:=-dc;
 { 4. Calcul de TS0/TS1 (verbatim BIBLILA InitJour) }
 sref:=Sin(-61*PI_VAL/18000);
 x:=REQT/Sqrt(Cos(lt)*Cos(lt)+0.99330562*Sin(lt)*Sin(lt));
 rcp:=(x+(alt/1000))*Cos(lt);
 rsp:=(0.99330562*x+(alt/1000))*Sin(lt);
 jdv:=jj(qu,ms,an,0,0,0);
 tv:=(jdv-2451545)/365250;
 t:=tv; jd:=jdv; CalcNut;
 eps:=PI_VAL*(deps+84381.448+tv*((1.813*tv-0.059)*tv-468.15))/648000;
 ts0:=24110.54841+tv*(86401848.12866+tv*(9.3104-0.0062*tv));
 ts0:=ts0+((dpsi*Cos(eps))/15)-(lg*43200/PI_VAL);
 ts0:=(ts0-86400.0*Int(ts0/86400.0))/3600;
 If ts0<0 Then ts0:=ts0+24;
 jdv:=jj(qu,ms,an,24,0,0);
 tv:=(jdv-2451545)/365250;
 t:=tv; jd:=jdv; CalcNut;
 eps:=PI_VAL*(deps+84381.448+tv*((1.813*tv-0.059)*tv-468.15))/648000;
 ts1:=24110.54841+tv*(86401848.12866+tv*(9.3104-0.0062*tv));
 ts1:=ts1+((dpsi*Cos(eps))/15)-(lg*43200/PI_VAL);
 ts1:=(ts1-86400.0*Int(ts1/86400.0))/3600;
 If ts1<0 Then ts1:=ts1+24;
 If ts1<ts0 Then ts1:=ts1+24;
 { 5. Sortie }
 RClear;
 ResultTitle:='Lever, coucher et passage au meridien';
 RWriteLn('Longitude : '+FmtF(lg*180/PI_VAL,12,6)+' deg (O+)');
 RWriteLn('Latitude  : '+FmtF(lt*180/PI_VAL,12,6)+' deg');
 RWriteLn('Altitude  : '+FmtF(alt,10,2)+' m');
 RWriteLn('Date      : '+FmtI(qu,3)+' '+mth[ms]+' '+FmtI(an,5));
 RWriteLn('AD        : '+FmtI(adh,3)+'h '+FmtI(adm,2)+'m '+FmtF(adsv,6,2)+'s');
 If nordN Then
  RWriteLn('Decl      :  '+FmtI(dcd,2)+'d '+FmtI(dcm,2)+'m '+FmtF(dcsv,6,2)+'s')
 Else
  RWriteLn('Decl      : -'+FmtI(dcd,2)+'d '+FmtI(dcm,2)+'m '+FmtF(dcsv,6,2)+'s');
 RWriteLn('TS 00h    : '+FmtF(ts0,10,6)+'h ;  TS 24h : '+FmtF(ts1,10,6)+'h');
 RWriteLn('');
 u:=Sin(lt)*Sin(dc)+Cos(lt)*Cos(dc);
 v:=Sin(lt)*Sin(dc)-Cos(lt)*Cos(dc);
 If (u<=sref) Then Begin
  RWriteLn('Point toujours au dessous de l''horizon ou y culminant.');
  RFlush; ResultsShow; Exit;
 End;
 { Meridien superieur (verbatim) }
 ah:=ad-ts0;
 If (ah<0) Then ah:=ah+24;
 az:=(24*ah)/(ts1-ts0);
 hrS:=Trunc(az); mnS:=Trunc(60*az) Mod 60; scS:=3600*az-60*Int(az*60);
 RWriteLn('Passage au meridien sup. : '+FmtI(hrS,3)+'h '+FmtI(mnS,2)+'m '+FmtF(scS,7,4)+'s TE');
 If ((ah+24+ts0)<ts1) Then Begin
  az:=(24*ah+576)/(ts1-ts0);
  hrS:=Trunc(az); mnS:=Trunc(60*az) Mod 60; scS:=3600*az-60*Int(az*60);
  RWriteLn('Second passage merid.sup.: '+FmtI(hrS,3)+'h '+FmtI(mnS,2)+'m '+FmtF(scS,7,4)+'s TE');
 End;
 If (v<=sref) Then Begin
  z:=(sref-Sin(lt)*Sin(dc))/(Cos(lt)*Cos(dc));
  z:=ArcTan(Sqrt(1-z*z)/z)*12/PI_VAL;
  If (z<0) Then z:=z+12;
  x:=ad-z; y:=ad+z;
  ah:=x-ts0; If (ah<0) Then ah:=ah+24;
  az:=(24*ah)/(ts1-ts0);
  hrS:=Trunc(az); mnS:=Trunc(60*az) Mod 60; scS:=3600*az-60*Int(az*60);
  RWriteLn('Lever                    : '+FmtI(hrS,3)+'h '+FmtI(mnS,2)+'m '+FmtF(scS,7,4)+'s TE');
  If ((ah+24+ts0)<ts1) Then Begin
   az:=(24*ah+576)/(ts1-ts0);
   hrS:=Trunc(az); mnS:=Trunc(60*az) Mod 60; scS:=3600*az-60*Int(az*60);
   RWriteLn('Second lever             : '+FmtI(hrS,3)+'h '+FmtI(mnS,2)+'m '+FmtF(scS,7,4)+'s TE');
  End;
  ah:=y-ts0; If (ah<0) Then ah:=ah+24;
  az:=(24*ah)/(ts1-ts0);
  hrS:=Trunc(az); mnS:=Trunc(60*az) Mod 60; scS:=3600*az-60*Int(az*60);
  RWriteLn('Coucher                  : '+FmtI(hrS,3)+'h '+FmtI(mnS,2)+'m '+FmtF(scS,7,4)+'s TE');
  If ((ah+24+ts0)<ts1) Then Begin
   az:=(24*ah+576)/(ts1-ts0);
   hrS:=Trunc(az); mnS:=Trunc(60*az) Mod 60; scS:=3600*az-60*Int(az*60);
   RWriteLn('Second coucher           : '+FmtI(hrS,3)+'h '+FmtI(mnS,2)+'m '+FmtF(scS,7,4)+'s TE');
  End;
 End Else Begin
  ah:=ad+12-ts0;
  If (ah>24) Then ah:=ah-24;
  If (ah<0) Then ah:=ah+24;
  az:=(24*ah)/(ts1-ts0);
  hrS:=Trunc(az); mnS:=Trunc(60*az) Mod 60; scS:=3600*az-60*Int(az*60);
  RWriteLn('Passage au meridien inf. : '+FmtI(hrS,3)+'h '+FmtI(mnS,2)+'m '+FmtF(scS,7,4)+'s TE');
  If ((ah+24+ts0)<ts1) Then Begin
   az:=(24*ah+576)/(ts1-ts0);
   hrS:=Trunc(az); mnS:=Trunc(60*az) Mod 60; scS:=3600*az-60*Int(az*60);
   RWriteLn('Second passage merid.inf.: '+FmtI(hrS,3)+'h '+FmtI(mnS,2)+'m '+FmtF(scS,7,4)+'s TE');
  End;
 End;
 RWriteLn('');
 RWriteLn('NOTE : Soleil/Lune/planetes integres en Phase 5+ (modules BIBLILA/B/C).');
 RFlush;
 ResultsShow;
End;

{ ========================================================================== }
{ ==== OBSERVATIONS PHYSIQUES DU SOLEIL (verbatim PHS1.PAS Solphys) ========= }
{ ========================================================================== }
Procedure DoSolphys;
Var
 fev,lc,bc,ap,a0,d0,w,xc,yc,xt,yt,s,th,d,l,b : Extended;
 x,y,z,u,v                                   : Extended;
 ng,nt,nw                                    : LongInt;
 tpc                                         : Char;
 Cont                                        : Boolean;
Begin
 If Not InputDateTime('Observations Soleil - Date et TE',qu,ms,an,hr,mn,sc) Then Exit;
 jd:=jj(qu,ms,an,hr,mn,sc);
 a0:=28613*pi/18000;
 d0:=6387*pi/18000;
 ReducPole(a0,d0);
 eps:=pi*(84381.448+deps+t*((1.813*t-0.059)*t-468.15))/648000.0;
 flag:=False;
 Terre;
 w:=84.10+14.1844*(jd-2451545.0-(r0/JLM));
 w:=w-360*int(w/360);
 If w<0 Then w:=w+360;
 xc:=(ad0*pi/12)-a0;
 yc:=dc0*pi/180;
 x:=cos(xc)*sin(d0)*cos(yc)-cos(d0)*sin(yc);
 y:=sin(xc)*cos(yc);
 z:=-(cos(xc)*cos(d0)*cos(yc)+sin(d0)*sin(yc));
 u:=sin(d0)*cos(yc)-cos(xc)*cos(d0)*sin(yc);
 v:=-sin(xc)*cos(d0);
 bc:=arctan(z/sqrt(x*x+y*y))*180/pi;
 If x<>0 Then lc:=arctan(y/x)*180/pi Else lc:=90*y/Abs(y);
 If x<0 Then lc:=lc+180;
 lc:=90+lc-w;
 lc:=lc-360*int(lc/360);
 If lc<0 Then lc:=lc+360;
 If u<>0 Then ap:=arctan(v/u)*180/pi Else ap:=90*v/Abs(u);
 If u<0 Then ap:=ap+180;
 If ap<0 Then ap:=ap+360;
 If ap>180 Then ap:=ap-360;
 cor:=Trunc(jd+1.5) Mod 7;
 RClear;
 ResultTitle:='Observations physiques du Soleil';
 RWriteLn('Date et TE : '+sem[cor]+FmtI(qu,3)+' '+mth[ms]+FmtI(an,6)
          +'  '+FmtI(hr,2)+'h'+FmtI(mn,3)+'m'+FmtF(sc,8,4)+'s');
 RWriteLn('Jour julien                 : '+FmtF(jd,20,10));
 RWriteLn('Angle de position du pole P : '+FmtF(ap,10,6));
 RWriteLn('Latitude du centre B0       : '+FmtF(bc,10,6));
 RWriteLn('Longitude du centre L0      : '+FmtF(lc,10,6));

 If YesNo('Soleil','Obtenir le nombre de Wolf ?') Then
  Begin
   ng:=0; nt:=0;
   wrk:=ng;
   If InputReal('Soleil','Nombre de groupes de taches :',wrk) Then ng:=Trunc(wrk);
   If ng<0 Then ng:=0;
   If ng>0 Then
    Begin
     wrk:=nt;
     If InputReal('Soleil','Nombre de taches :',wrk) Then nt:=Trunc(wrk);
     If nt<ng Then nt:=ng;
    End;
   nw:=10*ng+nt;
   RWriteLn('G = '+FmtI(ng,3)+'   T = '+FmtI(nt,4)+'   W = '+FmtI(nw,5));
  End;

 If YesNo('Soleil','Positions heliographiques de details a calculer ?') Then
  Begin
   If YesNo('Soleil','Coordonnees polaires (Non = cartesiennes) ?') Then tpc:='P' Else tpc:='C';
   bc:=pi*bc/180;
   lc:=pi*lc/180;
   d:=0;
   If Not InputReal('Soleil','Diametre apparent du Soleil sur cliche/dessin :',d) Then Exit;
   If d<=0 Then Begin ShowMessage('Erreur','Diametre <= 0'); Exit; End;
   fev:=sqrt(r0*r0-484416000000.0)*d/1392000.0;
   RWriteLn('Calcul de positions heliographiques. Diametre solaire : '+FmtF(d,8,3));
   Cont:=True;
   While Cont Do
    Begin
     s:=0; th:=0;
     If tpc='P' Then
      Begin
       If Not InputReal('Soleil','Distance r au centre (rau) :',s) Then Break;
       If Not InputReal('Soleil','Angle de position theta (deg) :',th) Then Break;
       x:=s*cos(pi*th/180);
       y:=s*sin(pi*th/180);
      End
     Else
      Begin
       If Not InputReal('Soleil','Coordonnee X (vers Nord) :',x) Then Break;
       If Not InputReal('Soleil','Coordonnee Y (vers Ouest) :',y) Then Break;
       s:=sqrt(x*x+y*y);
       If x<>0 Then th:=arctan(y/x) Else If s=0 Then th:=0 Else th:=90*y/Abs(y);
       If x<0 Then th:=th+180;
       If th<0 Then th:=th+180;
      End;
     RWriteLn('Distance au centre       : '+FmtF(s,8,3));
     RWriteLn('Angle de position        : '+FmtF(th,5,1));
     RWriteLn('Coordonnees cartesiennes : '+FmtF(x,10,3)+FmtF(y,10,3));
     If 2*s>d Then RWriteLn('*** Erreur dans la mesure : 2*s > d ***')
     Else
      Begin
       th:=pi*(ap-th)/180;
       s:=arctan(s/fev);
       wrk:=r0*sin(s)/696000.0;
       If wrk>=1.0 Then s:=(pi/2)-s Else s:=arctan(wrk/sqrt(1-wrk*wrk))-s;
       x:=(cos(s)*cos(bc)-sin(s)*sin(bc)*cos(th))*cos(lc);
       x:=x-sin(s)*sin(th)*sin(lc);
       y:=(cos(s)*cos(bc)-sin(s)*sin(bc)*cos(th))*sin(lc);
       y:=y+sin(s)*sin(th)*cos(lc);
       z:=sin(bc)*cos(s)+cos(bc)*sin(s)*cos(th);
       If x<>0 Then l:=arctan(y/x)*180/pi
       Else
        Begin
         If y<0 Then l:=270;
         If y>0 Then l:=90;
         If y=0 Then l:=0;
        End;
       If x<0 Then l:=l+180;
       If l<0 Then l:=l+360;
       b:=arctan(z/sqrt(x*x+y*y))*180/pi;
       RWriteLn('L = '+FmtF(l,6,2)+'   B = '+FmtF(b,6,2));
      End;
     Cont:=YesNo('Soleil','Un autre detail ?');
    End;
  End;
 ResultsShow;
End;

{ ========================================================================== }
{ ==== OBSERVATIONS PHYSIQUES DE LA LUNE (verbatim PHS1.PAS Selenogr) ====== }
{ ========================================================================== }
Procedure DoSelenogr;
Var
 fev,l,b,s,th,ap,lc,bc,ls,bs,fil,th0,aph,ts,lm,lg,lt,lgX : Extended;
 ah,wM,e1,e2,e3,e4,e5,e6,e7,e8,e9,e10,e11,e12,e13,cls    : Extended;
 a0,d0,asA,ds,ai,di,x,y,z,u,v,xs,ys,zs,us,vs,ws,d          : Extended;
 elg,dlg,ecl,rcp,rsp                                       : Extended;
 lgdg,lgmn,ltdg,ltmn,js                                    : LongInt;
 lgsc,ltsc                                                 : Extended;
 lgh,lth,tpc                                               : Char;
 Cont                                                      : Boolean;
Begin
 { --- Lieu d'observation (topocentrique) --- }
 lgdg:=0; lgmn:=0; lgsc:=0;
 If Not InputAngleDMS('Selenographie','Longitude (valeur absolue)',
                     lgdg,lgmn,lgsc,False) Then Exit;
 lgh:='O';
 If YesNo('Selenographie','Longitude Est (Non = Ouest) ?') Then lgh:='E' Else lgh:='O';
 ltdg:=0; ltmn:=0; ltsc:=0;
 If Not InputAngleDMS('Selenographie','Latitude (valeur absolue)',
                     ltdg,ltmn,ltsc,True) Then Exit;
 lth:='N';
 If YesNo('Selenographie','Latitude Sud (Non = Nord) ?') Then lth:='S' Else lth:='N';
 z:=0;
 If Not InputReal('Selenographie','Altitude (metres) :',z) Then Exit;

 lg:=((lgdg*60+lgmn)*60+lgsc)/3600;
 If lgh='E' Then lg:=-lg;
 lt:=((ltdg*60+ltmn)*60+ltsc)/3600;
 If lth='S' Then lt:=-lt;

 RClear;
 ResultTitle:='Observations physiques de la Lune';
 RWriteLn('Longitude Ouest : '+FmtF(lg,10,6));
 RWriteLn('Latitude Nord   : '+FmtF(lt,10,6));
 RWriteLn('Altitude (en m) : '+FmtF(z,10,3));

 lg:=pi*lg/180;
 lt:=pi*lt/180;
 x:=REQT/sqrt(cos(lt)*cos(lt)+0.99330562*sin(lt)*sin(lt));
 rcp:=(x+(z/1000))*cos(lt);
 rsp:=(0.99330562*x+(z/1000))*sin(lt);
 RWriteLn('Rau*cos(phi) = '+FmtF(rcp,10,3));
 RWriteLn('Rau*sin(phi) = '+FmtF(rsp,10,3));

 If Not InputDateTime('Selenographie - Date et TE',qu,ms,an,hr,mn,sc) Then Exit;
 jd:=jj(qu,ms,an,hr,mn,sc);
 Lune;
 t:=(jd-2451545)/36525;
 wrk:=jd-2451545.0-(r9/JLM);
 e1:=125.045-0.0529921*wrk;
 e2:=250.089-0.1059842*wrk;
 e3:=260.008+13.0120009*wrk;
 e4:=176.625+13.3407154*wrk;
 e5:=357.529+0.9856003*wrk;
 e6:=311.589+26.4057084*wrk;
 e7:=134.963+13.0649930*wrk;
 e8:=276.617+0.3287146*wrk;
 e9:=34.226+1.7484877*wrk;
 e10:=15.134-0.1589763*wrk;
 e11:=119.743+0.0036096*wrk;
 e12:=239.961+0.1643573*wrk;
 e13:=25.053+12.9590088*wrk;
 e1:=e1-360*int(e1/360);   e2:=e2-360*int(e2/360);
 e3:=e3-360*int(e3/360);   e4:=e4-360*int(e4/360);
 e5:=e5-360*int(e5/360);   e6:=e6-360*int(e6/360);
 e7:=e7-360*int(e7/360);   e8:=e8-360*int(e8/360);
 e9:=e9-360*int(e9/360);   e10:=e10-360*int(e10/360);
 e11:=e11-360*int(e11/360); e12:=e12-360*int(e12/360);
 e13:=e13-360*int(e13/360);
 If e1<0 Then e1:=e1+360;   If e2<0 Then e2:=e2+360;
 If e3<0 Then e3:=e3+360;   If e4<0 Then e4:=e4+360;
 If e5<0 Then e5:=e5+360;   If e6<0 Then e6:=e6+360;
 If e7<0 Then e7:=e7+360;   If e8<0 Then e8:=e8+360;
 If e9<0 Then e9:=e9+360;   If e10<0 Then e10:=e10+360;
 If e11<0 Then e11:=e11+360; If e12<0 Then e12:=e12+360;
 If e13<0 Then e13:=e13+360;
 e1:=e1*pi/180;   e2:=e2*pi/180;
 e3:=e3*pi/180;   e4:=e4*pi/180;
 e5:=e5*pi/180;   e6:=e6*pi/180;
 e7:=e7*pi/180;   e8:=e8*pi/180;
 e9:=e9*pi/180;   e10:=e10*pi/180;
 e11:=e11*pi/180; e12:=e12*pi/180;
 e13:=e13*pi/180;
 a0:=(2699949+31*t-38787*sin(e1)-1204*sin(e2)+700*sin(e3)-172*sin(e4)+72*sin(e6)-52*sin(e10)+43*sin(e13))*pi/1800000;
 d0:=(665392+130*t+15419*cos(e1)+239*cos(e2)-278*cos(e3)+68*cos(e4)-29*cos(e6)+9*cos(e7)+8*cos(e10)-9*cos(e13))*pi/1800000;
 wM:=383213+wrk*(131763.5815-0.000000014*wrk)+35610*sin(e1)+1208*sin(e2);
 wM:=wM-642*sin(e3)+158*sin(e4)+252*sin(e5)-66*sin(e6)-47*sin(e7)-46*sin(e8);
 wM:=(wM+28*sin(e9)+52*sin(e10)+40*sin(e11)+19*sin(e12)-44*sin(e13))/10000;
 wM:=wM-360*int(wM/360);
 If wM<0 Then wM:=wM+360;
 ReducPole(a0,d0);
 eps:=pi*(deps+84381.448+t*((1.813*t-0.059)*t-468.15))/648000.0;
 flag:=False;
 Terre;
 x:=x0+x9; y:=y0+y9; z:=z0+z9;
 If x<>0 Then asA:=arctan(y/x) Else asA:=-pi*y/Abs(2*y);
 If x>0 Then asA:=asA+pi;
 If asA<0 Then asA:=asA+2*pi;
 ds:=-arctan(z/sqrt(x*x+y*y));
 ai:=pi*ad9/12;
 di:=pi*dc9/180;
 x:=cos(di)*sin(d0)*cos(a0-ai)-sin(di)*cos(d0);
 y:=-sin(a0-ai)*cos(di);
 z:=-(cos(di)*cos(d0)*cos(a0-ai)+sin(di)*sin(d0));
 u:=cos(di)*sin(d0)-sin(di)*cos(d0)*cos(a0-ai);
 v:=sin(a0-ai)*cos(d0);
 xs:=sin(ds)*cos(d0)-cos(ds)*sin(d0)*cos(asA-a0);
 ys:=sin(a0-asA)*cos(ds);
 zs:=cos(ds)*cos(d0)*cos(asA-a0)+sin(ds)*sin(d0);
 us:=sin(ds)*cos(di)-cos(ds)*sin(di)*cos(asA-ai);
 vs:=sin(asA-ai)*cos(ds);
 ws:=-(cos(ds)*cos(di)*cos(asA-ai)+sin(ds)*sin(di));
 ap:=arctan(v/u)*180/pi;
 If ap<0 Then ap:=ap+360;
 fil:=(1+ws)/2;
 If u<>0 Then ap:=arctan(v/u)*180/pi Else If v=0 Then ap:=0 Else ap:=90*v/Abs(v);
 If u<0 Then ap:=ap+180;
 If ap<0 Then ap:=ap+360;
 If x<>0 Then lc:=arctan(y/x)*180/pi Else lc:=90*y/Abs(y);
 If x<0 Then lc:=lc+180;
 lc:=90+lc-wM;
 lc:=lc-360*int(lc/360);
 If lc<0 Then lc:=lc+360;
 If lc>180 Then lc:=lc-360;
 wrk:=sqrt(x*x+y*y);
 If wrk<>0 Then bc:=arctan(z/wrk)*180/pi Else bc:=90*z/Abs(z);
 If xs<>0 Then ls:=arctan(ys/xs)*180/pi Else ls:=90*ys/Abs(ys);
 If xs<0 Then ls:=ls+180;
 ls:=90+ls-wM;
 ls:=ls-360*int(ls/360);
 If ls<0 Then ls:=ls+360;
 If ls>180 Then ls:=ls-360;
 cls:=90-ls;
 If cls<0 Then cls:=cls+360;
 wrk:=sqrt(xs*xs+ys*ys);
 If wrk<>0 Then bs:=arctan(zs/wrk)*180/pi Else bs:=90*zs/Abs(zs);
 If us<>0 Then th0:=arctan(vs/us)*180/pi Else If vs=0 Then th0:=0 Else th0:=90*vs/Abs(vs);
 If us<0 Then th0:=th0+180;
 If th0<0 Then th0:=th0+360;
 x:=y9*z0-y0*z9;
 u:=z9*x0-z0*x9;
 v:=x9*y0-x0*y9;
 y:=u*cos(eps)+v*sin(eps);
 z:=v*cos(eps)-u*sin(eps);
 u:=z*sqrt(x*x+y*y+z*z)/Abs(z);
 v:=x9*(x9+x0)+y9*(y9+y0)+z9*(z9+z0);
 If v<>0 Then aph:=180*arctan(u/v)/pi Else aph:=90*u/Abs(u);
 If v<0 Then aph:=aph+180;
 If aph>180 Then aph:=aph-360;
 wrk:=-(x0*x9+y0*y9+z0*z9);
 If wrk<>0 Then elg:=180*arctan(u/wrk)/pi Else elg:=90*u/Abs(u);
 If wrk<0 Then elg:=elg+180;
 If elg>180 Then elg:=elg-360;
 v:=x9*(x9+x0)+y9*(y9+y0)*cos(eps)*cos(eps)+z9*(z9+z0)*sin(eps)*sin(eps)+(z9*(y9+y0)+y9*(z9+z0))*cos(eps)*sin(eps);
 If v<>0 Then dlg:=180*arctan(z/v)/pi Else dlg:=90*z/Abs(z);
 If v<0 Then dlg:=dlg+180;
 If dlg>180 Then dlg:=dlg-360;
 wrk:=-(x9*x0+y9*y0*cos(eps)*cos(eps)+z9*z0*sin(eps)*sin(eps)+(z9*y0+y9*z0)*cos(eps)*sin(eps));
 If wrk<>0 Then ecl:=180*arctan(z/wrk)/pi Else ecl:=90*z/Abs(z);
