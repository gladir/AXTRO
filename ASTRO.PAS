{ -------------------------------------------------------------------------- }
{ DoCal2JD : Conversion date civile -> jour julien (Jrjulien original)      }
{ Source : BIBLIU.PAS lignes 97-178.                                        }
{ -------------------------------------------------------------------------- }
Procedure DoCal2JD;
Var
 jsv:LongInt;
 sec0:Extended;
Begin
 qu:=1; ms:=1; an:=2000; hr:=0; mn:=0; sc:=0.0;
 If Not InputDateTime('Date civile -> JD',qu,ms,an,hr,mn,sc) Then Exit;
 RClear;
 ResultTitle:='Date civile -> Jour julien';
 jd:=jj(qu,ms,an,hr,mn,sc);
 jsv:=Trunc(jd+1.5) Mod 7;
 sec0:=sc;
 RWriteLn('Date saisie : '+sem[jsv]+' '+FmtI(qu,2)+' '+mth[ms]+' '+FmtI(an,5));
 RWriteLn('              '+FmtI(hr,2)+'h '+FmtI(mn,2)+'m '+FmtF(sec0,5,2)+'s TU');
 RWriteLn('');
 RWriteLn('Jour julien (JD) : '+FmtF(jd,16,8));
 RWriteLn('JD modifie (MJD) : '+FmtF(jd-2400000.5,12,8));
 RWriteLn('J2000 (jours)    : '+FmtF(jd-2451545.0,12,8));
 RWriteLn('Annees julien.   : '+FmtF((jd-2451545.0)/365.25,12,6));
 RWriteLn('Siecles julien.  : '+FmtF((jd-2451545.0)/36525.0,14,9));
 ResultsShow;
End;

{ -------------------------------------------------------------------------- }
{ DoJD2Cal : Conversion jour julien -> date civile (Calendar original)      }
{ Source : BIBLIU.PAS lignes 181-258.                                       }
{ -------------------------------------------------------------------------- }
Procedure DoJD2Cal;
Var
 jsv:LongInt;
Begin
 jd:=2451545.0;
 If Not InputJD('Jour julien -> Date civile',jd) Then Exit;
 RClear;
 ResultTitle:='Jour julien -> Date civile';
 cal(jd,qu,ms,an,hr,mn,sc);
 jsv:=Trunc(jd+1.5) Mod 7;
 RWriteLn('Jour julien : '+FmtF(jd,16,8));
 RWriteLn('');
 RWriteLn('Date civile : '+sem[jsv]+' '+FmtI(qu,2)+' '+mth[ms]+' '+FmtI(an,5));
 RWriteLn('Heure TU    : '+FmtI(hr,2)+'h '+FmtI(mn,2)+'m '+FmtF(sc,5,2)+'s');
 RWriteLn('');
 RWriteLn('JD modifie (MJD) : '+FmtF(jd-2400000.5,12,8));
 RWriteLn('Depuis J2000     : '+FmtF(jd-2451545.0,12,8)+' jours');
 ResultsShow;
End;

{ -------------------------------------------------------------------------- }
{ DoJrdansan : Rang du jour dans l'annee (Jrdansan original)                }
{ Source : BIBLIU.PAS lignes 17-94.                                         }
{ -------------------------------------------------------------------------- }
Procedure DoJrdansan;
Var
 rg,jsv:LongInt;
 jdv:Extended;
Begin
 qu:=1; ms:=1; an:=2000;
 If Not InputDate('Rang du jour dans l''annee',qu,ms,an) Then Exit;
 RClear;
 ResultTitle:='Rang du jour dans l''annee';
 rg:=jda(qu,ms,an);
 jdv:=jj(qu,ms,an,0,0,0.0);
 jsv:=Trunc(jdv+1.5) Mod 7;
 RWriteLn('Date : '+sem[jsv]+' '+FmtI(qu,2)+' '+mth[ms]+' '+FmtI(an,5));
 RWriteLn('');
 RWriteLn('Rang dans l''annee : '+FmtI(rg,4));
 If ((an Mod 4)=0) And (((an Mod 100)<>0) Or ((an Mod 400)=0) Or (an<1582)) Then
  RWriteLn('Annee bissextile (366 jours)')
 Else
  RWriteLn('Annee non bissextile (365 jours)');
 ResultsShow;
End;

{ -------------------------------------------------------------------------- }
{ DoPaques : Date de Paques + saisons + fetes mobiles                       }
{ NOTE : version simplifiee Phase 1 - calcul de Paques uniquement par le    }
{ comput gregorien (et julien si demande). Le calcul des saisons necessite  }
{ les routines Terre/CalcNut qui seront ajoutees en Phase 2 avec les longs  }
{ developpements en serie de Bibli0.                                        }
{ Source : BIBLIU.PAS procedure Paques.                                     }
{ -------------------------------------------------------------------------- }
Procedure DoPaques;
{ Saisons + Paques (gregorien et julien) + fetes mobiles.
  Formules verbatim de BIBLIU.PAS (procedure Paques). }
Var
 a,b,c,d2,e2,fp,gp,hp,ip,kp,lp,m2,n2,p2,js,yr:LongInt;
 dt,eqp,sle,eqa,slh,j0,limite:Extended;
 jdv:Extended; n:LongInt;
Begin
 yr:=2026;
 If Not InputYear('Saisons, Paques et fetes mobiles',yr) Then Exit;
 If yr<326 Then Begin
  ShowMessage('Note','Calculs definis a partir de l''annee 326.'); Exit;
 End;
 an:=yr;
 RClear;
 ResultTitle:='Saisons, Paques et fetes mobiles - annee '+FmtI(yr,5);
 limite:=3.0/8388608.0;
 j0:=jj(0,1,yr,0,0,0.0);
 t:=yr/1000;
 eqp:=1721139.2855+365.2421376*yr+t*t*(0.067919-0.0027879*t);
 sle:=1721233.2486+365.2417284*yr-t*t*(0.053018-0.0093320*t);
 eqa:=1721325.6978+365.2425055*yr-t*t*(0.126689-0.0019401*t);
 slh:=1721414.3920+365.2428898*yr-t*t*(0.010965+0.0084885*t);
 flag:=False;
 { Printemps : iteration sur la longitude solaire }
 jd:=eqp; dt:=1.0;
 While (Abs(dt)>limite) Do Begin
  t:=(jd-2451545)/365250;
  CalcNut;
  eps:=PI_VAL*(deps+84381.448+t*((1.813*t-0.059)*t-468.15))/648000;
  Terre;
  dt:=58.0*Sin(lg0);
  jd:=jd+dt;
 End;
 eqp:=jd;
 jd:=sle; dt:=1.0;
 While (Abs(dt)>limite) Do Begin
  t:=(jd-2451545)/365250;
  CalcNut;
  eps:=PI_VAL*(deps+84381.448+t*((1.813*t-0.059)*t-468.15))/648000;
  Terre;
  dt:=-58.0*Cos(lg0);
  jd:=jd+dt;
 End;
 sle:=jd;
 jd:=eqa; dt:=1.0;
 While (Abs(dt)>limite) Do Begin
  t:=(jd-2451545)/365250;
  CalcNut;
  eps:=PI_VAL*(deps+84381.448+t*((1.813*t-0.059)*t-468.15))/648000;
  Terre;
  dt:=-58.0*Sin(lg0);
  jd:=jd+dt;
 End;
 eqa:=jd;
 jd:=slh; dt:=1.0;
 While (Abs(dt)>limite) Do Begin
  t:=(jd-2451545)/365250;
  CalcNut;
  eps:=PI_VAL*(deps+84381.448+t*((1.813*t-0.059)*t-468.15))/648000;
  Terre;
  dt:=58.0*Cos(lg0);
  jd:=jd+dt;
 End;
 slh:=jd;
 RWriteLn('SAISONS (temps des ephemerides) :');
 RWriteLn('');
 cal(eqp,qu,ms,an,hr,mn,sc); js:=Trunc(eqp+1.5) Mod 7;
 RWriteLn('Printemps : '+sem[js]+FmtI(qu,3)+FmtI(ms,3)+FmtI(an,6)+
          '  a '+FmtI(hr,2)+'h'+FmtI(mn,3)+'mn'+FmtF(sc,5,1)+
          's  JJ = '+FmtF(eqp,18,9));
 cal(sle,qu,ms,an,hr,mn,sc); js:=Trunc(sle+1.5) Mod 7;
 RWriteLn('Ete       : '+sem[js]+FmtI(qu,3)+FmtI(ms,3)+FmtI(an,6)+
          '  a '+FmtI(hr,2)+'h'+FmtI(mn,3)+'mn'+FmtF(sc,5,1)+
          's  JJ = '+FmtF(sle,18,9));
 cal(eqa,qu,ms,an,hr,mn,sc); js:=Trunc(eqa+1.5) Mod 7;
 RWriteLn('Automne   : '+sem[js]+FmtI(qu,3)+FmtI(ms,3)+FmtI(an,6)+
          '  a '+FmtI(hr,2)+'h'+FmtI(mn,3)+'mn'+FmtF(sc,5,1)+
          's  JJ = '+FmtF(eqa,18,9));
 cal(slh,qu,ms,an,hr,mn,sc); js:=Trunc(slh+1.5) Mod 7;
 RWriteLn('Hiver     : '+sem[js]+FmtI(qu,3)+FmtI(ms,3)+FmtI(an,6)+
          '  a '+FmtI(hr,2)+'h'+FmtI(mn,3)+'mn'+FmtF(sc,5,1)+
          's  JJ = '+FmtF(slh,18,9));
 RWriteLn('');
 RWriteLn('PAQUES :');
 RWriteLn('');
 { Comput gregorien ou julien selon l'annee - formules verbatim BIBLIU.PAS }
 If (yr>1582) Then Begin
  a:=yr Mod 19;
  b:=yr Div 100;
  c:=yr Mod 100;
  d2:=b Div 4;
  e2:=b Mod 4;
  fp:=(b+8) Div 25;
  gp:=(b-fp+1) Div 3;
  hp:=(19*a+b-d2-gp+15) Mod 30;
  ip:=c Div 4;
  kp:=c Mod 4;
  lp:=(32+2*(ip+e2)-hp-kp) Mod 7;
  m2:=(a+11*(hp+2*lp)) Div 451;
  n2:=hp+lp-7*m2+114;
  p2:=n2 Mod 31;
  n2:=n2 Div 31;
  ms:=n2;
  qu:=p2+1;
 End
 Else Begin
  a:=yr Mod 4;
  b:=yr Mod 7;
  c:=yr Mod 19;
  d2:=(19*c+15) Mod 30;
  e2:=(2*a+4*b-d2+34) Mod 7;
  fp:=d2+e2+114;
  gp:=fp Mod 31;
  fp:=fp Div 31;
  ms:=fp;
  qu:=gp+1;
 End;
 n:=jda(qu,ms,yr);
 an:=yr;
 jdv:=j0+n;     cal(jdv,qu,ms,an,hr,mn,sc); js:=Trunc(jdv+1.5) Mod 7;
 RWriteLn('Paques         : '+sem[js]+FmtI(qu,3)+' '+mth[ms]+FmtI(an,6)+
          '  Rang dans l''annee : '+FmtI(n,4));
 RWriteLn('');
 RWriteLn('FETES MOBILES :');
 RWriteLn('');
 jdv:=j0+n-46;  cal(jdv,qu,ms,an,hr,mn,sc); js:=Trunc(jdv+1.5) Mod 7;
 RWriteLn('Cendres        : '+sem[js]+FmtI(qu,3)+' '+mth[ms]+FmtI(an,6)+
          '  Rang dans l''annee : '+FmtI(n-46,4));
 jdv:=j0+n-3;   cal(jdv,qu,ms,an,hr,mn,sc); js:=Trunc(jdv+1.5) Mod 7;
 RWriteLn('Jeudi saint    : '+sem[js]+FmtI(qu,3)+' '+mth[ms]+FmtI(an,6));
 jdv:=j0+n-2;   cal(jdv,qu,ms,an,hr,mn,sc); js:=Trunc(jdv+1.5) Mod 7;
 RWriteLn('Vendredi saint : '+sem[js]+FmtI(qu,3)+' '+mth[ms]+FmtI(an,6));
 jdv:=j0+n-1;   cal(jdv,qu,ms,an,hr,mn,sc); js:=Trunc(jdv+1.5) Mod 7;
 RWriteLn('Samedi saint   : '+sem[js]+FmtI(qu,3)+' '+mth[ms]+FmtI(an,6));
 jdv:=j0+n+39;  cal(jdv,qu,ms,an,hr,mn,sc); js:=Trunc(jdv+1.5) Mod 7;
 RWriteLn('Ascension      : '+sem[js]+FmtI(qu,3)+' '+mth[ms]+FmtI(an,6));
 jdv:=j0+n+49;  cal(jdv,qu,ms,an,hr,mn,sc); js:=Trunc(jdv+1.5) Mod 7;
 RWriteLn('Pentecote      : '+sem[js]+FmtI(qu,3)+' '+mth[ms]+FmtI(an,6));
 RFlush;
 ResultsShow;
End;

{ -------------------------------------------------------------------------- }
{ DoConvCal : Conversion de calendriers - civil/julien/musulman/maya/hebreu }
{ Verbatim BIBLIC.PAS : entree dans n'importe quel calendrier, sortie tous. }
{ -------------------------------------------------------------------------- }
Procedure DoConvCal;
Var
 qj,mj,aj,hj,nj:LongInt;
 sj,jdv,jdv2:Extended;
 jsv:LongInt;
 a,b,c,d2,e2:LongInt;
 quM,msM,anM,hrM,mnM:LongInt; scM:Extended;
 ah,kc,ca,pic,bk,kt,tn,ui,kn:LongInt;
 tzhb:String;
 ier:Boolean;
 src:String;
 qh,mh,anh,hrh,halH:LongInt; regH:Extended;
 cor:LongInt;
Begin
 src:='C';
 If Not InputString('Conversion calendriers',
   'Calendrier source (C=Civil, M=Musulman, H=Hebreu, Y=Maya)',src,1) Then Exit;
 If Length(src)<1 Then Exit;
 src[1]:=UpCase(src[1]);
 If Not (src[1] In ['C','M','H','Y']) Then Begin
  ShowMessage('Erreur','Lettre invalide. Tapez C, M, H ou Y.'); Exit;
 End;

 jdv:=0;

 If src[1]='C' Then Begin
  qj:=1; mj:=1; aj:=2000; hj:=0; nj:=0; sj:=0.0;
  If Not InputDateTime('Date civile',qj,mj,aj,hj,nj,sj) Then Exit;
  If Not DateOK(qj,mj,aj) Then Begin ShowMessage('Erreur','Date civile invalide.'); Exit; End;
  If Not HeureOK(hj,nj,sj) Then Begin ShowMessage('Erreur','Heure invalide.'); Exit; End;
  qu:=qj; ms:=mj; an:=aj; hr:=hj; mn:=nj; sc:=sj;
  jdv:=jj(qu,ms,an,hr,mn,sc);
 End
 Else If src[1]='M' Then Begin
  qj:=1; mj:=1; aj:=1445; hj:=0; nj:=0; sj:=0.0;
  If Not InputDateTime('Date musulmane (qu/ms/an h n s)',qj,mj,aj,hj,nj,sj) Then Exit;
  If (qj<1) Or (qj>30) Or (mj<1) Or (mj>12) Then Begin
   ShowMessage('Erreur','Quantieme/mois musulman invalide.'); Exit;
  End;
  If Not HeureOK(hj,nj,sj) Then Begin ShowMessage('Erreur','Heure invalide.'); Exit; End;
  jdv:=arjj(qj,mj,aj,hj,nj,sj);
 End
 Else If src[1]='H' Then Begin
  qh:=1; mh:=1; anh:=5786; hrh:=0; halH:=0; regH:=0.0;
  If Not InputInt('Date hebraique','Quantieme du mois',qh) Then Exit;
  If Not InputInt('Date hebraique','Numero du mois (1=Tichri ... 12 ou 13)',mh) Then Exit;
  If Not InputInt('Date hebraique','Annee hebraique (>0)',anh) Then Exit;
  If Not InputInt('Date hebraique','Heure (0..23)',hrh) Then Exit;
  If Not InputInt('Date hebraique','Halakim (0..1079, 1080/heure)',halH) Then Exit;
  If Not InputReal('Date hebraique','Regaim (0..76, 76/helek)',regH) Then Exit;
  jdv:=hebjj(qh,mh,anh,hrh,halH,regH,ier);
  If ier Then Begin ShowMessage('Erreur','Date hebraique invalide.'); Exit; End;
 End
 Else Begin  { Maya }
  ah:=0; kc:=0; ca:=0; pic:=0; bk:=13; kt:=0; tn:=0; ui:=0; kn:=0;
  If YesNo('Date maya','Version longue du long compte (9 chiffres) ?') Then Begin
   If Not InputInt('Maya','Ahautun (0..19)',ah) Then Exit;
   If Not InputInt('Maya','Kinchiltun (0..19)',kc) Then Exit;
   If Not InputInt('Maya','Calabtun (0..19)',ca) Then Exit;
   If Not InputInt('Maya','Pictun (0..19)',pic) Then Exit;
  End;
  If Not InputInt('Maya','Baktun (0..19)',bk) Then Exit;
  If Not InputInt('Maya','Katun (0..19)',kt) Then Exit;
  If Not InputInt('Maya','Tun (0..19)',tn) Then Exit;
  If Not InputInt('Maya','Uinal (0..17)',ui) Then Exit;
  If Not InputInt('Maya','Kin (0..19)',kn) Then Exit;
  jdv:=mayajj(ah,kc,ca,pic,bk,kt,tn,ui,kn);
 End;

 jsv:=Trunc(jdv+1.5) Mod 7;
 RClear;
 ResultTitle:='Conversion de calendriers';
 RWriteLn('Jour julien : '+FmtF(jdv,18,8));
 RWriteLn('Jour de la semaine : '+sem[jsv]);
 RWriteLn('');

 { Calendrier civil (julien ou gregorien) }
 jdv2:=jdv+0.5;
 a:=Trunc(jdv2);
 b:=a+1524;
 c:=Trunc((b-122.1)/365.25);
 d2:=Trunc(365.25*c);
 e2:=Trunc((b-d2)/30.6001);
 qu:=b-d2-Trunc(30.6001*e2);
 If e2<14 Then ms:=e2-1 Else ms:=e2-13;
 If ms>2 Then an:=c-4716 Else an:=c-4715;
 { Heure }
 wrk:=jdv2-Int(jdv2);
 hr:=Trunc(24*wrk);
 mn:=Trunc(1440*wrk) Mod 60;
 sc:=86400*wrk; sc:=sc-60*Int(sc/60);
 RWriteLn('CALENDRIER CIVIL :');
 RWriteLn('  '+FmtI(qu,3)+' '+mth[ms]+' '+FmtI(an,5)+
          '  '+FmtI(hr,2)+'h '+FmtI(mn,2)+'m '+FmtF(sc,6,2)+'s');
 RWriteLn('');

 { Musulman }
 RWriteLn('CALENDRIER MUSULMAN :');
 If jdv<1948439.138916015625 Then
  RWriteLn('  Date anterieure au calendrier musulman.')
 Else Begin
  arcal(jdv,quM,msM,anM,hrM,mnM,scM,ier);
  If ier Then RWriteLn('  (conversion impossible)')
  Else Begin
   cor:=Trunc(arjj(1,1,anM+1,12,0,0)-arjj(1,1,anM,0,0,0))-354;
   RWriteLn('  '+FmtI(quM,3)+'/'+FmtI(msM,2)+'/'+FmtI(anM,5)+
            '  '+FmtI(hrM,2)+'h '+FmtI(mnM,2)+'m '+FmtF(scM,6,2)+'s  (AH)');
   If cor=0 Then RWriteLn('  Annee commune.')
            Else RWriteLn('  Annee abondante.');
  End;
 End;
 RWriteLn('');

 { Hebreu }
 RWriteLn('CALENDRIER HEBRAIQUE :');
 If jdv<347985.1522216796875 Then
  RWriteLn('  Date anterieure au calendrier hebraique.')
 Else Begin
  hebcal(jdv,qh,mh,anh,hrh,halH,regH,ier);
  If ier Then RWriteLn('  (conversion impossible)')
  Else Begin
   RWriteLn('  '+FmtI(qh,3)+'/'+FmtI(mh,2)+'/'+FmtI(anh,5)+
            '  '+FmtI(hrh,2)+'h '+FmtI(halH,5)+'hal '+FmtF(regH,7,3)+'reg');
   Case hebJsrhp Of
     0 : RWriteLn('  Roch Hachana : Chabbat.');
     2 : RWriteLn('  Roch Hachana : Lundi.');
     3 : RWriteLn('  Roch Hachana : Mardi.');
     5 : RWriteLn('  Roch Hachana : Jeudi.');
   End;
   Case hebNja Of
     353 : RWriteLn('  Annee commune defective.');
     354 : RWriteLn('  Annee commune reguliere.');
     355 : RWriteLn('  Annee commune abondante.');
     383 : RWriteLn('  Annee embolismique defective.');
     384 : RWriteLn('  Annee embolismique reguliere.');
     385 : RWriteLn('  Annee embolismique abondante.');
   End;
   Case hebJspssh Of
     0 : RWriteLn('  Pessah debute : Chabbat.');
     1 : RWriteLn('  Pessah debute : Dimanche.');
     3 : RWriteLn('  Pessah debute : Mardi.');
     5 : RWriteLn('  Pessah debute : Jeudi.');
   End;
  End;
 End;
 RWriteLn('');

 { Maya }
 RWriteLn('CALENDRIER MAYA :');
 If jdv<584282.5 Then
  RWriteLn('  Date anterieure au calendrier maya.')
 Else Begin
  mayacal(jdv,ah,kc,ca,pic,bk,kt,tn,ui,kn,tzhb,ier);
  If ier Then RWriteLn('  (conversion impossible)')
  Else Begin
   RWriteLn('  Long count : '+FmtI(ah,3)+'.'+FmtI(kc,2)+'.'+FmtI(ca,2)+
            '.'+FmtI(pic,2)+'.'+FmtI(bk,2)+'.'+FmtI(kt,2)+
            '.'+FmtI(tn,2)+'.'+FmtI(ui,2)+'.'+FmtI(kn,2));
   RWriteLn('  Haab/Tzolkin :'+tzhb);
  End;
 End;
 RFlush;
 ResultsShow;
End;

{ -------------------------------------------------------------------------- }
{ DoEquaTps : Equation du temps (placeholder, sera complete phase 2)        }
{ -------------------------------------------------------------------------- }
Procedure DoEquaTps;
{ Equation du temps. Formules verbatim de BIBLIU.PAS. }
Var
 eqt,ts:Extended;
 quL,msL,anL,hrL,mnL:LongInt; scL:Extended;
Begin
 quL:=15; msL:=6; anL:=2024; hrL:=12; mnL:=0; scL:=0.0;
 If Not InputDateTime('Equation du temps - Date et TE',
                      quL,msL,anL,hrL,mnL,scL) Then Exit;
 If Not DateOK(quL,msL,anL) Then Begin
  ShowMessage('Erreur','Date invalide.'); Exit;
 End;
 If Not HeureOK(hrL,mnL,scL) Then Begin
  ShowMessage('Erreur','Heure invalide.'); Exit;
 End;
 qu:=quL; ms:=msL; an:=anL; hr:=hrL; mn:=mnL; sc:=scL;
 jd:=jj(qu,ms,an,hr,mn,sc);
 t:=(jd-2451545)/365250;
 flag:=False;
 CalcNut;
 eps:=PI_VAL*(deps+84381.448+t*((1.813*t-0.059)*t-468.15))/648000;
 Terre;
 ts:=24110.54841+t*(86401848.12866+t*(9.3104-0.0062*t))+((dpsi*Cos(eps))/15);
 ts:=ts-86400*Int(ts/86400);
 If (ts<0) Then ts:=ts+86400;
 eqt:=3600*ad0+43200-ts;
 eqt:=eqt-86400*Int(eqt/86400);
 If (eqt>43200) Then eqt:=eqt-86400;
 If (eqt<-43200) Then eqt:=eqt+86400;
 RClear;
 ResultTitle:='Equation du temps';
 RWriteLn('Date et TE : '+FmtI(qu,2)+' '+mth[ms]+' '+FmtI(an,5)+
          '  '+FmtI(hr,2)+'h '+FmtI(mn,2)+'mn '+FmtF(sc,7,4)+'s');
 RWriteLn('');
 RWriteLn('Equation du temps          : '+FmtF(eqt,10,4)+' secondes.');
 RWriteLn('TS-TE (a Greenwich)        : '+FmtF(ts/3600,12,8)+' heures.');
 RWriteLn('Ascension droite du Soleil : '+FmtF(ad0,12,8)+' heures.');
 RWriteLn('Declinaison du Soleil      : '+FmtF(dc0,12,8)+' degres.');
 RFlush;
 ResultsShow;
End;

{ -------------------------------------------------------------------------- }
{ DoRefraction : Refraction atmospherique - Bennett 1982                    }
{ -------------------------------------------------------------------------- }
Procedure DoRefraction;
Var
 hauteur,Pmb,Tc,R,Rcorr:Extended;
 dg,mm:LongInt; ss:Extended;
Begin
 dg:=10; mm:=0; ss:=0.0;
 If Not InputAngleDMS('Refraction atmospherique','Hauteur apparente',
                      dg,mm,ss,True) Then Exit;
 hauteur:=Abs(dg)+mm/60.0+ss/3600.0;
 If dg<0 Then hauteur:=-hauteur;
 Pmb:=1010.0;
 Tc:=10.0;
 If Not InputReal('Refraction','Pression atmospherique (mbar):',Pmb) Then Exit;
 If Not InputReal('Refraction','Temperature (degC):',Tc) Then Exit;
 RClear;
 ResultTitle:='Refraction atmospherique';
 { Formule de Bennett (Astron. Almanac) :
   R = cot(h + 7.31/(h+4.4))  en minutes d'arc pour h en degres,
   correction P/T : * P/1010 * 283/(273+T) }
 R:=1.0/Sin(PI_VAL/180.0*(hauteur+7.31/(hauteur+4.4)));
 Rcorr:=R*(Pmb/1010.0)*(283.0/(273.0+Tc));
 RWriteLn('Hauteur apparente   : '+FmtF(hauteur,10,4)+' deg');
 RWriteLn('Pression            : '+FmtF(Pmb,8,2)+' mbar');
 RWriteLn('Temperature         : '+FmtF(Tc,8,2)+' degC');
 RWriteLn('');
 RWriteLn('Refraction (std)    : '+FmtF(R,10,4)+' min d''arc');
 RWriteLn('Refraction (P,T)    : '+FmtF(Rcorr,10,4)+' min d''arc');
 RWriteLn('                    = '+FmtF(Rcorr/60.0,10,5)+' deg');
 RWriteLn('Hauteur vraie       : '+FmtF(hauteur-Rcorr/60.0,10,4)+' deg');
 ResultsShow;
End;

{ -------------------------------------------------------------------------- }
{ DoEquEcl : Coordonnees equatoriales -> ecliptiques                        }
{ -------------------------------------------------------------------------- }
Procedure DoEquEcl;
{ Equatoriales -> Ecliptiques. Source verbatim : BIBLIU.PAS. }
Var
 x,y,z,u,v,ad,dc,lg,bt,ads,dcs,lgs,bts:Extended;
 adh,adm,dcd,dcm,lgd,lgm,btd,btm:LongInt;
 quL,msL,anL,hrL,mnL:LongInt; scL:Extended;
 hmq,hmc:Char;
 vrai:Boolean;
Begin
 quL:=15; msL:=6; anL:=2024; hrL:=12; mnL:=0; scL:=0.0;
 If Not InputDateTime('Eq->Ecl - Date et TE',quL,msL,anL,hrL,mnL,scL) Then Exit;
 If Not DateOK(quL,msL,anL) Then Begin ShowMessage('Erreur','Date invalide.'); Exit; End;
 If Not HeureOK(hrL,mnL,scL) Then Begin ShowMessage('Erreur','Heure invalide.'); Exit; End;
 qu:=quL; ms:=msL; an:=anL; hr:=hrL; mn:=mnL; sc:=scL;
 jd:=jj(qu,ms,an,hr,mn,sc);
 dt:=(jd-2451545.0)/365250.0;
 eps:=(((1813*dt-59)*dt-468150)*dt+84381448)/1000;
 vrai:=YesNo('Eq->Ecl','Coordonnees equatoriales vraies (sinon moyennes) ?');
 t:=dt;
 If vrai Then Begin CalcNut; eps:=eps+deps; End;
 eps:=PI_VAL*eps/648000;
 adh:=18; adm:=36; ads:=56.33; hmq:='N'; dcd:=38; dcm:=47; dcs:=1.3;
 If Not InputAngleDMS('Eq->Ecl','Ascension droite (h m s)',
                      adh,adm,ads,False) Then Exit;
 If Not InputAngleDMS('Eq->Ecl','Declinaison (d m s, signe N+/S-)',
                      dcd,dcm,dcs,True) Then Exit;
 If dcd<0 Then Begin hmq:='S'; dcd:=-dcd; End;
 If Not HeureOK(adh,adm,ads) Then Begin ShowMessage('Erreur','Alpha invalide.'); Exit; End;
 If Not DecliOK(dcd,dcm,dcs) Then Begin ShowMessage('Erreur','Delta invalide.'); Exit; End;
 ad:=PI_VAL*((60*adh+adm)*60+ads)/43200;
 dc:=PI_VAL*((60*dcd+dcm)*60+dcs)/648000;
 If (hmq='S') Then dc:=-dc;
 x:=Cos(ad)*Cos(dc);
 u:=Sin(ad)*Cos(dc);
 v:=Sin(dc);
 y:=u*Cos(eps)+v*Sin(eps);
 z:=v*Cos(eps)-u*Sin(eps);
 If (x<>0) Then lg:=ArcTan(y/x)*180/PI_VAL Else lg:=90*y/Abs(y);
 If (x<0) Then lg:=lg+180;
 If (lg<0) Then lg:=lg+360;
 bt:=ArcTan(z/Sqrt(x*x+y*y))*180/PI_VAL;
 If vrai Then Begin
  lg:=lg-dpsi/3600;
  If (lg<0) Then lg:=lg+360;
  If (lg>=360) Then lg:=lg-360;
 End;
 lgd:=Trunc(lg);
 lgm:=Trunc(60*Frac(lg));
 lgs:=3600*lg; lgs:=lgs-60*Int(lgs/60);
 If (bt<0) Then hmc:='S' Else hmc:='N';
 bt:=Abs(bt);
 btd:=Trunc(bt);
 btm:=Trunc(60*Frac(bt));
 bts:=3600*bt; bts:=bts-60*Int(bts/60);
 RClear;
 ResultTitle:='Equatoriales -> Ecliptiques';
 RWriteLn('Position equatoriale :');
 RWriteLn('  Ascension droite : '+FmtI(adh,3)+FmtI(adm,3)+FmtF(ads,7,2));
 RWriteLn('  Declinaison      : '+FmtI(dcd,3)+FmtI(dcm,3)+FmtF(dcs,7,2)+'  '+hmq);
 RWriteLn('');
 If vrai Then RWriteLn('Position ecliptique vraie de la date :')
         Else RWriteLn('Position ecliptique moyenne de la date :');
 RWriteLn('  Longitude : '+FmtI(lgd,3)+FmtI(lgm,3)+FmtF(lgs,7,2));
 RWriteLn('  Latitude  : '+FmtI(btd,3)+FmtI(btm,3)+FmtF(bts,7,2)+'  '+hmc);
 RFlush;
 ResultsShow;
End;

{ -------------------------------------------------------------------------- }
{ DoEclEqu : Coordonnees ecliptiques -> equatoriales                        }
{ -------------------------------------------------------------------------- }
Procedure DoEclEqu;
{ Ecliptiques -> Equatoriales. Source verbatim : BIBLIU.PAS. }
Var
 x,y,z,u,v,ad,dc,lg,bt,ads,dcs,lgs,bts:Extended;
 adh,adm,dcd,dcm,lgd,lgm,btd,btm:LongInt;
 quL,msL,anL,hrL,mnL:LongInt; scL:Extended;
 hmq,hmc:Char;
 vrai:Boolean;
Begin
 quL:=15; msL:=6; anL:=2024; hrL:=12; mnL:=0; scL:=0.0;
 If Not InputDateTime('Ecl->Eq - Date et TE',quL,msL,anL,hrL,mnL,scL) Then Exit;
 If Not DateOK(quL,msL,anL) Then Begin ShowMessage('Erreur','Date invalide.'); Exit; End;
 If Not HeureOK(hrL,mnL,scL) Then Begin ShowMessage('Erreur','Heure invalide.'); Exit; End;
 qu:=quL; ms:=msL; an:=anL; hr:=hrL; mn:=mnL; sc:=scL;
 jd:=jj(qu,ms,an,hr,mn,sc);
 dt:=(jd-2451545.0)/365250.0;
 eps:=(((1813*dt-59)*dt-468150)*dt+84381448)/1000;
 vrai:=YesNo('Ecl->Eq','Coordonnees equatoriales vraies (sinon moyennes) ?');
 t:=dt;
 If vrai Then Begin CalcNut; eps:=eps+deps; End;
 eps:=PI_VAL*eps/648000;
 lgd:=200; lgm:=0; lgs:=0.0; btd:=0; btm:=0; bts:=0.0; hmc:='N';
 If Not InputAngleDMS('Ecl->Eq','Longitude ecliptique (d m s)',
                      lgd,lgm,lgs,False) Then Exit;
 If Not InputAngleDMS('Ecl->Eq','Latitude ecliptique (d m s, signe N+/S-)',
                      btd,btm,bts,True) Then Exit;
 If btd<0 Then Begin hmc:='S'; btd:=-btd; End;
 If Not LngnsOK(lgd,lgm,lgs) Then Begin ShowMessage('Erreur','Longitude invalide.'); Exit; End;
 If Not DecliOK(btd,btm,bts) Then Begin ShowMessage('Erreur','Latitude invalide.'); Exit; End;
 lg:=(60*lgd+lgm)*60+lgs;
 If vrai Then lg:=lg+dpsi;
 lg:=PI_VAL*lg/648000;
 bt:=PI_VAL*((60*btd+btm)*60+bts)/648000;
 If (hmc='S') Then bt:=-bt;
 x:=Cos(lg)*Cos(bt);
 u:=Sin(lg)*Cos(bt);
 v:=Sin(bt);
 y:=u*Cos(eps)-v*Sin(eps);
 z:=v*Cos(eps)+u*Sin(eps);
 If (x<>0) Then ad:=ArcTan(y/x)*12/PI_VAL Else ad:=6*y/Abs(y);
 If (x<0) Then ad:=ad+12;
 If (ad<0) Then ad:=ad+24;
 dc:=ArcTan(z/Sqrt(x*x+y*y))*180/PI_VAL;
 adh:=Trunc(ad);
 adm:=Trunc(60*Frac(ad));
 ads:=3600*ad; ads:=ads-60*Int(ads/60);
 If (dc<0) Then hmq:='S' Else hmq:='N';
 dc:=Abs(dc);
 dcd:=Trunc(dc);
 dcm:=Trunc(60*Frac(dc));
 dcs:=3600*dc; dcs:=dcs-60*Int(dcs/60);
 RClear;
 ResultTitle:='Ecliptiques -> Equatoriales';
 RWriteLn('Position ecliptique :');
 RWriteLn('  Longitude : '+FmtI(lgd,3)+FmtI(lgm,3)+FmtF(lgs,7,2));
 RWriteLn('  Latitude  : '+FmtI(btd,3)+FmtI(btm,3)+FmtF(bts,7,2)+'  '+hmc);
 RWriteLn('');
 If vrai Then RWriteLn('Position equatoriale vraie de la date :')
         Else RWriteLn('Position equatoriale moyenne de la date :');
 RWriteLn('  Ascension droite : '+FmtI(adh,3)+FmtI(adm,3)+FmtF(ads,7,2));
 RWriteLn('  Declinaison      : '+FmtI(dcd,3)+FmtI(dcm,3)+FmtF(dcs,7,2)+'  '+hmq);
 RFlush;
 ResultsShow;
End;

{ -------------------------------------------------------------------------- }
{ DoEquGal / DoGalEqu : equatorial <-> galactique (B1950 - convention IAU)   }
{ Pole nord galactique : alpha=12h49m, delta=+27.4 deg ; theta=33 deg.       }
{ -------------------------------------------------------------------------- }
Procedure DoEquGal;
{ Equatoriales (moyennes de la date) -> Galactiques. Source verbatim : BIBLIU.PAS.
  Precession entre la date et J2000 par matrice IAU 1976 (theta, dzeta, za). }
Var
 ad,dc,lg,bt,ads,dcs,lgs,bts,adg,dcg,tht,theta,dzeta,za:Extended;
 mf,mt:Array[1..3,1..3] Of Extended;
 pse,psg:Array[1..3] Of Extended;
 adh,adm,dcd,dcm,lgd,lgm,btd,btm,i,j,k:LongInt;
 quL,msL,anL,hrL,mnL:LongInt; scL:Extended;
 hmq,hmc:Char;
Begin
 adg:=PI_VAL*30857517.0/28800000.0;
 dcg:=PI_VAL*12207713.0/81000000.0;
 tht:=PI_VAL*442554907.0/648000000.0;
 mf[1,1]:=-Cos(tht)*Cos(adg)*Sin(dcg)-Sin(tht)*Sin(adg);
 mf[1,2]:=Sin(tht)*Cos(adg)-Cos(tht)*Sin(adg)*Sin(dcg);
 mf[1,3]:=Cos(tht)*Cos(dcg);
 mf[2,1]:=Cos(tht)*Sin(adg)-Sin(tht)*Cos(adg)*Sin(dcg);
 mf[2,2]:=-Cos(tht)*Cos(adg)-Sin(tht)*Sin(adg)*Sin(dcg);
 mf[2,3]:=Sin(tht)*Cos(dcg);
 mf[3,1]:=Cos(adg)*Cos(dcg);
 mf[3,2]:=Sin(adg)*Cos(dcg);
 mf[3,3]:=Sin(dcg);
 quL:=15; msL:=6; anL:=2024; hrL:=12; mnL:=0; scL:=0.0;
 If Not InputDateTime('Eq->Gal - Date et TE',quL,msL,anL,hrL,mnL,scL) Then Exit;
 If Not DateOK(quL,msL,anL) Then Begin ShowMessage('Erreur','Date invalide.'); Exit; End;
 If Not HeureOK(hrL,mnL,scL) Then Begin ShowMessage('Erreur','Heure invalide.'); Exit; End;
 qu:=quL; ms:=msL; an:=anL; hr:=hrL; mn:=mnL; sc:=scL;
 jd:=jj(qu,ms,an,hr,mn,sc);
 dt:=(2451545.0-jd)/365250.0;
 theta:=PI_VAL*dt*(20043109-dt*(42665+41833*dt))/648000000.0;
 dzeta:=PI_VAL*dt*(23062181+dt*(30188+17998*dt))/648000000.0;
 za:=PI_VAL*dt*(23062181+dt*(109468+18203*dt))/648000000.0;
 mt[1,1]:=Cos(za)*Cos(theta)*Cos(dzeta)-Sin(za)*Sin(dzeta);
 mt[1,2]:=-(Cos(za)*Cos(theta)*Sin(dzeta)+Sin(za)*Cos(dzeta));
 mt[1,3]:=-Cos(za)*Sin(theta);
 mt[2,1]:=Sin(za)*Cos(theta)*Cos(dzeta)+Cos(za)*Sin(dzeta);
 mt[2,2]:=Cos(za)*Cos(dzeta)-Sin(za)*Cos(theta)*Sin(dzeta);
 mt[2,3]:=-Sin(za)*Sin(theta);
 mt[3,1]:=Sin(theta)*Cos(dzeta);
 mt[3,2]:=-Sin(theta)*Sin(dzeta);
 mt[3,3]:=Cos(theta);
 adh:=17; adm:=45; ads:=40.04; hmq:='S'; dcd:=29; dcm:=0; dcs:=28.1;
 If Not InputAngleDMS('Eq->Gal','Ascension droite moyenne (h m s)',
                      adh,adm,ads,False) Then Exit;
 If Not InputAngleDMS('Eq->Gal','Declinaison moyenne (d m s, signe N+/S-)',
                      dcd,dcm,dcs,True) Then Exit;
 If dcd<0 Then Begin hmq:='S'; dcd:=-dcd; End;
 ad:=PI_VAL*((60*adh+adm)*60+ads)/43200;
 dc:=PI_VAL*((60*dcd+dcm)*60+dcs)/648000;
 If (hmq='S') Then dc:=-dc;
 pse[1]:=Cos(ad)*Cos(dc);
 pse[2]:=Sin(ad)*Cos(dc);
 pse[3]:=Sin(dc);
 For i:=1 To 3 Do Begin
  psg[i]:=0;
  For j:=1 To 3 Do For k:=1 To 3 Do psg[i]:=psg[i]+mf[i,j]*mt[j,k]*pse[k];
 End;
 If (psg[1]<>0) Then lg:=ArcTan(psg[2]/psg[1])*180/PI_VAL Else lg:=90*psg[2]/Abs(psg[2]);
 If (psg[1]<0) Then lg:=lg+180;
 If (lg<0) Then lg:=lg+360;
 If (lg>=360) Then lg:=lg-360;
 bt:=ArcTan(psg[3]/Sqrt(psg[1]*psg[1]+psg[2]*psg[2]))*180/PI_VAL;
 lgd:=Trunc(lg);
 lgm:=Trunc(60*Frac(lg));
 lgs:=3600*lg; lgs:=lgs-60*Int(lgs/60);
 If (bt<0) Then hmc:='S' Else hmc:='N';
 bt:=Abs(bt);
 btd:=Trunc(bt);
 btm:=Trunc(60*Frac(bt));
 bts:=3600*bt; bts:=bts-60*Int(bts/60);
 RClear;
 ResultTitle:='Equatoriales -> Galactiques';
 RWriteLn('Position equatoriale :');
 RWriteLn('  Ascension droite : '+FmtI(adh,3)+FmtI(adm,3)+FmtF(ads,7,2));
 RWriteLn('  Declinaison      : '+FmtI(dcd,3)+FmtI(dcm,3)+FmtF(dcs,7,2)+'  '+hmq);
 RWriteLn('');
 RWriteLn('Position galactique :');
 RWriteLn('  Longitude : '+FmtI(lgd,3)+FmtI(lgm,3)+FmtF(lgs,7,2));
 RWriteLn('  Latitude  : '+FmtI(btd,3)+FmtI(btm,3)+FmtF(bts,7,2)+'  '+hmc);
 RFlush;
 ResultsShow;
End;

Procedure DoGalEqu;
{ Galactiques -> Equatoriales (moyennes de la date). Source verbatim : BIBLIU.PAS. }
Var
 ad,dc,lg,bt,ads,dcs,lgs,bts,adg,dcg,tht,theta,dzeta,za:Extended;
 mf,mt:Array[1..3,1..3] Of Extended;
 pse,psg:Array[1..3] Of Extended;
 adh,adm,dcd,dcm,lgd,lgm,btd,btm,i,j,k:LongInt;
 quL,msL,anL,hrL,mnL:LongInt; scL:Extended;
 hmq,hmc:Char;
Begin
 adg:=PI_VAL*30857517.0/28800000.0;
 dcg:=PI_VAL*12207713.0/81000000.0;
 tht:=PI_VAL*442554907.0/648000000.0;
 mf[1,1]:=-Cos(tht)*Cos(adg)*Sin(dcg)-Sin(tht)*Sin(adg);
 mf[2,1]:=Sin(tht)*Cos(adg)-Cos(tht)*Sin(adg)*Sin(dcg);
 mf[3,1]:=Cos(tht)*Cos(dcg);
 mf[1,2]:=Cos(tht)*Sin(adg)-Sin(tht)*Cos(adg)*Sin(dcg);
 mf[2,2]:=-Cos(tht)*Cos(adg)-Sin(tht)*Sin(adg)*Sin(dcg);
 mf[3,2]:=Sin(tht)*Cos(dcg);
 mf[1,3]:=Cos(adg)*Cos(dcg);
 mf[2,3]:=Sin(adg)*Cos(dcg);
 mf[3,3]:=Sin(dcg);
 quL:=15; msL:=6; anL:=2024; hrL:=12; mnL:=0; scL:=0.0;
 If Not InputDateTime('Gal->Eq - Date et TE',quL,msL,anL,hrL,mnL,scL) Then Exit;
 If Not DateOK(quL,msL,anL) Then Begin ShowMessage('Erreur','Date invalide.'); Exit; End;
 If Not HeureOK(hrL,mnL,scL) Then Begin ShowMessage('Erreur','Heure invalide.'); Exit; End;
 qu:=quL; ms:=msL; an:=anL; hr:=hrL; mn:=mnL; sc:=scL;
 jd:=jj(qu,ms,an,hr,mn,sc);
 dt:=(jd-2451545.0)/365250.0;
 theta:=PI_VAL*dt*(20043109-dt*(42665+41833*dt))/648000000.0;
 dzeta:=PI_VAL*dt*(23062181+dt*(30188+17998*dt))/648000000.0;
 za:=PI_VAL*dt*(23062181+dt*(109468+18203*dt))/648000000.0;
 mt[1,1]:=Cos(za)*Cos(theta)*Cos(dzeta)-Sin(za)*Sin(dzeta);
 mt[2,1]:=-(Cos(za)*Cos(theta)*Sin(dzeta)+Sin(za)*Cos(dzeta));
 mt[3,1]:=-Cos(za)*Sin(theta);
 mt[1,2]:=Sin(za)*Cos(theta)*Cos(dzeta)+Cos(za)*Sin(dzeta);
 mt[2,2]:=Cos(za)*Cos(dzeta)-Sin(za)*Cos(theta)*Sin(dzeta);
 mt[3,2]:=-Sin(za)*Sin(theta);
 mt[1,3]:=Sin(theta)*Cos(dzeta);
 mt[2,3]:=-Sin(theta)*Sin(dzeta);
 mt[3,3]:=Cos(theta);
 lgd:=0; lgm:=0; lgs:=0.0; btd:=0; btm:=0; bts:=0.0; hmc:='N';
 If Not InputAngleDMS('Gal->Eq','Longitude galactique (d m s)',
                      lgd,lgm,lgs,False) Then Exit;
 If Not InputAngleDMS('Gal->Eq','Latitude galactique (d m s, signe N+/S-)',
                      btd,btm,bts,True) Then Exit;
 If btd<0 Then Begin hmc:='S'; btd:=-btd; End;
 lg:=PI_VAL*((60*lgd+lgm)*60+lgs)/648000;
 bt:=PI_VAL*((60*btd+btm)*60+bts)/648000;
 If (hmc='S') Then bt:=-bt;
 psg[1]:=Cos(lg)*Cos(bt);
 psg[2]:=Sin(lg)*Cos(bt);
 psg[3]:=Sin(bt);
 For i:=1 To 3 Do Begin
  pse[i]:=0;
  For j:=1 To 3 Do For k:=1 To 3 Do pse[i]:=pse[i]+mt[i,j]*mf[j,k]*psg[k];
 End;
 If (pse[1]<>0) Then ad:=ArcTan(pse[2]/pse[1])*12/PI_VAL Else ad:=6*pse[2]/Abs(pse[2]);
 If (pse[1]<0) Then ad:=ad+12;
 If (ad<0) Then ad:=ad+24;
 If (ad>=24) Then ad:=ad-24;
 dc:=ArcTan(pse[3]/Sqrt(pse[1]*pse[1]+pse[2]*pse[2]))*180/PI_VAL;
 adh:=Trunc(ad);
 adm:=Trunc(60*Frac(ad));
 ads:=3600*ad; ads:=ads-60*Int(ads/60);
 If (dc<0) Then hmq:='S' Else hmq:='N';
 dc:=Abs(dc);
 dcd:=Trunc(dc);
 dcm:=Trunc(60*Frac(dc));
 dcs:=3600*dc; dcs:=dcs-60*Int(dcs/60);
 RClear;
 ResultTitle:='Galactiques -> Equatoriales';
 RWriteLn('Position galactique :');
 RWriteLn('  Longitude : '+FmtI(lgd,3)+FmtI(lgm,3)+FmtF(lgs,7,2));
 RWriteLn('  Latitude  : '+FmtI(btd,3)+FmtI(btm,3)+FmtF(bts,7,2)+'  '+hmc);
 RWriteLn('');
 RWriteLn('Position equatoriale moyenne de la date :');
 RWriteLn('  Ascension droite : '+FmtI(adh,3)+FmtI(adm,3)+FmtF(ads,7,2));
 RWriteLn('  Declinaison      : '+FmtI(dcd,3)+FmtI(dcm,3)+FmtF(dcs,7,2)+'  '+hmq);
 RFlush;
 ResultsShow;
End;

{ -------------------------------------------------------------------------- }
{ DoHorEqu : Horizontales (azimut/hauteur) -> Equatoriales (H,delta)        }
{ -------------------------------------------------------------------------- }
Procedure DoHorEqu;
{ Coordonnees horizontales -> equatoriales : azimut, hauteur, latitude,
  altitude, date+TE -> Ascension droite, Declinaison.
  Source verbatim : BIBLIO.PAS, procedure HorEqu. }
Var
 ts,lg,lt,ah,ad,dc,x,y,z,az,ht,rcp,rsp,alt,dcv:Extended;
 ads,dcs:Extended;
 lgdg,lgmn,ltdg,ltmn,adh,adm,dcd,dcm:LongInt;
 lgsc,ltsc:Extended;
 quL,msL,anL,hrL,mnL:LongInt; scL:Extended;
 azD,hD:Extended;
 estE,sudS:Boolean;
 xx:Extended;
Begin
 lgdg:=0; lgmn:=0; lgsc:=0.0;
 If Not InputAngleDMS('Coord. horizontales -> equatoriales',
                      'Longitude geographique (signe : O>0, E<0)',
                      lgdg,lgmn,lgsc,True) Then Exit;
 estE:=(lgdg<0) Or (lgmn<0) Or (lgsc<0);
 lgdg:=Abs(lgdg); lgmn:=Abs(lgmn); lgsc:=Abs(lgsc);
 lg:=PI_VAL*((lgdg*60+lgmn)*60+lgsc)/648000;
 If estE Then lg:=-lg;
 ltdg:=46; ltmn:=0; ltsc:=0.0;
 If Not InputAngleDMS('Coord. horizontales -> equatoriales',
                      'Latitude geographique (signe : N>0, S<0)',
                      ltdg,ltmn,ltsc,True) Then Exit;
 sudS:=(ltdg<0) Or (ltmn<0) Or (ltsc<0);
 ltdg:=Abs(ltdg); ltmn:=Abs(ltmn); ltsc:=Abs(ltsc);
 lt:=PI_VAL*((ltdg*60+ltmn)*60+ltsc)/648000;
 If sudS Then lt:=-lt;
 alt:=0.0;
 If Not InputReal('Coord. horizontales -> equatoriales',
                  'Altitude (en metres)',alt) Then Exit;
 quL:=1; msL:=1; anL:=2000; hrL:=0; mnL:=0; scL:=0.0;
 If Not InputDateTime('Coord. horizontales -> equatoriales - Date et TE',
                      quL,msL,anL,hrL,mnL,scL) Then Exit;
 If Not DateOK(quL,msL,anL) Then Begin ShowMessage('Erreur','Date invalide.'); Exit; End;
 If Not HeureOK(hrL,mnL,scL) Then Begin ShowMessage('Erreur','Heure invalide.'); Exit; End;
 azD:=0.0;
 If Not InputReal('Coord. horizontales -> equatoriales',
                  'Azimut en degres decimaux (compte a partir du Nord)',azD) Then Exit;
 If (azD<0) Or (azD>=360) Then Begin
  ShowMessage('Erreur','Azimut hors plage 0..360 deg.'); Exit;
 End;
 hD:=45.0;
 If Not InputReal('Coord. horizontales -> equatoriales',
                  'Hauteur au dessus de l''horizon (degres decimaux)',hD) Then Exit;
 If (hD<0) Or (hD>90) Then Begin
  ShowMessage('Erreur','Hauteur hors plage 0..90 deg.'); Exit;
 End;
 qu:=quL; ms:=msL; an:=anL; hr:=hrL; mn:=mnL; sc:=scL;
 { Coordonnees geocentriques observateur (verbatim BIBLIO) }
 x:=REQT/Sqrt(Cos(lt)*Cos(lt)+0.99330562*Sin(lt)*Sin(lt));
 rcp:=(x+(alt/1000))*Cos(lt);
 rsp:=(0.99330562*x+(alt/1000))*Sin(lt);
 { Temps sideral local }
 jd:=jj(qu,ms,an,hr,mn,sc);
 t:=(jd-2451545.0)/365250.0;
 Calcnut;
 eps:=(((1813*t-59)*t-468150)*t+84381448)/1000;
 eps:=PI_VAL*eps/648000;
 ts:=24110.54841+t*(86401848.12866+t*(9.3104-0.0062*t))+(hr*60+mn)*60+sc;
 ts:=ts+((dpsi*Cos(eps))/15);
 ts:=ts-(lg*43200/PI_VAL);
 ts:=(ts-86400.0*Int(ts/86400.0))/3600;
 If (ts<0.0) Then ts:=ts+24.0;
 hrL:=Trunc(ts);
 mnL:=Trunc(60*ts) Mod 60;
 scL:=3600*ts-60*Int(60*ts);
 { Transformation horizontales -> equatoriales (verbatim BIBLIO) }
 az:=PI_VAL*azD/180;
 ht:=PI_VAL*hD/180;
 x:=Cos(lt)*Sin(ht)-Sin(lt)*Cos(ht)*Cos(az);
 y:=-Cos(ht)*Sin(az);
 z:=Sin(lt)*Sin(ht)+Cos(lt)*Cos(ht)*Cos(az);
 If (x<>0) Then ah:=ArcTan(y/x)*12/PI_VAL Else
  If (y<>0) Then ah:=6*y/Abs(y) Else ah:=0;
 If (x<0) Then ah:=ah+12;
 If (ah<0) Then ah:=ah+24;
 ad:=ts-ah;
 If (ad<0) Then ad:=ad+24;
 xx:=Sqrt(x*x+y*y);
 If (xx<>0) Then dcv:=ArcTan(z/xx)*180/PI_VAL Else
  If (z<>0) Then dcv:=90*z/Abs(z) Else dcv:=0;
 dc:=dcv;
 adh:=Trunc(ad);
 adm:=Trunc(60*Frac(ad));
 ads:=60*Frac(60*ad);
 dcd:=Trunc(Abs(dc));
 dcm:=Trunc(60*Frac(Abs(dc)));
 dcs:=60*Frac(60*Abs(dc));
 RClear;
 ResultTitle:='Coord. horizontales -> equatoriales';
 RWriteLn('Longitude  : '+FmtF(lg*180/PI_VAL,12,6)+' deg (signe Ouest+)');
 RWriteLn('Latitude   : '+FmtF(lt*180/PI_VAL,12,6)+' deg');
 RWriteLn('Altitude   : '+FmtF(alt,10,2)+' m');
 RWriteLn('');
 RWriteLn('Date/TE    : '+FmtI(quL,3)+' '+mth[msL]+' '+FmtI(anL,5)+
          '  '+FmtI(hr,2)+'h '+FmtI(mn,2)+'m '+FmtF(sc,6,2)+'s');
 RWriteLn('Temps sideral local : '+FmtI(hrL,3)+'h '+FmtI(mnL,2)+'m '+FmtF(scL,6,2)+'s');
 RWriteLn('');
 RWriteLn('Azimut  (N) : '+FmtF(azD,12,6)+' deg');
 RWriteLn('Hauteur     : '+FmtF(hD,12,6)+' deg');
 RWriteLn('');
 RWriteLn('Angle horaire    : '+FmtI(Trunc(ah),3)+'h '+
          FmtI(Trunc(60*Frac(ah)),2)+'m '+FmtF(60*Frac(60*ah),6,2)+'s');
 RWriteLn('Ascension droite : '+FmtI(adh,3)+'h '+FmtI(adm,2)+'m '+FmtF(ads,6,2)+'s');
 If dc<0 Then
  RWriteLn('Declinaison      : -'+FmtI(dcd,2)+'d '+FmtI(dcm,2)+'m '+FmtF(dcs,6,2)+'s')
 Else
  RWriteLn('Declinaison      :  '+FmtI(dcd,2)+'d '+FmtI(dcm,2)+'m '+FmtF(dcs,6,2)+'s');
 RFlush;
 ResultsShow;
End;

