{ Source verbatim : BIBLI0.PAS (auteur original astrophysicien). }

Function DateOK(qu,ms,an:LongInt):Boolean;
Var
 flg:Boolean;
 x,y:LongInt;
Begin
 x:=2;
 If ((an<1583) And ((an Mod 4)=0)) Then x:=1;
 If (an>1582) Then Begin
  y:=an Mod 4;
  If (y=0) Then Begin
   y:=an Mod 100;
   If (y<>0) Then x:=1
   Else Begin
    y:=(an Div 100) Mod 4;
    If (y=0) Then x:=1;
   End;
  End;
 End;
 flg:=(ms>0) And (ms<13);
 If (flg) Then
  Case ms Of
   1,3,5,7,8,10,12 : flg:=(qu>0) And (qu<32);
   2               : flg:=(qu>0) And (qu<31-x);
   4,6,9,11        : flg:=(qu>0) And (qu<31);
  End;
 If (flg And (an=1582) And (ms=10)) Then flg:=((qu<5) Or (qu>14));
 DateOK:=flg;
End;

Function HeureOK(hh,nn:LongInt; sec:Extended):Boolean;
Var flg:Boolean;
Begin
 flg:=(hh>=0) And (hh<24);
 If (flg) Then flg:=(nn>=0) And (nn<60);
 If (flg) Then flg:=(sec>=0.0) And (sec<60.0);
 HeureOK:=flg;
End;

Function DecliOK(dg,mn0:LongInt; sec:Extended):Boolean;
Var flg,pl:Boolean;
Begin
 flg:=(dg>=0) And (dg<90);
 If (flg) Then flg:=(mn0>=0) And (mn0<60);
 If (flg) Then flg:=(sec>=0.0) And (sec<60.0);
 pl:=(dg=90) And (mn0=0) And (sec=0.0);
 DecliOK:=flg Or pl;
End;

Function LngsgOK(dg,mn0:LongInt; sec:Extended):Boolean;
Var flg,pl:Boolean;
Begin
 flg:=(dg>=0) And (dg<180);
 If (flg) Then flg:=(mn0>=0) And (mn0<60);
 If (flg) Then flg:=(sec>=0.0) And (sec<60.0);
 pl:=(dg=180) And (mn0=0) And (sec=0.0);
 LngsgOK:=flg Or pl;
End;

Function LngnsOK(dg,mn0:LongInt; sec:Extended):Boolean;
Var flg:Boolean;
Begin
 flg:=(dg>=0) And (dg<360);
 If (flg) Then flg:=(mn0>=0) And (mn0<60);
 If (flg) Then flg:=(sec>=0.0) And (sec<60.0);
 LngnsOK:=flg;
End;

Function jj(qu,ms,an,hr,mn:LongInt; sc:Extended):Extended;
{ Source : BIBLI0.PAS - utilise globale wrk comme variable de travail. }
Var
 x,y:Extended;
Begin
 wrk:=((an*100+ms)*100+qu)/10000;
 x:=an;
 y:=ms+1;
 If (ms<3) Then Begin
  x:=x-1;
  y:=y+12;
 End;
 If (wrk<1582.1015) Then wrk:=0 Else wrk:=2-Int(x/100)+Int(x/400);
 wrk:=wrk+qu+Int(30.6001*y);
 If (x<0) Then wrk:=wrk+Int(365.25*x-0.75) Else wrk:=wrk+Int(365.25*x);
 jj:=1720994.5+wrk+((hr*60+mn)*60+sc)/86400.0;
End;

Procedure cal(jdv:Extended; Var qu,ms,an,hr,mn:LongInt; Var sec:Extended);
{ Source : BIBLI0.PAS. }
Var
 a,b,c,d,e,z:Extended;
Begin
 wrk:=jdv+0.5;
 z:=Int(wrk);
 wrk:=wrk-z;
 If (wrk<0) Then Begin
  z:=z-1;
  wrk:=wrk+1;
 End;
 hr:=Trunc(24*wrk);
 mn:=Trunc(1440*wrk);
 sec:=86400.0*wrk;
 sec:=sec-60*mn;
 mn:=mn Mod 60;
 a:=z;
 If (z>2299160) Then Begin
  a:=Int((4*z-7468865)/146097);
  a:=z+1+a-Int(a/4);
 End;
 b:=a+1524;
 c:=Int(40*b-4884);
 If (c<0) Then c:=c-14609;
 c:=Int(c/14610);
 d:=c*1461;
 If (d<0) Then d:=d-3;
 d:=Int(d/4);
 e:=Int((5*(b-d))/153);
 qu:=Round(b-d-Int(30.6001*e));
 ms:=Round(e-1);
 an:=Round(c-4716);
 If (ms>12) Then Begin
  an:=an+1;
  ms:=ms-12;
 End;
 If (qu=0) Then Begin
  ms:=ms-1;
  qu:=31;
 End;
End;

Function jda(qu,ms,an:LongInt):LongInt;
{ Source : BIBLI0.PAS. }
Begin
 jda:=Trunc(jj(qu,ms,an,0,0,0.0)-jj(0,1,an,0,0,0.0));
End;

