{ ========================================================================== }
{ ============== EPHEMERIDES D'ETOILES DOUBLES (verbatim BIBLIL.PAS) ======== }
{ ========================================================================== }
{ Source : BIBLIL.PAS, procedure Ephemds (Bureau des Longitudes).
  Elements orbitaux au choix : Campbell (a, i, omega, Omega) ou Thiele-Innes
  (A, B, F, G). Conversion bidirectionnelle integrale.  Position relative
  (rau, theta) calculee a la date demandee par resolution de l'equation de
  Kepler (LIM=pi/648e6 rad pour la tolerance). }

Procedure DoEphemds;
Var
 a,e,i,pa,nd,p,epq,m,u,gx,gy : Extended;
 ath,fth,bth,gth,cth,hth     : Extended;
 xv,yv,rau,theta             : Extended;
 tep                         : Extended;
 nmst                        : String;
 quL,msL,anL,hrL,mnL         : LongInt;
 scL                         : Extended;
Begin
 nmst:='Etoile double';
 If Not InputString('Etoiles doubles','Nom de l''etoile :',nmst,40) Then Exit;

 If YesNo('Etoiles doubles - Type d''elements',
          'Elements de Campbell ?  (Non = Thiele-Innes)') Then
  Begin
   { ----- Saisie Campbell ----- }
   a:=1.0;
   Repeat
    If Not InputReal('Campbell','Demi grand axe (") :',a) Then Exit;
   Until a>0.0;
   i:=0.0;
   Repeat
    If Not InputReal('Campbell','Inclinaison (0..180 deg) :',i) Then Exit;
   Until (i>=0.0) And (i<=180.0);
   pa:=0.0;
   Repeat
    If Not InputReal('Campbell','Argument du periastre (0..360 deg) :',pa) Then Exit;
   Until (pa>=0.0) And (pa<360.0);
   nd:=0.0;
   Repeat
    If Not InputReal('Campbell','Longitude noeud ascendant (0..180 deg) :',nd) Then Exit;
   Until (nd>=0.0) And (nd<180.0);
   nd:=nd*pi/180;
   pa:=pa*pi/180;
   i:=i*pi/180;
   ath:=a*(cos(pa)*cos(nd)-sin(pa)*sin(nd)*cos(i));
   fth:=a*(-sin(pa)*cos(nd)-cos(pa)*sin(nd)*cos(i));
   bth:=a*(cos(pa)*sin(nd)+sin(pa)*cos(nd)*cos(i));
   gth:=a*(cos(pa)*cos(nd)*cos(i)-sin(pa)*sin(nd));
   cth:=a*sin(pa)*sin(i);
   hth:=a*cos(pa)*sin(i);
  End
 Else
  Begin
   { ----- Saisie Thiele-Innes ----- }
   ath:=0.0; If Not InputReal('Thiele-Innes','Element A :',ath) Then Exit;
   bth:=0.0; If Not InputReal('Thiele-Innes','Element B :',bth) Then Exit;
   fth:=0.0; If Not InputReal('Thiele-Innes','Element F :',fth) Then Exit;
   gth:=0.0; If Not InputReal('Thiele-Innes','Element G :',gth) Then Exit;
   xv:=ath*ath-bth*bth+fth*fth-gth*gth;
   yv:=2*(ath*bth+fth*gth);
   If (xv<>0) Then nd:=arctan(yv/xv) Else nd:=pi*yv/abs(2*yv);
   If (xv<0) Then nd:=nd+pi;
   If (nd<0) Then nd:=nd+2*pi;
   nd:=nd/2;
   a:=sqrt(xv*xv+yv*yv)+ath*ath+bth*bth+fth*fth+gth*gth;
   a:=sqrt(a/2);
   wrk:=(ath*gth-bth*fth)/(a*a);
   If (wrk=0) Then i:=0.5*pi Else i:=arctan(sqrt(1-wrk*wrk)/wrk);
   xv:=ath+gth;
   yv:=bth-fth;
   If (xv<>0) Then pa:=arctan(yv/xv) Else pa:=pi*yv/abs(2*yv);
   If (xv<0) Then pa:=pa+pi;
   pa:=pa-nd;
   If (pa<0) Then pa:=pa+2*pi;
   cth:=a*sin(pa)*sin(i);
   hth:=a*cos(pa)*sin(i);
  End;

 e:=0.0;
 Repeat
  If Not InputReal('Etoiles doubles','Excentricite (0..1) :',e) Then Exit;
 Until (e>=0.0) And (e<1.0);
 tep:=2000.0;
 If Not InputReal('Etoiles doubles','Epoque du periastre (aaaa.aaa) :',tep) Then Exit;
 p:=0.0;
 Repeat
  If Not InputReal('Etoiles doubles','Periode de revolution (annees) :',p) Then Exit;
 Until p>0.0;

 RClear;
 ResultTitle:='Ephemeride d''etoile double ('+nmst+')';
 RWriteLn('Etoile etudiee               : '+nmst);
 RWriteLn('');
 RWriteLn('Excentricite                 : '+FmtF(e,8,4));
 RWriteLn('Epoque du periastre          : '+FmtF(tep,10,3));
 RWriteLn('Periode de revolution        : '+FmtF(p,10,3)+' an');
 RWriteLn('');
 RWriteLn('Elements de Campbell :');
 RWriteLn('  Demi grand axe             : '+FmtF(a,8,3));
 RWriteLn('  Inclinaison                : '+FmtF(180*i/pi,8,2)+' deg');
 RWriteLn('  Argument du periastre      : '+FmtF(180*pa/pi,8,2)+' deg');
 RWriteLn('  Longitude noeud ascendant  : '+FmtF(180*nd/pi,8,2)+' deg');
 RWriteLn('');
 RWriteLn('Elements de Thiele-Innes :');
 RWriteLn('  A = '+FmtF(ath,10,6)+'   F = '+FmtF(fth,10,6));
 RWriteLn('  B = '+FmtF(bth,10,6)+'   G = '+FmtF(gth,10,6));
 RWriteLn('  C = '+FmtF(cth,10,6)+'   H = '+FmtF(hth,10,6));
 RWriteLn('');
 RWriteLn('Observations :');
 RWriteLn('  Date civile               Epoque    Theta(deg)  Rho(")');

 quL:=qu; msL:=ms; anL:=an; hrL:=hr; mnL:=mn; scL:=sc;
 Repeat
  If Not InputDateTime('Etoiles doubles - Date d''observation',
                       quL,msL,anL,hrL,mnL,scL) Then
   Begin
    qu:=quL; ms:=msL; an:=anL; hr:=hrL; mn:=mnL; sc:=scL;
    ResultsShow; Exit;
   End;
  qu:=quL; ms:=msL; an:=anL; hr:=hrL; mn:=mnL; sc:=scL;
  epq:=2000.0+((jj(qu,ms,an,hr,mn,sc)-2451545.0)/365.25);
  m:=360.0*(epq-tep)/p;
  m:=pi*(m-360.0*int(m/360.0))/180;
  u:=m;
  gx:=10.0;
  While (abs(gx)>LIM) Do
   Begin
    gx:=u-m-e*sin(u);
    u:=u-gx;
   End;
  gx:=cos(u)-e;
  gy:=sin(u)*sqrt(1.0-e*e);
  xv:=ath*gx+fth*gy;
  yv:=bth*gx+gth*gy;
  rau:=sqrt(xv*xv+yv*yv);
  If (xv<>0) Then theta:=arctan(yv/xv)*180/pi Else theta:=90*yv/abs(yv);
  If (xv<0.0) Then theta:=theta+180.0;
  If (theta<0.0) Then theta:=theta+360.0;
  RWriteLn('  '+FmtI(qu,2)+'/'+FmtI(ms,2)+'/'+FmtI(an,5)+' '
           +FmtI(hrL,2)+':'+FmtI(mnL,2)+':'+FmtF(scL,4,1)
           +'  '+FmtF(epq,10,4)+'  '+FmtF(theta,8,2)+'  '+FmtF(rau,8,3));
 Until Not YesNo('Etoiles doubles','Une autre epoque ?');

 ResultsShow;
End;

{ ========================================================================== }
{ ====== EPHEMERIDES COMETAIRES (verbatim COMET.PAS + COMETBIS.PAS) ========= }
{ ========================================================================== }
{ Integration numerique (Runge-Kutta-Gill) du mouvement keplerien d'une comete
  avec perturbations gravitationnelles des 9 planetes + Lune et forces non-
  gravitationnelles optionnelles (modele d'eclat de Marsden). Algorithme
  entierement repris de COMET.PAS / COMETBIS.PAS (Bureau des Longitudes). }

Procedure Calclg1; Forward; Procedure Calcb1; Forward; Procedure Calcr1; Forward;
Procedure Calclg2; Forward; Procedure Calcb2; Forward; Procedure Calcr2; Forward;
Procedure Calclg3; Forward; Procedure Calcb3; Forward; Procedure Calcr3; Forward;
Procedure Calclg4; Forward; Procedure Calcb4; Forward; Procedure Calcr4; Forward;
Procedure Calclg5; Forward; Procedure Calcb5; Forward; Procedure Calcr5; Forward;
Procedure Calclg6; Forward; Procedure Calcb6; Forward; Procedure Calcr6; Forward;
Procedure Calclg7; Forward; Procedure Calcb7; Forward; Procedure Calcr7; Forward;
Procedure GeoSpeed; Forward;

Procedure DoComete;
Const
 GS = 66356219000.0;
Var
 { --- Elements orbitaux et etat --- }
 tpas,dper,dga,exc,xc,yc,zc,adc,dcc,ads,dcs,lgc,btc,lgsn,btsn,anorg : Extended;
 elg,mg1,mgt,mgr,rau,delta,jeq,ndr,prr,inr,xr,yr,zr                  : Extended;
 xx,xy,xz,yx,yy,yz,zx,zy,zz,xc1,yc1,zc1,xc2,yc2,zc2                   : Extended;
 xco,yco,zco,xc0,yc0,zc0,vx0,vy0,vz0                                  : Extended;
 ect,pas,tosc,otd,prm,cst,vh,vg,cx,cy,cz,px,py,pz,qx,qy,qz            : Extended;
 vx,vy,vz,dvx,dvy,dvz,das,dma,dmd,dmmd,dmth,fil,phl                   : Extended;
 ai,ds,di,elgm,eps0,eps1,eps2,pa,ppa,gpa,p1,p2                        : Extended;
 fnga1,fnga2,fnga3,xec0,yec0,zec0,xeq0,yeq0,zeq0                      : Extended;
 adsn,dcsn,ado,dco,adso,dcso,adsr,dcsr,adsc,dcsc                      : Extended;
 ad1c,dc1c,ad2c,dc2c                                                  : Extended;
 lp,eqr,adh,adm,dcd,dcm,adhr,admr,dcdr,dcmr                            : LongInt;
 adhc,admc,dcdc,dcmc,adho,admo,dcdo,dcmo                              : LongInt;
 typ,tpr,hmr,hmo,hmc,sgC                                              : Char;
 flgn,flgt,flobs,fldtl,flfng,flprt                                    : Boolean;
 x,y,z,ah,ht                                                          : Extended;
 nmobj                                                                : String;

 Procedure AngtoVec;
 Begin
  Case eqr Of
   1900 : jeq:=2415020.31351996;
   1950 : jeq:=2433282.42345905;
   2000 : jeq:=2451545.0;
  End;
  cx:=pi*ndr/180;
  cy:=pi*inr/180;
  cz:=pi*prr/180;
  px:=cos(cx)*cos(cz)-sin(cx)*sin(cz)*cos(cy);
  py:=sin(cx)*cos(cz)+cos(cx)*sin(cz)*cos(cy);
  pz:=sin(cz)*sin(cy);
  qx:=-cos(cx)*sin(cz)-sin(cx)*cos(cz)*cos(cy);
  qy:=-sin(cx)*sin(cz)+cos(cx)*cos(cz)*cos(cy);
  qz:=cos(cz)*sin(cy);
  cx:=py*qz-pz*qy;
  cy:=pz*qx-px*qz;
  cz:=px*qy-py*qx;
  { Si l'equinoxe des elements n'est pas J2000, ramener vers J2000 par
    rotation precession-nutation simplifiee (formule verbatim BIBLIE) }
  If eqr<>2000 Then
   Begin
    wrk:=(jeq-2451545.0)/365250.0;
    wrk:=pi*(84381448.0-wrk*(468150.0+wrk*(59-1813*wrk)))/648000000.0;
    cy:=py*cos(wrk)+pz*sin(wrk);
    pz:=-py*sin(wrk)+pz*cos(wrk);
    py:=cy;
    cy:=qy*cos(wrk)+qz*sin(wrk);
    qz:=-qy*sin(wrk)+qz*cos(wrk);
    qy:=cy;
    cx:=py*qz-pz*qy;
    cy:=pz*qx-px*qz;
    cz:=px*qy-py*qx;
   End;
 End;

 Procedure CalcFonc(tps:Extended; xcp,ycp,zcp,vxp,vyp,vzp:Extended;
                    Var kx,ky,kz:Extended);
 Begin
  wrk:=(xcp*xcp+ycp*ycp+zcp*zcp);
  wrk:=wrk*sqrt(wrk);
  kx:=-GS*pas*xcp/wrk;
  ky:=-GS*pas*ycp/wrk;
  kz:=-GS*pas*zcp/wrk;
  If flprt Then
   Begin
    t:=(tps-2451545)/365250.0;
    ppa:=(-470029+t*(3301-60*t))*t*pi/648000000.0;
    gpa:=(629554982+t*(41592878+114649*t))*pi/648000000.0;
    pa:=gpa-(50290966+t*(111113-6*t))*t*pi/648000000.0;
    xx:=cos(pa)*cos(gpa)+sin(pa)*cos(ppa)*sin(gpa);
    xy:=cos(pa)*sin(gpa)-sin(pa)*cos(ppa)*cos(gpa);
    xz:=-sin(pa)*sin(ppa);
    yx:=sin(pa)*cos(gpa)-cos(pa)*cos(ppa)*sin(gpa);
    yy:=sin(pa)*sin(gpa)+cos(pa)*cos(ppa)*cos(gpa);
    yz:=cos(pa)*sin(ppa);
    zx:=sin(ppa)*sin(gpa);
    zy:=-sin(ppa)*cos(gpa);
    zz:=cos(ppa);
    Calclg0; Calcb0; Calcr0;
    x0:=r0*((xx*cos(lg0)+xy*sin(lg0))*cos(b0)+xz*sin(b0));
    y0:=r0*((yx*cos(lg0)+yy*sin(lg0))*cos(b0)+yz*sin(b0));
    z0:=r0*((zx*cos(lg0)+zy*sin(lg0))*cos(b0)+zz*sin(b0));
    wrk:=xcp*xcp+ycp*ycp+zcp*zcp+r0*r0-2*(xcp*x0+ycp*y0+zcp*z0);
    wrk:=332946*wrk*sqrt(wrk);
    kx:=kx-GS*pas*(xcp-x0)/wrk;
    ky:=ky-GS*pas*(ycp-y0)/wrk;
    kz:=kz-GS*pas*(zcp-z0)/wrk;
    Calclg1; Calcb1; Calcr1;
    x1:=r1*((xx*cos(lg1)+xy*sin(lg1))*cos(b1)+xz*sin(b1));
    y1:=r1*((yx*cos(lg1)+yy*sin(lg1))*cos(b1)+yz*sin(b1));
    z1:=r1*((zx*cos(lg1)+zy*sin(lg1))*cos(b1)+zz*sin(b1));
    wrk:=xcp*xcp+ycp*ycp+zcp*zcp+r1*r1-2*(xcp*x1+ycp*y1+zcp*z1);
    wrk:=6023600*wrk*sqrt(wrk);
    kx:=kx-GS*pas*(xcp-x1)/wrk;
    ky:=ky-GS*pas*(ycp-y1)/wrk;
    kz:=kz-GS*pas*(zcp-z1)/wrk;
    Calclg2; Calcb2; Calcr2;
    x2:=r2*((xx*cos(lg2)+xy*sin(lg2))*cos(b2)+xz*sin(b2));
    y2:=r2*((yx*cos(lg2)+yy*sin(lg2))*cos(b2)+yz*sin(b2));
    z2:=r2*((zx*cos(lg2)+zy*sin(lg2))*cos(b2)+zz*sin(b2));
    wrk:=xcp*xcp+ycp*ycp+zcp*zcp+r2*r2-2*(xcp*x2+ycp*y2+zcp*z2);
    wrk:=408523.5*wrk*sqrt(wrk);
    kx:=kx-GS*pas*(xcp-x2)/wrk;
    ky:=ky-GS*pas*(ycp-y2)/wrk;
    kz:=kz-GS*pas*(zcp-z2)/wrk;
    Calclg3; Calcb3; Calcr3;
    x3:=r3*((xx*cos(lg3)+xy*sin(lg3))*cos(b3)+xz*sin(b3));
    y3:=r3*((yx*cos(lg3)+yy*sin(lg3))*cos(b3)+yz*sin(b3));
    z3:=r3*((zx*cos(lg3)+zy*sin(lg3))*cos(b3)+zz*sin(b3));
    wrk:=xcp*xcp+ycp*ycp+zcp*zcp+r3*r3-2*(xcp*x3+ycp*y3+zcp*z3);
    wrk:=3098710*wrk*sqrt(wrk);
    kx:=kx-GS*pas*(xcp-x3)/wrk;
    ky:=ky-GS*pas*(ycp-y3)/wrk;
    kz:=kz-GS*pas*(zcp-z3)/wrk;
    Calclg4; Calcb4; Calcr4;
    x4:=r4*((xx*cos(lg4)+xy*sin(lg4))*cos(b4)+xz*sin(b4));
    y4:=r4*((yx*cos(lg4)+yy*sin(lg4))*cos(b4)+yz*sin(b4));
    z4:=r4*((zx*cos(lg4)+zy*sin(lg4))*cos(b4)+zz*sin(b4));
    wrk:=xcp*xcp+ycp*ycp+zcp*zcp+r4*r4-2*(xcp*x4+ycp*y4+zcp*z4);
    wrk:=209471*wrk*sqrt(wrk)/200;
    kx:=kx-GS*pas*(xcp-x4)/wrk;
    ky:=ky-GS*pas*(ycp-y4)/wrk;
    kz:=kz-GS*pas*(zcp-z4)/wrk;
    Calclg5; Calcb5; Calcr5;
    x5:=r5*((xx*cos(lg5)+xy*sin(lg5))*cos(b5)+xz*sin(b5));
    y5:=r5*((yx*cos(lg5)+yy*sin(lg5))*cos(b5)+yz*sin(b5));
    z5:=r5*((zx*cos(lg5)+zy*sin(lg5))*cos(b5)+zz*sin(b5));
    wrk:=xcp*xcp+ycp*ycp+zcp*zcp+r5*r5-2*(xcp*x5+ycp*y5+zcp*z5);
    wrk:=3498.5*wrk*sqrt(wrk);
    kx:=kx-GS*pas*(xcp-x5)/wrk;
    ky:=ky-GS*pas*(ycp-y5)/wrk;
    kz:=kz-GS*pas*(zcp-z5)/wrk;
    Calclg6; Calcb6; Calcr6;
    x6:=r6*((xx*cos(lg6)+xy*sin(lg6))*cos(b6)+xz*sin(b6));
    y6:=r6*((yx*cos(lg6)+yy*sin(lg6))*cos(b6)+yz*sin(b6));
    z6:=r6*((zx*cos(lg6)+zy*sin(lg6))*cos(b6)+zz*sin(b6));
    wrk:=xcp*xcp+ycp*ycp+zcp*zcp+r6*r6-2*(xcp*x6+ycp*y6+zcp*z6);
    wrk:=22869*wrk*sqrt(wrk);
    kx:=kx-GS*pas*(xcp-x6)/wrk;
    ky:=ky-GS*pas*(ycp-y6)/wrk;
    kz:=kz-GS*pas*(zcp-z6)/wrk;
    Calclg7; Calcb7; Calcr7;
    x7:=r7*((xx*cos(lg7)+xy*sin(lg7))*cos(b7)+xz*sin(b7));
    y7:=r7*((yx*cos(lg7)+yy*sin(lg7))*cos(b7)+yz*sin(b7));
    z7:=r7*((zx*cos(lg7)+zy*sin(lg7))*cos(b7)+zz*sin(b7));
    wrk:=xcp*xcp+ycp*ycp+zcp*zcp+r7*r7-2*(xcp*x7+ycp*y7+zcp*z7);
    wrk:=19314*wrk*sqrt(wrk);
    kx:=kx-GS*pas*(xcp-x7)/wrk;
    ky:=ky-GS*pas*(ycp-y7)/wrk;
    kz:=kz-GS*pas*(zcp-z7)/wrk;
    jd:=tps;
    Lune;
    x9:=x0+r9*((xx*cos(lg9)+xy*sin(lg9))*cos(b9)+xz*sin(b9));
    y9:=y0+r9*((yx*cos(lg9)+yy*sin(lg9))*cos(b9)+yz*sin(b9));
    z9:=z0+r9*((zx*cos(lg9)+zy*sin(lg9))*cos(b9)+zz*sin(b9));
    wrk:=xcp*xcp+ycp*ycp+zcp*zcp+x9*x9+y9*y9+z9*z9-2*(xcp*x9+ycp*y9+zcp*z9);
    wrk:=24334690194.0*wrk*sqrt(wrk)/899;
    kx:=kx-GS*pas*(xcp-x9)/wrk;
    ky:=ky-GS*pas*(ycp-y9)/wrk;
    kz:=kz-GS*pas*(zcp-z9)/wrk;
    If flfng Then
     Begin
      x:=ycp*vzp-zcp*vyp;
      y:=zcp*vxp-xcp*vzp;
      z9:=xcp*vyp-ycp*vxp;
      u:=y*zcp-z9*ycp;
      f:=z9*xcp-x*zcp;  { f reutilise comme var locale; non global ici }
      d:=x*ycp-y*xcp;
      wrk:=sqrt(x*x+y*y+z9*z9);
      x:=x/wrk; y:=y/wrk; z9:=z9/wrk;
      wrk:=sqrt(u*u+f*f+d*d);
      u:=u/wrk; f:=f/wrk; d:=d/wrk;
      wrk:=sqrt(xcp*xcp+ycp*ycp+zcp*zcp);
      xr:=xcp/wrk; yr:=ycp/wrk; zr:=zcp/wrk;
      wrk:=ln(wrk/(2.808*UA));
      wrk:=8322279.144411021*pas*exp(-4.6142*ln(1+exp(5.093*wrk)))*exp(-2.15*wrk)/7464960000.0;
      xr:=wrk*(fnga1*xr+fnga2*u+fnga3*x);
      yr:=wrk*(fnga1*yr+fnga2*f+fnga3*y);
      zr:=wrk*(fnga1*zr+fnga2*d+fnga3*z9);
      kx:=kx+xr; ky:=ky+yr; kz:=kz+zr;
     End;
   End;
 End;

 Procedure Integration;
 Var
  nb:LongInt;
  xcp,ycp,zcp,vxp,vyp,vzp,k1x,k2x,k3x,k4x,k1y,k2y,k3y,k4y,k1z,k2z,k3z,k4z:Extended;
 Begin
  ect:=0;
  xc:=xc0; yc:=yc0; zc:=zc0;
  vx:=vx0; vy:=vy0; vz:=vz0;
  lp:=Trunc(Abs(jd-otd));
  If lp<1 Then lp:=1;
  pas:=86400*(jd-otd)/lp;
  If pas>90000 Then
   Begin lp:=lp+1; pas:=86400*(jd-otd)/lp; End;
  For nb:=1 To lp Do
   Begin
    xcp:=xc; ycp:=yc; zcp:=zc; vxp:=vx; vyp:=vy; vzp:=vz;
    CalcFonc(otd+(ect/86400),xcp,ycp,zcp,vxp,vyp,vzp,k1x,k1y,k1z);
    xcp:=xc+0.5*pas*(vx+0.5*k1x);
    ycp:=yc+0.5*pas*(vy+0.5*k1y);
    zcp:=zc+0.5*pas*(vz+0.5*k1z);
    vxp:=vx+k1x; vyp:=vy+k1y; vzp:=vz+k1z;
    CalcFonc(otd+((ect+0.5*pas)/86400),xcp,ycp,zcp,vxp,vyp,vzp,k2x,k2y,k2z);
    If flfng Then
     Begin
      xcp:=xc+0.5*pas*(vx+0.5*k1x);
      ycp:=yc+0.5*pas*(vy+0.5*k1y);
      zcp:=zc+0.5*pas*(vz+0.5*k1z);
      vxp:=vx+k2x; vyp:=vy+k2y; vzp:=vz+k2z;
      CalcFonc(otd+((ect+0.5*pas)/86400),xcp,ycp,zcp,vxp,vyp,vzp,k3x,k3y,k3z);
     End
    Else
     Begin k3x:=k2x; k3y:=k2y; k3z:=k2z; End;
    xcp:=xc+pas*(vx+k3x);
    ycp:=yc+pas*(vy+k3y);
    zcp:=zc+pas*(vz+k3z);
    vxp:=vx+2*k3x; vyp:=vy+2*k3y; vzp:=vz+2*k3z;
    CalcFonc(otd+((ect+pas)/86400),xcp,ycp,zcp,vxp,vyp,vzp,k4x,k4y,k4z);
    xc:=xc+(pas*vx)+(pas*(k1x+k2x+k3x)/3);
    yc:=yc+(pas*vy)+(pas*(k1y+k2y+k3y)/3);
    zc:=zc+(pas*vz)+(pas*(k1z+k2z+k3z)/3);
    vx:=vx+(2*(k2x+k3x)+k1x+k4x)/3;
    vy:=vy+(2*(k2y+k3y)+k1y+k4y)/3;
    vz:=vz+(2*(k2z+k3z)+k1z+k4z)/3;
    ect:=ect+pas;
   End;
  xc0:=xc; yc0:=yc; zc0:=zc;
  vx0:=vx; vy0:=vy; vz0:=vz;
 End;

 Procedure ComputeStateAtTosc;
 Var x,y,z,zk,yk:Extended;
 Begin
  prm:=dper*(1+exc);
  cst:=0.0172020909895*sqrt(prm);
  Case typ Of
   'E' : Begin
          If tpr='M' Then anorg:=pi*anorg/180
                     Else anorg:=0.01720209895*(tosc-tpas)/(dga*sqrt(dga));
          yk:=10; zk:=anorg;
          While Abs(yk)>LIM Do
           Begin yk:=(anorg-zk+exc*sin(zk))/(1-exc*cos(zk)); zk:=zk+yk; End;
          x:=dga*(cos(zk)-exc);
          y:=dga*sqrt(1-exc*exc)*sin(zk);
         End;
   'P' : Begin
          anorg:=0.05160629685*(tosc-tpas)/(dper*sqrt(8*dper));
          yk:=exp(ln(anorg+sqrt(1+anorg*anorg))/3);
          If yk=0 Then zk:=0 Else zk:=(yk*yk-1)/yk;
          x:=dper*(1-zk*zk);
          y:=2*dper*zk;
         End;
   'H' : Begin
          anorg:=0.01720209895*(tosc-tpas)/(dga*sqrt(dga));
          yk:=10; zk:=anorg;
          While Abs(yk)>LIM Do
           Begin
            yk:=(2*(anorg+zk)+exc*(exp(-zk)-exp(zk)))/(exc*(exp(-zk)+exp(zk))-2);
            zk:=zk+yk;
           End;
          x:=dga*(exc-0.5*(exp(zk)+exp(-zk)));
          y:=0.5*dga*sqrt(exc*exc-1)*(exp(zk)-exp(-zk));
         End;
  End;
  xc0:=UA*(px*x+qx*y);
  yc0:=UA*(py*x+qy*y);
  zc0:=UA*(pz*x+qz*y);
  vx:=(exc*x-prm)*y;
  vy:=(exc*y*y+prm*x);
  z:=UA*cst/(86400*prm*(x*x+y*y));
  vx0:=z*(px*vx+qx*vy);
  vy0:=z*(py*vx+qy*vy);
  vz0:=z*(pz*vx+qz*vy);
 End;

 Procedure EphCometeAt;
 { Calcul et impression de l'ephemeride a l'instant jd. xc0,yc0,zc0,vx0..vz0
   doivent contenir l'etat osculateur a l'epoque otd. }
 Var sigDc:Char; i:LongInt;
 Begin
  Integration;
  otd:=jd;
  t:=(jd-2451545.0)/365250.0;
  GeoSpeed;
  ppa:=-(470029-t*(3301-60*t))*t*pi/648000000.0;
  gpa:=(629554982+t*(41592878+114649*t))*pi/648000000.0;
  pa:=(629554982-t*(8698088-t*(3536+6*t)))*pi/648000000.0;
  xx:=cos(pa)*cos(gpa)+sin(pa)*cos(ppa)*sin(gpa);
  xy:=cos(pa)*sin(gpa)-sin(pa)*cos(ppa)*cos(gpa);
  xz:=-sin(pa)*sin(ppa);
  yx:=sin(pa)*cos(gpa)-cos(pa)*cos(ppa)*sin(gpa);
  yy:=sin(pa)*sin(gpa)+cos(pa)*cos(ppa)*cos(gpa);
  yz:=cos(pa)*sin(ppa);
  zx:=sin(ppa)*sin(gpa);
  zy:=-sin(ppa)*cos(gpa);
  zz:=cos(ppa);
  xec0:=xx*x0+xy*y0+xz*z0;
  yec0:=yx*x0+yy*y0+yz*z0;
  zec0:=zx*x0+zy*y0+zz*z0;
  xeq0:=xec0;
  yeq0:=yec0*cos(eps2)-zec0*sin(eps2);
  zeq0:=yec0*sin(eps2)+zec0*cos(eps2);
  x:=xx*vxe0+xy*vye0+xz*vze0;
  y:=yx*vxe0+yy*vye0+yz*vze0;
  d:=zx*vxe0+zy*vye0+zz*vze0;
  vxe0:=x; vye0:=y; vze0:=d;
  If xec0<>0 Then lgsn:=180*arctan(yec0/xec0)/pi Else lgsn:=90*yec0/Abs(yec0);
  If xec0<0 Then lgsn:=lgsn+180;
  If lgsn<0 Then lgsn:=lgsn+360;
  btsn:=180*arctan(zec0/sqrt(xec0*xec0+yec0*yec0))/pi;
  If xeq0<>0 Then adsn:=12*arctan(yeq0/xeq0)/pi Else adsn:=6*yeq0/Abs(yeq0);
  If xeq0<0 Then adsn:=adsn+12;
  If adsn<0 Then adsn:=adsn+24;
  dcsn:=180*arctan(zeq0/sqrt(xeq0*xeq0+yeq0*yeq0))/pi;
  xr:=xc-xec0; yr:=yc-yec0; zr:=zc-zec0;
  rau:=sqrt(xc*xc+yc*yc+zc*zc);
  delta:=sqrt(xr*xr+yr*yr+zr*zr);
  For i:=1 To MAXITER Do
   Begin
    dt:=sqrt(xr*xr+yr*yr+zr*zr)/VLM;
    xr:=xc-xec0-vx*dt;
    yr:=yc-yec0-vy*dt;
    zr:=zc-zec0-vz*dt;
   End;
  dvx:=vx-vxe0; dvy:=vy-vye0; dvz:=vz-vze0;
  vh:=sqrt(vx*vx+vy*vy+vz*vz);
  vg:=sqrt(dvx*dvx+dvy*dvy+dvz*dvz);
  wrk:=sqrt(xc*xc+yc*yc);
  If xc<>0 Then lgc:=arctan(yc/xc)*180/pi Else If yc<>0 Then lgc:=90*Abs(yc)/yc Else lgc:=0;
  If xc<0 Then lgc:=lgc+180;
  If lgc<0 Then lgc:=lgc+360;
  If wrk<>0 Then btc:=arctan(zc/wrk)*180/pi Else btc:=90*Abs(zc)/zc;
  wrk:=sqrt(xr*xr+yr*yr+zr*zr);
  elg:=-(xr*xec0+yr*yec0+zr*zec0)/(wrk*r0);
  elg:=arctan(sqrt(1.0-elg*elg)/elg)*180/pi;
  If elg<0.0 Then elg:=elg+180.0;
  wrk:=wrk*sqrt((xr+xec0)*(xr+xec0)+(yr+yec0)*(yr+yec0)+(zr+zec0)*(zr+zec0));
  phs:=(xr*(xr+xec0)+yr*(yr+yec0)+zr*(zr+zec0))/wrk;
  If phs<>0 Then phs:=arctan(sqrt(1-phs*phs)/phs)*180/pi Else phs:=90;
  If phs<0 Then phs:=phs+180;
  If flgt Then
   Begin
    If mgr>1.0 Then mg1:=mgt+(((2*ln(delta/UA)+mgr*ln(rau/UA))*2.5)/ln(10))
    Else
     Begin
      wrk:=phs*pi/360.0;
      wrk:=ln(sin(wrk)/cos(wrk));
      p1:=exp(-3.33*exp(0.63*wrk));
      p2:=exp(-1.87*exp(1.22*wrk));
      mg1:=mgt+(5*ln((delta*rau)/(UA*UA))-2.5*ln((1.0-mgr)*p1+mgr*p2))/ln(10);
     End;
   End;
  xc2:=xr;
  yc2:=yr*cos(eps2)-zr*sin(eps2);
  zc2:=yr*sin(eps2)+zr*cos(eps2);
  ppa:=-2351*pi/64800000;
  gpa:=125997979*pi/129600000;
  pa:=1003961*pi/1036800;
  xx:=cos(pa)*cos(gpa)+sin(pa)*cos(ppa)*sin(gpa);
  xy:=cos(pa)*sin(gpa)-sin(pa)*cos(ppa)*cos(gpa);
  xz:=-sin(pa)*sin(ppa);
  yx:=sin(pa)*cos(gpa)-cos(pa)*cos(ppa)*sin(gpa);
  yy:=sin(pa)*sin(gpa)+cos(pa)*cos(ppa)*cos(gpa);
  yz:=cos(pa)*sin(ppa);
  zx:=sin(ppa)*sin(gpa);
  zy:=-sin(ppa)*cos(gpa);
  zz:=cos(ppa);
  xc1:=xx*xr+xy*yr+xz*zr;
  y:=yx*xr+yy*yr+yz*zr;
  d:=zx*xr+zy*yr+zz*zr;
  yc1:=y*cos(eps1)-d*sin(eps1);
  zc1:=y*sin(eps1)+d*cos(eps1);
  ppa:=-11759*pi/162000000;
  gpa:=315212413*pi/324000000;
  pa:=625396841*pi/648000000;
  xx:=cos(pa)*cos(gpa)+sin(pa)*cos(ppa)*sin(gpa);
  xy:=cos(pa)*sin(gpa)-sin(pa)*cos(ppa)*cos(gpa);
  xz:=-sin(pa)*sin(ppa);
  yx:=sin(pa)*cos(gpa)-cos(pa)*cos(ppa)*sin(gpa);
  yy:=sin(pa)*sin(gpa)+cos(pa)*cos(ppa)*cos(gpa);
  yz:=cos(pa)*sin(ppa);
  zx:=sin(ppa)*sin(gpa);
  zy:=-sin(ppa)*cos(gpa);
  zz:=cos(ppa);
  xco:=xx*xr+xy*yr+xz*zr;
  y:=yx*xr+yy*yr+yz*zr;
  d:=zx*xr+zy*yr+zz*zr;
  yco:=y*cos(eps0)-d*sin(eps0);
  zco:=y*sin(eps0)+d*cos(eps0);
  t:=(jd-2451545)/365250;
  CalcNut;
  eps:=pi*(deps+84381.448+t*((1.813*t-0.059)*t-468.15))/648000;
  ppa:=(470029+t*(60*t-3302))*t*pi/648000000.0;
  gpa:=(629554982-t*(8698089-3536*t))*pi/648000000.0;
  pa:=gpa+((pi*dpsi)/648000.0)+(50290966+t*(111113-6*t))*t*pi/648000000.0;
  xx:=cos(pa)*cos(gpa)+sin(pa)*cos(ppa)*sin(gpa);
  xy:=cos(pa)*sin(gpa)-sin(pa)*cos(ppa)*cos(gpa);
  xz:=-sin(pa)*sin(ppa);
  yx:=sin(pa)*cos(gpa)-cos(pa)*cos(ppa)*sin(gpa);
  yy:=sin(pa)*sin(gpa)+cos(pa)*cos(ppa)*cos(gpa);
  yz:=cos(pa)*sin(ppa);
  zx:=sin(ppa)*sin(gpa);
  zy:=-sin(ppa)*cos(gpa);
  zz:=cos(ppa);
  x:=xx*xc+xy*yc+xz*zc;
  y:=yx*xc+yy*yc+yz*zc;
  d:=zx*xc+zy*yc+zz*zc;
  u:=xx*dvx+xy*dvy+xz*dvz;
  f:=yx*dvx+yy*dvy+yz*dvz;
  omg:=zx*dvx+zy*dvy+zz*dvz;  { stockage temporaire dans omg }
  xx:=x-x0; xy:=y-y0; xz:=d-z0;
  dt:=sqrt(xx*xx+xy*xy+xz*xz)/VLM;
  For i:=1 To MAXITER Do
   Begin
    zx:=xx-u*dt; zy:=xy-f*dt; zz:=xz-omg*dt;
    dt:=sqrt(zx*zx+zy*zy+zz*zz)/VLM;
   End;
  xr:=zx;
  yr:=zy*cos(eps)-zz*sin(eps);
  zr:=zy*sin(eps)+zz*cos(eps);
  u:=yx;
  f:=yy*cos(eps)-yz*sin(eps);
  omg:=yy*sin(eps)+yz*cos(eps);
  x:=xr+60*u;
  y:=yr+60*f;
  d:=zr+60*omg;
  wrk:=sqrt(xr*xr+yr*yr+zr*zr);
  u:=xr/wrk; f:=yr/wrk; omg:=zr/wrk;
  wrk:=sqrt(x*x+y*y+d*d);
  x:=x/wrk; y:=y/wrk; d:=d/wrk;
  dma:=(u*y-f*x)/((u*x+f*y+omg*d)*sqrt(u*u+f*f));
  dmd:=(d*(u*u+f*f)-omg*(u*x+f*y))/((u*x+f*y+omg*d)*sqrt(u*u+f*f));
  dmmd:=648000*arctan(sqrt(dma*dma+dmd*dmd))/pi;
  If dmd<>0 Then dmth:=180*arctan(dma/dmd)/pi
            Else If dma=0 Then dmth:=0 Else dmth:=90*Abs(dma)/dma;
  If dmd<0 Then dmth:=dmth+180;
  If dmth<0 Then dmth:=dmth+360;
  dma:=648000*arctan(dma)/(pi*sqrt(u*u+f*f));
  dmd:=648000*arctan(dmd)/pi;
  If xr=0.0 Then adc:=6.0*yr/Abs(yr) Else adc:=arctan(yr/xr)*12/pi;
  If xr<0.0 Then adc:=adc+12.0;
  If adc<0.0 Then adc:=adc+24.0;
  wrk:=sqrt(xr*xr+yr*yr);
  If wrk<>0 Then dcc:=arctan(zr/wrk)*180/pi Else dcc:=90*zr/Abs(zr);
  ads:=3600*adc;
  If dcc<0.0 Then sigDc:='-' Else sigDc:='+';
  dcs:=3600*Abs(dcc);
  adh:=Trunc(adc);
  adm:=Trunc(ads/60.0);
  ads:=ads-60.0*adm;
  adm:=adm Mod 60;
  dcd:=Trunc(Abs(dcc));
  dcm:=Trunc(dcs/60.0);
  dcs:=dcs-60.0*dcm;
  dcm:=dcm Mod 60;
  If xc2<>0 Then ad2c:=arctan(yc2/xc2)*12/pi
            Else If yc2=0 Then ad2c:=0 Else ad2c:=6*yc2/Abs(yc2);
  If xc2<0 Then ad2c:=ad2c+12;
  If ad2c<0 Then ad2c:=ad2c+24;
  wrk:=sqrt(xc2*xc2+yc2*yc2);
  If wrk<>0 Then dc2c:=arctan(zc2/wrk)*180/pi Else dc2c:=90*zc2/Abs(zc2);
  If xc1<>0 Then ad1c:=arctan(yc1/xc1)*12/pi
            Else If yc1=0 Then ad1c:=0 Else ad1c:=6*yc1/Abs(yc1);
  If xc1<0 Then ad1c:=ad1c+12;
  If ad1c<0 Then ad1c:=ad1c+24;
