Procedure ZeroItem(Var It:TMenuItem);
Begin
 It.Caption:='';
 It.Action:=-1;
 It.Separator:=False;
 It.Enabled:=True;
 It.Checked:=False;
End;

Procedure MI(MenuIdx:Integer; Const Cap:String; Action:Integer);
{ Ajoute un item normal. }
Var It:TMenuItem; N:Integer;
Begin
 ZeroItem(It);
 It.Caption:=Cap;
 It.Action:=Action;
 N:=Menus[MenuIdx].ItemCount;
 If N<MAX_MENU_ITEMS Then Begin
  Menus[MenuIdx].Items[N]:=It;
  Menus[MenuIdx].ItemCount:=N+1;
 End;
End;

Procedure MSep(MenuIdx:Integer);
{ Ajoute un separateur. }
Var It:TMenuItem; N:Integer;
Begin
 ZeroItem(It);
 It.Separator:=True;
 N:=Menus[MenuIdx].ItemCount;
 If N<MAX_MENU_ITEMS Then Begin
  Menus[MenuIdx].Items[N]:=It;
  Menus[MenuIdx].ItemCount:=N+1;
 End;
End;

