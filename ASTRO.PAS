 If elg>180 Then elg:=elg-360;
 v:=us*(us+xs)+vs*(vs+ys)*cos(eps)*cos(eps)+ws*(ws+zs)*sin(eps)*sin(eps)+(ws*(vs+ys)+vs*(ws+zs))*cos(eps)*sin(eps);
 If v<>0 Then dlg:=180*arctan(z/v)/pi Else dlg:=90*z/Abs(z);
