Function ToolbarHitTest(X,Y:LongInt):Integer;
Var I:Integer;
Begin
 ToolbarHitTest:=-1;
 For I:=0 To NUM_TOOLS-1 Do
  If PtInRect(X,Y,ToolButtons[I].R) Then Begin
   ToolbarHitTest:=I; Exit;
  End;
End;

Procedure RedrawAll;
Begin
 HideMouse;
 DrawMainBackground;
 DrawMenuBar;
 DrawToolbar;
 DrawStatusBar('Pret');
 ShowMouse;
End;

Procedure DrawMenuPopup(MenuIdx:Integer);
Var
 R:TRect;
 I,Y,W,H:Integer;
 ItRect:TRect;
Begin
 W:=0;
 For I:=0 To Menus[MenuIdx].ItemCount-1 Do
  If Length(Menus[MenuIdx].Items[I].Caption)*8+20 > W Then
   W:=Length(Menus[MenuIdx].Items[I].Caption)*8+20;
 If W<120 Then W:=120;
 H:=Menus[MenuIdx].ItemCount*16+4;
 R:=MkRect(Menus[MenuIdx].BarX1,MENUBAR_HEIGHT,
           Menus[MenuIdx].BarX1+W,MENUBAR_HEIGHT+H);
 SetFillStyle(1,CLR_BTN);
 Bar(R.X1,R.Y1,R.X2,R.Y2);
 SetColor(CLR_FG);
 Rectangle(R.X1,R.Y1,R.X2,R.Y2);
 Y:=R.Y1+2;
 For I:=0 To Menus[MenuIdx].ItemCount-1 Do Begin
  ItRect:=MkRect(R.X1+1,Y,R.X2-1,Y+14);
  If Menus[MenuIdx].Items[I].Separator Then Begin
   SetColor(CLR_BTN_DARK);
   Line(R.X1+4,Y+7,R.X2-4,Y+7);
  End
  Else Begin
   If I=ActiveMenuItem Then Begin
    SetFillStyle(1,CLR_SEL_BG);
    Bar(ItRect.X1,ItRect.Y1,ItRect.X2,ItRect.Y2);
    SetColor(CLR_SEL_FG);
   End
   Else
    SetColor(CLR_FG);
   OutTextXY(R.X1+10,Y+3,Menus[MenuIdx].Items[I].Caption);
   If Menus[MenuIdx].Items[I].Checked Then
    OutTextXY(R.X1+2,Y+3,Chr(251));
  End;
  Y:=Y+16;
 End;
End;

Function MenuBarHitTest(X,Y:LongInt):Integer;
Var I:Integer;
Begin
 MenuBarHitTest:=-1;
 If (Y<0) Or (Y>=MENUBAR_HEIGHT) Then Exit;
 For I:=0 To NUM_MENUS-1 Do
  If (X>=Menus[I].BarX1) And (X<=Menus[I].BarX2) Then Begin
   MenuBarHitTest:=I; Exit;
  End;
End;

Function MenuItemHitTest(MenuIdx:Integer; X,Y:LongInt):Integer;
Var W,H,Idx:Integer;
Begin
 MenuItemHitTest:=-1;
 W:=0;
 For Idx:=0 To Menus[MenuIdx].ItemCount-1 Do
  If Length(Menus[MenuIdx].Items[Idx].Caption)*8+20 > W Then
   W:=Length(Menus[MenuIdx].Items[Idx].Caption)*8+20;
 If W<120 Then W:=120;
 H:=Menus[MenuIdx].ItemCount*16+4;
 If (X<Menus[MenuIdx].BarX1) Or (X>Menus[MenuIdx].BarX1+W) Then Exit;
 If (Y<MENUBAR_HEIGHT+2) Or (Y>MENUBAR_HEIGHT+H-2) Then Exit;
 Idx:=(Y-MENUBAR_HEIGHT-2) Div 16;
 If (Idx>=0) And (Idx<Menus[MenuIdx].ItemCount) And
    Not Menus[MenuIdx].Items[Idx].Separator Then
  MenuItemHitTest:=Idx;
End;

