Procedure DrawMenuBar;
Var I,TX:Integer;
Begin
 SetFillStyle(1,CLR_BTN);
 Bar(0,0,SCREEN_WIDTH-1,MENUBAR_HEIGHT-1);
 SetColor(CLR_BTN_DARK);
 Line(0,MENUBAR_HEIGHT-1,SCREEN_WIDTH-1,MENUBAR_HEIGHT-1);
 For I:=0 To NUM_MENUS-1 Do Begin
  If (MenuActive) And (I=ActiveMenu) Then Begin
   SetFillStyle(1,CLR_SEL_BG);
   Bar(Menus[I].BarX1,2,Menus[I].BarX2,MENUBAR_HEIGHT-2);
   SetColor(CLR_SEL_FG);
  End
  Else
   SetColor(CLR_FG);
  TX:=Menus[I].BarX1+6;
  OutTextXY(TX,6,Menus[I].Caption);
 End;
End;

