Function InputString(Const Title,Prompt:String; Var S:String; MaxLen:Integer):Boolean;
{ Boite de dialogue avec un champ texte et boutons OK / Annuler. }
Var
 DlgR,FieldR,BtnOK,BtnCancel:TRect;
 K:Char;
 Done,Accepted:Boolean;
 MX,MY,MB,OldMB:LongInt;
 NeedDraw:Boolean;
 Focus:Integer;       { 0=field 1=OK 2=Cancel }
Begin
 DlgR:=MkRect(120,150,520,300);
 FieldR:=MkRect(DlgR.X1+20,DlgR.Y1+70,DlgR.X2-20,DlgR.Y1+90);
 BtnOK:=MkRect(DlgR.X1+90,DlgR.Y2-40,DlgR.X1+190,DlgR.Y2-15);
 BtnCancel:=MkRect(DlgR.X1+210,DlgR.Y2-40,DlgR.X1+310,DlgR.Y2-15);
 Done:=False;
 Accepted:=False;
 NeedDraw:=True;
 OldMB:=0;
 Focus:=0;
 While Not Done Do Begin
  If NeedDraw Then Begin
   HideMouse;
   DrawDialogBox(DlgR,Title);
   SetColor(CLR_FG);
   OutTextXY(DlgR.X1+20,DlgR.Y1+40,Prompt);
   SetFillStyle(1,CLR_FIELD_BG);
   Bar(FieldR.X1,FieldR.Y1,FieldR.X2,FieldR.Y2);
   SetColor(CLR_DLG_FRAME);
   Rectangle(FieldR.X1,FieldR.Y1,FieldR.X2,FieldR.Y2);
   SetColor(CLR_FIELD_FG);
   OutTextXY(FieldR.X1+4,FieldR.Y1+6,S);
   { curseur }
   SetColor(CLR_FIELD_FG);
   Line(FieldR.X1+6+8*Length(S),FieldR.Y1+5,
        FieldR.X1+6+8*Length(S),FieldR.Y1+15);
   DrawButton(BtnOK,'OK',Focus=1);
   DrawButton(BtnCancel,'Annuler',Focus=2);
   ShowMouse;
   NeedDraw:=False;
  End;
  If KeyPressed Then Begin
   K:=ReadKey;
   If K=#27 Then Begin Done:=True; Accepted:=False; End
   Else If K=#13 Then Begin Done:=True; Accepted:=True; End
   Else If K=#8 Then Begin
    If Length(S)>0 Then Begin
     S:=Copy(S,1,Length(S)-1);
     NeedDraw:=True;
    End;
   End
   Else If (K>=' ') And (K<=#126) And (Length(S)<MaxLen) Then Begin
    S:=S+K;
    NeedDraw:=True;
   End
   Else If K=#0 Then Begin
    K:=ReadKey; { ignorer touches speciales }
   End;
  End;
  If HasMouse Then Begin
   ReadMouse(MX,MY,MB);
   If (MB=1) And (OldMB=0) Then Begin
    If PtInRect(MX,MY,BtnOK) Then Begin Done:=True; Accepted:=True; End
    Else If PtInRect(MX,MY,BtnCancel) Then Begin Done:=True; Accepted:=False; End;
   End;
   OldMB:=MB;
  End;
  Delay(15);
 End;
 InputString:=Accepted;
End;

Procedure ShowMessage(Const Title,Msg:String);
Const
 MAX_LINES = 20;
 MAX_COLS  = 40;     { 360px utiles / 8px par char }
 CHAR_W    = 8;
 LINE_H    = 10;
Var
 DlgR,BtnOK:TRect;
 K:Char;
 Done:Boolean;
 MX,MY,MB,OldMB:LongInt;
 Lines:Array[1..MAX_LINES] Of String;
 NLines,I,P,L,LastSp:Integer;
 Rest,Cur:String;
 H,DlgW,DlgH,Cx:Integer;
Begin
 { Decoupage en lignes : retour a la ligne sur dernier espace avant MAX_COLS,
   ou coupe brute si pas d'espace. Sauts de ligne explicites (#13 ou #10)
   respectes. }
 NLines:=0;
 Rest:=Msg;
 While (NLines<MAX_LINES) And (Length(Rest)>0) Do Begin
  { Couper sur saut de ligne explicite si present avant MAX_COLS. }
  P:=0;
  For I:=1 To Length(Rest) Do
   If (Rest[I]=#13) Or (Rest[I]=#10) Then Begin P:=I; Break; End;
  If (P>0) And (P<=MAX_COLS+1) Then Begin
   Cur:=Copy(Rest,1,P-1);
   Delete(Rest,1,P);
   If (Length(Rest)>0) And ((Rest[1]=#10) Or (Rest[1]=#13)) Then
    Delete(Rest,1,1);
  End
  Else If Length(Rest)<=MAX_COLS Then Begin
   Cur:=Rest; Rest:='';
  End
  Else Begin
   LastSp:=0;
   For I:=1 To MAX_COLS Do
    If Rest[I]=' ' Then LastSp:=I;
   If LastSp=0 Then L:=MAX_COLS Else L:=LastSp-1;
   Cur:=Copy(Rest,1,L);
   Delete(Rest,1,L);
   While (Length(Rest)>0) And (Rest[1]=' ') Do Delete(Rest,1,1);
  End;
  Inc(NLines); Lines[NLines]:=Cur;
 End;
 If NLines=0 Then Begin NLines:=1; Lines[1]:=''; End;
 { Dimensionnement dynamique. }
 DlgW:=360;
 DlgH:=45 + NLines*LINE_H + 50;   { 45 entete + N*ligne + 50 bouton/marge }
 If DlgH<130 Then DlgH:=130;
 Cx:=SCREEN_WIDTH Div 2;
 H:=SCREEN_HEIGHT Div 2;
 DlgR:=MkRect(Cx-DlgW Div 2,H-DlgH Div 2,
              Cx+DlgW Div 2,H+DlgH Div 2);
 BtnOK:=MkRect(DlgR.X1+(DlgW-100) Div 2,DlgR.Y2-40,
               DlgR.X1+(DlgW-100) Div 2+100,DlgR.Y2-15);
 HideMouse;
 DrawDialogBox(DlgR,Title);
 SetColor(CLR_FG);
 For I:=1 To NLines Do
  OutTextXY(DlgR.X1+20,DlgR.Y1+40+(I-1)*LINE_H,Lines[I]);
 DrawButton(BtnOK,'OK',True);
 ShowMouse;
 Done:=False; OldMB:=0;
 Repeat
  If KeyPressed Then Begin
   K:=ReadKey;
   If (K=#13) Or (K=#27) Or (K=' ') Then Done:=True;
   If K=#0 Then K:=ReadKey;
  End;
  If HasMouse Then Begin
   ReadMouse(MX,MY,MB);
   If (MB=1) And (OldMB=0) And PtInRect(MX,MY,BtnOK) Then Done:=True;
   OldMB:=MB;
  End;
  Delay(15);
 Until Done;
End;

Function InputInt(Const Title,Prompt:String; Var V:LongInt):Boolean;
Var S:String; Code:Integer; OK:Boolean;
Begin
 Str(V,S);
 OK:=InputString(Title,Prompt,S,15);
 If OK Then Begin
  Val(S,V,Code);
  If Code<>0 Then Begin
   ShowMessage('Erreur','Valeur entiere invalide.');
   OK:=False;
  End;
 End;
 InputInt:=OK;
End;

Function InputReal(Const Title,Prompt:String; Var V:Extended):Boolean;
Var S:String; Code:Integer; OK:Boolean;
Begin
 Str(V:0:6,S);
 OK:=InputString(Title,Prompt,S,30);
 If OK Then Begin
  Val(S,V,Code);
  If Code<>0 Then Begin
   ShowMessage('Erreur','Valeur reelle invalide.');
   OK:=False;
  End;
 End;
 InputReal:=OK;
End;

Function ParseTriplet(Const S:String; Var A,B,C:LongInt):Boolean;
{ Decoupe "j m a" ou "j/m/a" ou "j-m-a" en 3 entiers. }
Var
 I,Idx:Integer;
 Parts:Array[1..3] Of String;
 Code:Integer;
Begin
 Parts[1]:=''; Parts[2]:=''; Parts[3]:='';
 Idx:=1;
 For I:=1 To Length(S) Do Begin
  Case S[I] Of
   ' ','/','-',',',';',#9:
    If Parts[Idx]<>'' Then Begin
     Inc(Idx);
     If Idx>3 Then Begin ParseTriplet:=False; Exit; End;
    End;
   Else
    If Idx<=3 Then Parts[Idx]:=Parts[Idx]+S[I];
  End;
 End;
 If (Parts[1]='') Or (Parts[2]='') Or (Parts[3]='') Then Begin
  ParseTriplet:=False; Exit;
 End;
 Val(Parts[1],A,Code); If Code<>0 Then Begin ParseTriplet:=False; Exit; End;
 Val(Parts[2],B,Code); If Code<>0 Then Begin ParseTriplet:=False; Exit; End;
 Val(Parts[3],C,Code); If Code<>0 Then Begin ParseTriplet:=False; Exit; End;
 ParseTriplet:=True;
End;

Function InputDate(Const Title:String; Var qd,md,ad:LongInt):Boolean;
Var S:String; OK:Boolean;
Begin
 S:=FmtI(qd,1)+' '+FmtI(md,1)+' '+FmtI(ad,1);
 Repeat
  OK:=InputString(Title,'Date (jour mois annee, ex: 15 10 1582):',S,30);
  If Not OK Then Begin InputDate:=False; Exit; End;
  If Not ParseTriplet(S,qd,md,ad) Then Begin
   ShowMessage('Erreur','Format invalide. Utilisez "jour mois annee".');
   OK:=False;
  End
  Else If Not DateOK(qd,md,ad) Then Begin
   ShowMessage('Erreur','Date invalide (verifier jour/mois/bissextile ou bascule gregorienne).');
   OK:=False;
  End;
 Until OK;
 InputDate:=True;
End;

Function InputTime(Const Title:String; Var hh,mm:LongInt; Var ss:Extended):Boolean;
Var S:String; OK:Boolean; A,B,C:LongInt;
Begin
 Str(ss:0:0,S);
 S:=FmtI(hh,1)+' '+FmtI(mm,1)+' '+S;
 Repeat
  OK:=InputString(Title,'Heure (h m s, en TU):',S,30);
  If Not OK Then Begin InputTime:=False; Exit; End;
  If Not ParseTriplet(S,A,B,C) Then Begin
   ShowMessage('Erreur','Format invalide.'); OK:=False;
  End
  Else Begin
   hh:=A; mm:=B; ss:=C;
   If Not HeureOK(hh,mm,ss) Then Begin
    ShowMessage('Erreur','Heure invalide (0..23, 0..59, 0..59.99).');
    OK:=False;
   End;
  End;
 Until OK;
 InputTime:=True;
End;

Function InputDateTime(Const Title:String;
                       Var qd,md,ad,hh,mm:LongInt; Var ss:Extended):Boolean;
Begin
 If Not InputDate(Title+' - date',qd,md,ad) Then Begin
  InputDateTime:=False; Exit;
 End;
 If Not InputTime(Title+' - heure',hh,mm,ss) Then Begin
  InputDateTime:=False; Exit;
 End;
 InputDateTime:=True;
End;

Function InputYear(Const Title:String; Var Y:LongInt):Boolean;
Var S:String; OK:Boolean; Code:Integer;
Begin
 Str(Y,S);
 Repeat
  OK:=InputString(Title,'Annee (ex: 2026):',S,10);
  If Not OK Then Begin InputYear:=False; Exit; End;
  Val(S,Y,Code);
  If Code<>0 Then Begin
   ShowMessage('Erreur','Annee invalide.'); OK:=False;
  End;
 Until OK;
 InputYear:=True;
End;

Function InputJD(Const Title:String; Var JDV:Extended):Boolean;
Var S:String; OK:Boolean; Code:Integer;
Begin
 Str(JDV:0:5,S);
 Repeat
  OK:=InputString(Title,'Jour julien (ex: 2451545.0):',S,25);
  If Not OK Then Begin InputJD:=False; Exit; End;
  Val(S,JDV,Code);
  If Code<>0 Then Begin
   ShowMessage('Erreur','JD invalide.'); OK:=False;
  End;
 Until OK;
 InputJD:=True;
End;

Function InputAngleDMS(Const Title,Prompt:String;
                       Var dg,mm:LongInt; Var ss:Extended;
                       Signed:Boolean):Boolean;
Var S:String; OK:Boolean; A,B,C:LongInt;
Begin
 Str(ss:0:0,S);
 S:=FmtI(dg,1)+' '+FmtI(mm,1)+' '+S;
 Repeat
  OK:=InputString(Title,Prompt+' (deg min sec):',S,30);
  If Not OK Then Begin InputAngleDMS:=False; Exit; End;
  If Not ParseTriplet(S,A,B,C) Then Begin
   ShowMessage('Erreur','Format invalide.'); OK:=False;
  End
  Else Begin
   dg:=A; mm:=B; ss:=C;
   If Signed Then Begin
    If Not LngsgOK(dg,mm,ss) Then Begin
     ShowMessage('Erreur','Angle hors plage (-180..+180).');
     OK:=False;
    End;
   End
   Else Begin
    If Not LngnsOK(dg,mm,ss) Then Begin
     ShowMessage('Erreur','Angle hors plage (0..360).');
     OK:=False;
    End;
   End;
  End;
 Until OK;
 InputAngleDMS:=True;
End;

Function YesNo(Const Title,Question:String):Boolean;
Var
 DlgR,BtnYes,BtnNo:TRect;
 K:Char;
 Done,Result:Boolean;
 MX,MY,MB,OldMB:LongInt;
 Focus:Integer;
Begin
 DlgR:=MkRect(140,170,500,290);
 BtnYes:=MkRect(DlgR.X1+90,DlgR.Y2-40,DlgR.X1+170,DlgR.Y2-15);
 BtnNo:=MkRect(DlgR.X1+200,DlgR.Y2-40,DlgR.X1+280,DlgR.Y2-15);
 HideMouse;
 DrawDialogBox(DlgR,Title);
 SetColor(CLR_FG);
 OutTextXY(DlgR.X1+20,DlgR.Y1+45,Question);
 Focus:=0; Result:=False;
 DrawButton(BtnYes,'Oui',Focus=0);
 DrawButton(BtnNo,'Non',Focus=1);
 ShowMouse;
 Done:=False; OldMB:=0;
 Repeat
  If KeyPressed Then Begin
   K:=ReadKey;
   If (K='O') Or (K='o') Or (K='Y') Or (K='y') Then Begin Result:=True; Done:=True; End
   Else If (K='N') Or (K='n') Then Begin Result:=False; Done:=True; End
   Else If K=#27 Then Begin Result:=False; Done:=True; End
   Else If K=#13 Then Begin Result:=(Focus=0); Done:=True; End
   Else If K=#9 Then Begin
    Focus:=1-Focus;
    HideMouse;
    DrawButton(BtnYes,'Oui',Focus=0);
    DrawButton(BtnNo,'Non',Focus=1);
    ShowMouse;
   End
   Else If K=#0 Then K:=ReadKey;
  End;
  If HasMouse Then Begin
   ReadMouse(MX,MY,MB);
   If (MB=1) And (OldMB=0) Then Begin
    If PtInRect(MX,MY,BtnYes) Then Begin Result:=True; Done:=True; End
    Else If PtInRect(MX,MY,BtnNo) Then Begin Result:=False; Done:=True; End;
   End;
   OldMB:=MB;
  End;
  Delay(15);
 Until Done;
 YesNo:=Result;
End;

