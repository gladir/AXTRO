Function PtInRect(X,Y:LongInt; R:TRect):Boolean;
Begin
 PtInRect:=(X>=R.X1) And (X<=R.X2) And (Y>=R.Y1) And (Y<=R.Y2);
End;

Function MkRect(X1,Y1,X2,Y2:Integer):TRect;
Var R:TRect;
Begin
 R.X1:=X1; R.Y1:=Y1; R.X2:=X2; R.Y2:=Y2;
 MkRect:=R;
End;

Procedure FillRect(R:TRect; Color:Integer);
Begin
 SetFillStyle(1,Color);
 Bar(R.X1,R.Y1,R.X2,R.Y2);
End;

Procedure FrameRect(R:TRect; Color:Integer);
Begin
 SetColor(Color);
 Rectangle(R.X1,R.Y1,R.X2,R.Y2);
End;

Procedure DrawText(X,Y:Integer; Color:Integer; Const S:String);
Begin
 SetColor(Color);
 OutTextXY(X,Y,S);
End;

Procedure DrawButton(R:TRect; Const Caption:String; Focused:Boolean);
{ Bouton avec effet 3D (relief clair haut/gauche, sombre bas/droit). }
Var
 TX,TY:Integer;
Begin
 FillRect(R,CLR_BTN);
 SetColor(CLR_BTN_LIGHT);
 Line(R.X1,R.Y1,R.X2,R.Y1);
 Line(R.X1,R.Y1,R.X1,R.Y2);
 SetColor(CLR_BTN_DARK);
 Line(R.X1,R.Y2,R.X2,R.Y2);
 Line(R.X2,R.Y1,R.X2,R.Y2);
 TX:=(R.X1+R.X2-8*Length(Caption)) Div 2;
 TY:=(R.Y1+R.Y2-8) Div 2;
 SetColor(CLR_FG);
 OutTextXY(TX,TY,Caption);
 If Focused Then Begin
  SetColor(CLR_BTN_FOCUS);
  Rectangle(R.X1+2,R.Y1+2,R.X2-2,R.Y2-2);
 End;
End;

Procedure DrawDialogBox(R:TRect; Const Title:String);
Var
 TitleR:TRect;
Begin
 FillRect(R,CLR_DLG_BG);
 FrameRect(R,CLR_DLG_FRAME);
 TitleR:=MkRect(R.X1+1,R.Y1+1,R.X2-1,R.Y1+18);
 FillRect(TitleR,CLR_TITLE_BG);
 SetColor(CLR_TITLE_FG);
 OutTextXY(R.X1+8,R.Y1+5,Title);
End;

