{$IFNDEF FPC}
Function ArcSin(X:Extended):Extended;
Begin
 If Abs(X)>=1.0 Then Begin
  If X>0 Then ArcSin:=PI/2 Else ArcSin:=-PI/2;
 End
 Else
  ArcSin:=ArcTan(X/Sqrt(1.0-X*X));
End;

Function ArcTan2(Y,X:Extended):Extended;
Begin
 If X>0 Then ArcTan2:=ArcTan(Y/X)
 Else If X<0 Then Begin
  If Y>=0 Then ArcTan2:=ArcTan(Y/X)+PI
  Else ArcTan2:=ArcTan(Y/X)-PI;
 End
 Else Begin
  If Y>0 Then ArcTan2:=PI/2
  Else If Y<0 Then ArcTan2:=-PI/2
  Else ArcTan2:=0.0;
 End;
End;
{$ENDIF}

Procedure InitializeGraphics;
Var
 Driver, Mode: Integer;
 ErrCode: Integer;
Begin
 {$IFDEF FPC}
  Driver:=VGA;
  Mode:=VGAHi;
 {$ELSE}
  Driver:=Detect;
  Mode:=VGAHi;
 {$ENDIF}
 InitGraph(Driver,Mode,'');
 ErrCode:=GraphResult;
 If ErrCode=grOk Then Begin
  SetColor(White);
  SetLineStyle(0,0,1);
 End
  Else
 Begin
  WriteLn('Erreur graphique : ',GraphErrorMsg(ErrCode));
  Halt;
 End;
End;

